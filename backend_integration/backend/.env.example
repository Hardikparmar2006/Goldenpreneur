# =============================================================================
# Golden preneur Backend — Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to git
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://goldenpreneur.in

# ── MySQL Database ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=Golden preneur
