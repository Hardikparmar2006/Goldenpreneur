   © 2026 Golden preneur | 1 Million Entrepreneurs International Forum | NGO Certified | Viksit Bharat @2047\n                </div>\n                <div class=\"font-serif italic text-white/30 text-sm\" data-kid=\"332\">\n                    आइए, साथ मिलकर एक बेहतर भविष्य का निर्माण करें।\n                </div>\n            </div>\n        </div>\n    </footer>\n\n    \n    <div class=\"relative pb-24 overflow-hidden\" data-kid=\"333\">\n        <a href=\"#\" class=\"absolute right-10 bottom-10 w-20 h-20 bg-[#25D366] text-white rounded-[2rem] flex items-center justify-center text-4xl shadow-2xl hover:scale-110 active:scale-95 transition-all z-[100] group\" data-kid=\"334\">\n            <svg class=\"w-10 h-10\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"335\"><path d=\"M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.301-.15-.1.78-.1-.151 0-.11-.078-.271-.1-.32-.457-.621-1.489-1.247-1.638-1.322-.15-.075-.26-.112-.367.05-.107.163-.414.521-.507.625-.093.104-.186.117-.487.033-.3-.15-1.268-.467-2.414-1.489-.893-.797-1.495-1.78-1.671-2.08-.176-.3-.019-.462.131-.611.135-.134.3-.349.45-.524.15-.175.2-.299.3-.499.1-.2.05-.375-.025-.525-.075-.15-.675-1.625-.925-2.225-.244-.582-.493-.503-.677-.512-.175-.008-.375-.01-.575-.01-.2 0-.525.075-.8.375-.275.3-1.05 1.025-1.05 2.5s1.075 2.9 1.225 3.1c.15.2 2.112 3.226 5.118 4.525.715.309 1.274.494 1.708.632.718.228 1.372.196 1.889.119.576-.087 1.776-.726 2.026-1.426.25-.7 0-1.296-.075-1.422-.075-.125-.275-.2-.575-.35z\" data-kid=\"336\"></path></svg>\n            <span class=\"absolute right-full mr-4 bg-white text-[#1A1A1A] px-4 py-2 rounded-xl text-sm font-bold shadow-xl opacity-0 group-hover:opacity-100 transition-all whitespace-nowrap pointer-events-none\" data-kid=\"337\">Chat with us</span>\n        </a>\n    </div>\n</div>\n",
