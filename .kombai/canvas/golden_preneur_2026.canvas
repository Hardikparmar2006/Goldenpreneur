      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap');\n\n    :root {\n        --primary-green: #1E6B3C;\n        --dark-green: #0D3D20;\n        --accent-gold: #C9963A;\n        --cream-white: #F9F5EE;\n    }\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .gold-gradient-text {\n        background: linear-gradient(135deg, #C9963A 0%, #E8C17F 50%, #C9963A 100%);\n        -webkit-background-clip: text;\n        -webkit-text-fill-color: transparent;\n    }\n    \n    .pricing-row:hover {\n        background-color: rgba(249, 245, 238, 0.7);\n        transform: scale(1.002);\n    }\n    \n    .leaf-pattern {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0c1.105 0 2 .895 2 2v26.586l7.293-7.293c.78-.78 2.047-.78 2.828 0 .781.78.781 2.047 0 2.828L30 36.243l-12.121-12.122a2 2 0 1 1 2.828-2.828L28 28.586V2c0-1.105.895-2 2-2z' fill='%23C9963A' fill-opacity='0.03' fill-rule='evenodd'/%3E%3C/svg%3E\");\n    }\n</style>\n\n<div class=\"font-sans text-[#1A1A1A] bg-white overflow-x-hidden\" data-kid=\"1\">\n    \n    <nav class=\"relative z-50 bg-white shadow-sm border-b border-gray-100 py-4 px-6 md:px-12 flex items-center justify-between\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <div class=\"w-10 h-10 bg-[#1E6B3C] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n                <span class=\"text-white font-serif font-bold text-xl italic\" data-kid=\"5\">G</span>\n            </div>\n            <div data-kid=\"6\">\n                <h1 class=\"text-xl font-serif font-bold tracking-tight leading-none text-[#0D3D20]\" data-kid=\"7\">GOLDEN PRENEUR</h1>\n                <p class=\"text-[10px] font-sans font-bold tracking-[0.2em] text-[#C9963A] uppercase\" data-kid=\"8\">2026 Edition</p>\n            </div>\n        </div>\n        \n        <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"9\">\n            <a href=\"/\" class=\"text-sm font-semibold hover:text-[#1E6B3C] transition-colors\" data-kid=\"10\">Home</a>\n            <a href=\"/about\" class=\"text-sm font-semibold hover:text-[#1E6B3C] transition-colors\" data-kid=\"11\">About</a>\n            <a href=\"/awards\" class=\"text-sm font-semibold hover:text-[#1E6B3C] transition-colors\" data-kid=\"12\">Awards</a>\n            <a href=\"/coffee-table-book\" class=\"text-sm font-bold text-[#1E6B3C] border-b-2 border-[#1E6B3C]\" data-kid=\"13\">Coffee Table Book</a>\n            <a href=\"/sponsors\" class=\"text-sm font-semibold hover:text-[#1E6B3C] transition-colors\" data-kid=\"14\">Sponsors</a>\n        </div>\n\n        <div class=\"flex items-center gap-3\" data-kid=\"15\">\n            <a href=\"/get-pass\" class=\"hidden md:flex items-center justify-center px-5 py-2.5 border-2 border-[#1E6B3C] text-[#1E6B3C] rounded-lg text-sm font-bold hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"16\">\n                Get Pass\n            </a>\n            <a href=\"/apply\" class=\"flex items-center justify-center px-5 py-2.5 bg-[#1E6B3C] text-white rounded-lg text-sm font-bold shadow-md hover:bg-[#0D3D20] transition-all\" data-kid=\"17\">\n                Apply for Award\n            </a>\n        </div>\n    </nav>\n\n    \n    <header class=\"relative bg-[#F9F5EE] py-20 px-6 lg:px-24 overflow-hidden\" data-kid=\"18\">\n        <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16\" data-kid=\"19\">\n            <div class=\"lg:w-1/2 z-10\" data-kid=\"20\">\n                <div class=\"flex items-center gap-4 mb-6\" data-kid=\"21\">\n                    <span class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-[#0D3D20] text-white text-xs font-bold uppercase tracking-widest rounded-full\" data-kid=\"22\">\n                        <span class=\"w-2 h-2 bg-[#C9963A] rounded-full animate-pulse\" data-kid=\"23\"></span>\n                        Premium Publication 2026\n                    </span>\n                    <span class=\"text-[10px] font-bold text-[#1E6B3C] uppercase tracking-[0.2em] flex items-center gap-2\" data-kid=\"24\">\n                        <span class=\"w-1.5 h-1.5 bg-[#C9963A] rounded-full\" data-kid=\"25\"></span>\n                        Viksit Bharat @2047\n                    </span>\n                </div>\n                <h2 class=\"font-serif text-5xl lg:text-8xl text-[#0D3D20] leading-[1.1] mb-6\" data-kid=\"26\">\n                    Top 50 <br data-kid=\"27\">Sustainable <span class=\"italic text-[#C9963A]\" data-kid=\"28\">Leaders</span>\n                </h2>\n                <p class=\"text-xl text-[#0D3D20]/70 font-serif leading-relaxed mb-10 max-w-xl italic\" data-kid=\"29\">\n                    \"A curated anthology of visionaries redefining India's green economy. A legacy print edition for those who lead by example.\"\n                </p>\n                \n                <div class=\"grid grid-cols-2 gap-8 mb-12\" data-kid=\"30\">\n                    <div class=\"border-l-2 border-[#C9963A] pl-6\" data-kid=\"31\">\n                        <span class=\"block text-3xl font-serif text-[#0D3D20] font-bold\" data-kid=\"32\">5,000+</span>\n                        <span class=\"text-sm text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"33\">Print Copies</span>\n                    </div>\n                    <div class=\"border-l-2 border-[#C9963A] pl-6\" data-kid=\"34\">\n                        <span class=\"block text-3xl font-serif text-[#0D3D20] font-bold\" data-kid=\"35\">500,000+</span>\n                        <span class=\"text-sm text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"36\">Digital Reach</span>\n                    </div>\n                </div>\n\n                <div class=\"flex flex-wrap gap-4\" data-kid=\"37\">\n                    <a href=\"#apply\" class=\"px-10 py-4 bg-[#C9963A] text-white rounded-lg font-bold text-lg shadow-xl hover:bg-[#b08433] hover:-translate-y-1 transition-all\" data-kid=\"38\">\n                        Reserve Your Slot\n                    </a>\n                    <a href=\"#distribution\" class=\"px-10 py-4 border-2 border-[#0D3D20] text-[#0D3D20] rounded-lg font-bold text-lg hover:bg-[#0D3D20] hover:text-white transition-all\" data-kid=\"39\">\n                        View Sample\n                    </a>\n                </div>\n            </div>\n\n            <div class=\"lg:w-1/2 relative h-[500px] flex items-center justify-center\" data-kid=\"40\">\n                \n                <div class=\"absolute inset-0 bg-[#1E6B3C]/5 rounded-full blur-[100px]\" data-kid=\"41\"></div>\n                \n                <div class=\"relative z-10 p-4 bg-white shadow-2xl rounded-sm border-[16px] border-white transform rotate-2 hover:rotate-0 transition-all duration-700 max-w-[400px]\" data-kid=\"42\">\n                    <img src=\"https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&w=1000&q=80\" alt=\"Coffee Table Book Mockup\" class=\"w-full h-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"43\">\n                    <div class=\"absolute top-0 right-0 bg-[#C9963A] text-white px-6 py-2 transform translate-x-1/2 -translate-y-1/2 shadow-lg\" data-kid=\"44\">\n                        <span class=\"font-serif italic text-sm\" data-kid=\"45\">Limited Edition</span>\n                    </div>\n                </div>\n                \n                \n                <div class=\"absolute bottom-10 -left-6 z-20 bg-white text-[#0D3D20] p-5 rounded-2xl shadow-2xl max-w-[200px] border border-gray-100 transform -translate-y-4\" data-kid=\"46\">\n                    <p class=\"text-[10px] uppercase tracking-[0.2em] font-bold mb-2 text-[#C9963A]\" data-kid=\"47\">Status Update</p>\n                    <p class=\"font-serif text-lg leading-tight mb-2 italic\" data-kid=\"48\">Cover Story</p>\n                    <span class=\"inline-block bg-red-600 text-white text-[9px] font-bold px-3 py-1 rounded-full uppercase tracking-widest\" data-kid=\"49\">Sold Out</span>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    \n    <section class=\"py-24 px-6 lg:px-24 bg-white border-b border-gray-100 relative\" data-kid=\"50\">\n        <div class=\"absolute inset-0 leaf-pattern opacity-50\" data-kid=\"51\"></div>\n        <div class=\"max-w-4xl mx-auto text-center relative z-10\" data-kid=\"52\">\n            <div class=\"w-20 h-1 bg-[#C9963A]/20 mx-auto mb-12\" data-kid=\"53\"></div>\n            <svg class=\"w-12 h-12 text-[#C9963A]/30 mx-auto mb-8\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"54\"><path d=\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C14.9124 8 14.017 7.10457 14.017 6V3L14.017 3H21.017V21H14.017ZM3.017 21L3.017 18C3.017 16.8954 3.91243 16 5.017 16H8.017C8.56928 16 9.017 15.5523 9.017 15V9C9.017 8.44772 8.56928 8 8.017 8H5.017C3.91243 8 3.017 7.10457 3.017 6V3L3.017 3H10.017V21H3.017Z\" data-kid=\"55\"></path></svg>\n            <h3 class=\"font-serif text-3xl lg:text-5xl text-[#0D3D20] italic leading-[1.4] mb-10 px-4\" data-kid=\"56\">\n                \"Nomination is FREE. Always. This is our way of celebrating the green entrepreneur. This book is the permanent record of that celebration.\"\n            </h3>\n            <div class=\"flex flex-col items-center\" data-kid=\"57\">\n                <div class=\"w-16 h-16 rounded-full overflow-hidden mb-4 border-2 border-[#C9963A]\" data-kid=\"58\">\n                    <img src=\"https://i.pravatar.cc/150?u=pravin\" alt=\"Dr. Pravin Parmar\" class=\"w-full h-full object-cover\" data-kid=\"59\">\n                </div>\n                <p class=\"font-bold text-[#0D3D20]\" data-kid=\"60\">Dr. Pravin Parmar</p>\n                <p class=\"text-xs uppercase tracking-widest text-[#C9963A] font-bold\" data-kid=\"61\">Founder, 1MEIF</p>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"distribution\" class=\"py-24 px-6 lg:px-24 bg-white\" data-kid=\"62\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"63\">\n            <div class=\"grid lg:grid-cols-2 gap-20 items-center\" data-kid=\"64\">\n                <div class=\"order-2 lg:order-1\" data-kid=\"65\">\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch\" data-kid=\"66\">\n                        <div class=\"p-8 bg-[#F9F5EE] rounded-3xl border border-[#E5E7EB] hover:shadow-xl transition-shadow group flex flex-col h-full\" data-kid=\"67\">\n                            <div class=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm mb-6 group-hover:bg-[#C9963A] transition-colors shrink-0\" data-kid=\"68\">\n                                <svg class=\"w-8 h-8 text-[#1E6B3C] group-hover:text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"69\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\" data-kid=\"70\"></path></svg>\n                            </div>\n                            <h4 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"71\">Premium Print</h4>\n                            <p class=\"text-gray-600 leading-relaxed text-sm\" data-kid=\"72\">High-GSM archival quality paper with gold foil embossing and hardbound cover for a lasting legacy.</p>\n                        </div>\n                        <di