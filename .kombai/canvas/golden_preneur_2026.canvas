      "html": "\n\n<link href=\"https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css\" rel=\"stylesheet\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --primary-green: #1E6B3C;\n    --dark-green: #0D3D20;\n    --accent-gold: #C9963A;\n    --leaf-green: #4CAF50;\n    --cream-white: #F9F5EE;\n    --alert-red: #DC2626;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #1A1A1A;\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .font-serif {\n    font-family: 'Playfair Display', serif;\n  }\n\n  .leaf-pattern-bg {\n    background-image: linear-gradient(rgba(13, 61, 32, 0.85), rgba(13, 61, 32, 0.95)), \n                      url('https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?auto=format&w=1440&q=80&fit=crop');\n    background-size: cover;\n    background-position: center;\n  }\n\n  .gold-gradient {\n    background: linear-gradient(135deg, #C9963A 0%, #a87b2b 100%);\n  }\n\n  .nav-blur {\n    backdrop-filter: blur(12px);\n    background-color: rgba(255, 255, 255, 0.9);\n  }\n\n  .card-shadow {\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);\n  }\n\n  .sticky-bottom-cta {\n    position: absolute;\n    bottom: 24px;\n    right: 24px;\n    z-index: 50;\n  }\n</style>\n\n<div class=\"relative bg-white\" data-kid=\"2\">\n  \n  <nav class=\"nav-blur relative w-full z-[100] border-b border-gray-100 transition-all\" data-kid=\"3\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2\" data-kid=\"5\">\n        <div class=\"w-10 h-10 bg-[var(--primary-green)] rounded-lg flex items-center justify-center text-white\" data-kid=\"6\">\n          <i class=\"ri-leaf-fill text-2xl\" data-kid=\"7\"></i>\n        </div>\n        <span class=\"text-2xl font-serif font-bold tracking-tight text-[var(--dark-green)]\" data-kid=\"8\">GOLDEN PRENEUR <span class=\"text-[var(--accent-gold)]\" data-kid=\"9\">2026</span></span>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"10\">\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"11\">HOME</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"12\">ABOUT</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"13\">AWARDS</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"14\">SPEAKERS</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"15\">SPONSORS</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--primary-green)]\" data-kid=\"16\">WINNERS</a>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"17\">\n        <button class=\"hidden md:block bg-[var(--primary-green)] text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity\" data-kid=\"18\">\n          APPLY FOR AWARD\n        </button>\n        <button class=\"border-2 border-[var(--primary-green)] text-[var(--primary-green)] px-6 py-2 rounded-lg text-sm font-semibold hover:bg-[var(--primary-green)] hover:text-white transition-all\" data-kid=\"19\">\n          GET PASS\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"leaf-pattern-bg min-h-[780px] flex items-center relative overflow-hidden\" data-kid=\"20\">\n    <div class=\"max-w-7xl mx-auto px-6 w-full relative z-10 py-32\" data-kid=\"21\">\n      <div class=\"max-w-3xl\" data-kid=\"22\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-xs font-bold tracking-[0.2em] mb-8 uppercase\" data-kid=\"23\">\n          <span class=\"w-2 h-2 rounded-full bg-[var(--accent-gold)] animate-pulse\" data-kid=\"24\"></span>\n          5th Year Celebration\n        </div>\n        <h1 class=\"text-5xl lg:text-8xl font-serif text-white leading-[1.1] mb-8 drop-shadow-lg\" data-kid=\"25\">\n          India's Premier <span class=\"text-[var(--accent-gold)] italic\" data-kid=\"26\">Green</span> Entrepreneurship Awards\n        </h1>\n        <p class=\"text-xl lg:text-2xl text-white/90 leading-relaxed mb-12 max-w-2xl font-light\" data-kid=\"27\">\n          Celebrating 148+ Green Categories. Join 500+ leaders on 25th June 2026 at Renaissance by Marriott, Ahmedabad.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-5\" data-kid=\"28\">\n          <button class=\"bg-[var(--primary-green)] hover:bg-[#154d2b] text-white px-10 py-5 rounded-xl font-bold flex items-center justify-center gap-3 transition-all shadow-2xl text-lg group\" data-kid=\"29\">\n            <i class=\"ri-medal-fill text-[var(--accent-gold)]\" data-kid=\"30\"></i> Apply for Award — FREE\n          </button>\n          <button class=\"bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/30 text-white px-10 py-5 rounded-xl font-bold transition-all text-lg flex items-center justify-center gap-2\" data-kid=\"31\">\n            See 2025 Winners <i class=\"ri-arrow-right-up-line\" data-kid=\"32\"></i>\n          </button>\n        </div>\n        \n        <div class=\"mt-20 flex flex-wrap items-center gap-12 border-t border-white/10 pt-10\" data-kid=\"33\">\n          <div class=\"flex flex-col\" data-kid=\"34\">\n            <span class=\"text-4xl font-serif text-white font-bold\" data-kid=\"35\">4+</span>\n            <span class=\"text-white/50 text-xs uppercase tracking-widest mt-1\" data-kid=\"36\">Editions Delivered</span>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"37\">\n            <span class=\"text-4xl font-serif text-white font-bold\" data-kid=\"38\">10,000+</span>\n            <span class=\"text-white/50 text-xs uppercase tracking-widest mt-1\" data-kid=\"39\">Stories Published</span>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"40\">\n            <span class=\"text-4xl font-serif text-white font-bold\" data-kid=\"41\">35+</span>\n            <span class=\"text-white/50 text-xs uppercase tracking-widest mt-1\" data-kid=\"42\">Award Categories</span>\n          </div>\n        </div>\n      </div>\n    </div>\n    \n    \n    <div class=\"absolute right-0 bottom-0 top-0 w-1/3 hidden lg:flex items-center justify-center opacity-30 pointer-events-none\" data-kid=\"43\">\n        <div class=\"absolute inset-0 bg-gradient-to-l from-transparent via-[var(--dark-green)]/20 to-[var(--dark-green)] z-10\" data-kid=\"44\"></div>\n        <img src=\"https://images.unsplash.com/photo-1578269174936-2709b6aeb913?auto=format&w=800&q=80\" alt=\"Award Trophy\" class=\"h-4/5 object-contain mix-blend-screen filter brightness-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"45\">\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--cream-white)] py-20 border-b border-gray-100\" data-kid=\"46\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"47\">\n      <div class=\"flex flex-col lg:flex-row items-center justify-between gap-12 lg:items-center\" data-kid=\"48\">\n        <div class=\"text-center lg:text-left\" data-kid=\"49\">\n          <h2 class=\"text-3xl font-serif text-[var(--dark-green)] mb-2\" data-kid=\"50\">Countdown to the Gala</h2>\n          <p class=\"text-gray-500 font-medium\" data-kid=\"51\">Ahmedabad is calling. Are you ready?</p>\n          <div class=\"mt-4 flex items-center justify-center lg:justify-start gap-4 text-sm text-[var(--primary-green)] font-semibold\" data-kid=\"52\">\n            <span class=\"flex items-center gap-1\" data-kid=\"53\"><i class=\"ri-calendar-event-line\" data-kid=\"54\"></i> 25 June 2026</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"55\"><i class=\"ri-time-line\" data-kid=\"56\"></i> 2:00 PM onwards</span>\n          </div>\n        </div>\n        \n        <div class=\"flex gap-4 md:gap-8 self-center\" data-kid=\"57\">\n          <div class=\"flex flex-col items-center\" data-kid=\"58\">\n            <div class=\"w-20 h-24 md:w-32 md:h-36 bg-white rounded-2xl flex items-center justify-center text-4xl md:text-6xl font-serif text-[var(--primary-green)] card-shadow border border-gray-100\" data-kid=\"59\">124</div>\n            <span class=\"text-[10px] md:text-xs font-bold text-gray-400 mt-3 tracking-widest uppercase\" data-kid=\"60\">Days</span>\n          </div>\n          <div class=\"flex flex-col items-center\" data-kid=\"61\">\n            <div class=\"w-20 h-24 md:w-32 md:h-36 bg-white rounded-2xl flex items-center justify-center text-4xl md:text-6xl font-serif text-[var(--primary-green)] card-shadow border border-gray-100\" data-kid=\"62\">14</div>\n            <span class=\"text-[10px] md:text-xs font-bold text-gray-400 mt-3 tracking-widest uppercase\" data-kid=\"63\">Hours</span>\n          </div>\n          <div class=\"flex flex-col items-center\" data-kid=\"64\">\n            <div class=\"w-20 h-24 md:w-32 md:h-36 bg-white rounded-2xl flex items-center justify-center text-4xl md:text-6xl font-serif text-[var(--primary-green)] card-shadow border border-gray-100\" data-kid=\"65\">35</div>\n            <span class=\"text-[10px] md:text-xs font-bold text-gray-400 mt-3 tracking-widest uppercase\" data-kid=\"66\">Mins</span>\n          </div>\n          <div class=\"flex flex-col items-center\" data-kid=\"67\">\n            <div class=\"w-20 h-24 md:w-32 md:h-36 bg-white rounded-2xl flex items-center justify-center text-4xl md:text-6xl font-serif text-[var(--primary-green)] card-shadow border border-gray-100\" data-kid=\"68\">42</div>\n            <span class=\"text-[10px] md:text-xs font-bold text-gray-400 mt-3 tracking-widest uppercase\" data-kid=\"69\">Secs</span>\n          </div>\n        </div>\n        \n        <div class=\"shrink-0\" data-kid=\"70\">\n          <button class=\"bg-[var(--accent-gold)] hover:bg-[#ae8231] text-white px-8 py-4 rounded-xl font-bold shadow-xl transition-all flex items-center gap-2\" data-kid=\"71\">\n            SECURE YOUR PASS <i class=\"ri-arrow-right-line\" data-kid=\"72\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-white relative\" data-kid=\"73\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"74\">\n      <div class=\"text-center mb-20\" data-kid=\"75\">\n        <h2 class=\"text-4xl lg:text-5xl font-serif text-[var(--dark-green)] mb-6\" data-kid=\"76\">Built on Three Core Pillars</h2>\n        <div class=\"w-24 h-1 bg-[var(--accent-gold)] mx-auto mb-6\" data-kid=\"77\"></div>\n        <p class=\"text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed\" data-kid=\"78\">\n          Golden preneur isn't just an award; it's an ecosystem designed to identify, connect, and amplify the voices of a sustainable Bharat.\n        </p>\n      </div>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10\" data-kid=\"79\">\n        \n        <div class=\"group p-10 rounded-3xl bg-[var(--cream-white)] border border-gray-100 transition-all hover:-translate-y-2 hover:shadow-2xl hover:bg-white\" data-kid=\"80\">\n          <div class=\"w-20 h-20 bg-[var(--primary-green)] rounded-2xl flex items-center justify-center text-white mb-8 group-hover:rotate-6 transition-transform\" data-kid=\"81\">\n            <i class=\"ri-medal-line text-4xl\" data-kid=\"82\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif text-[var(--dark-green)] mb-4\" data-kid=\"83\">AWARD</h3>\n          <p class=\"text-gray-600 mb-8 leading-relaxed\" data-kid=\"84\">Recognising green entrepreneurs across 35+ categories through a structured 75% jury and 25% public voting process.</p>\n          <a href=\"#\" class=\"inline-flex items-center text-[var(--primary-green)] font-bold group-hover:gap-3 transition-all\" data-kid=\"85\">\n            Apply Now <i class=\"ri-arrow-right-line ml-2\" data-kid=\"86\"></i>\n          </a>\n        </div>\n        \n        \n        <div class=\"group p-10 rounded-3xl bg-[var(--cream-white)] border border-gray-100 transition-all hover:-translate-y-2 hover:shadow-2xl hover:bg-white\" data-kid=\"87\">\n          <div class=\"w-20 h-20 bg-[var(--accent-gold)] rounded-2xl flex items-center justify-center text-white mb-8 group-hover:rotate-6 transition-transform\" data-kid=\"88\">\n            <i class=\"ri-group-line text-4xl\" data-kid=\"89\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif text-[var(--dark-green)] mb-4\" data-kid=\"90\">CONNECT</h3>\n          <p class=\"text-gray-600 mb-8 leading-relaxed\" data-kid=\"91\">Building a permanent business community across 150+ green economy sectors for collaboration and growth.</p>\n          <a href=\"#\" class=\"inline-flex items-center text-[var(--primary-green)] font-bold group-hover:gap-3 transition-all\" data-kid=\"92\">\n            Join Community <i class=\"ri-arrow-right-line ml-2\" data-kid=\"93\"></i>\n          </a>\n        </div>\n\n        \n        <div class=\"group p-10 rounded-3xl bg-[var(--cream-white)] border border-gray-100 transition-all hover:-translate-y-2 hover:shadow-2xl hover:bg-white\" data-kid=\"94\">\n          <div class=\"w-20 h-20 bg-[var(--leaf-green)] rounded-2xl flex items-center justify-center text-white mb-8 group-hover:rotate-6 transition-transform\" data-kid=\"95\">\n            <i class=\"ri-broadcast-line text-4xl\" data-kid=\"96\"></i>\n          </div>\n          <h3 class=\"text-2xl font-serif text-[var(--dark-green)] mb-4\" data-kid=\"97\">AMPLIFY</h3>\n          <p class=\"text-gray-600 mb-8 leading-relaxed\" data-kid=\"98\">Publishing 1,000+ green stories on VyapaarJagat.com and featuring top 50 leaders in our premium Coffee Table Book.</p>\n          <a href=\"#\" class=\"inline-flex items-center text-[var(--primary-green)] font-bold group-hover:gap-3 transition-all\" data-kid=\"99\">\n            Publish Story <i class=\"ri-arrow-right-line ml-2\" data-kid=\"100\"></i>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-[var(--cream-white)]\" data-kid=\"101\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"102\">\n      <div class=\"flex flex-col md:flex-row items-end justify-between mb-16 gap-8\" data-kid=\"103\">\n        <div class=\"max-w-xl\" data-kid=\"104\">\n          <h2 class=\"text-4xl font-serif text-[var(--dark-green)] mb-6\" data-kid=\"105\">35+ Award Categories — Find Yours</h2>\n          <p class=\"text-gray-600 text-lg\" data-kid=\"106\">Every green business belongs here. We've structured categories to cover the entire spectrum of sustainability.</p>\n        </div>\n        <button class=\"bg-[var(--primary-green)] text-white px-10 py-4 rounded-xl font-bold shadow-lg hover:opacity-90 transition-all\" data-kid=\"107\">\n          SEE ALL 35+ CATEGORIES\n        </button>\n      </div>\n      \n      <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"108\">\n        \n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"109\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"110\">\n            <i class=\"ri-sun-line text-3xl\" data-kid=\"111\"></i>\n          </div>\n          <div data-kid=\"112\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"113\">Renewable Energy</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"114\">Solar, wind, biogas, and alternative energy pioneers.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"115\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"116\"></i></a>\n          </div>\n        </div>\n        \n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"117\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"118\">\n            <i class=\"ri-recycle-line text-3xl\" data-kid=\"119\"></i>\n          </div>\n          <div data-kid=\"120\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"121\">Waste Management</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"122\">Innovative waste processing and circular solutions.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"123\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"124\"></i></a>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"125\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"126\">\n            <i class=\"ri-leaf-line text-3xl\" data-kid=\"127\"></i>\n          </div>\n          <div data-kid=\"128\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"129\">Sustainable Agriculture</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"130\">Organic farming and eco-friendly agri-tech products.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"131\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"132\"></i></a>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"133\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"134\">\n            <i class=\"ri-building-line text-3xl\" data-kid=\"135\"></i>\n          </div>\n          <div data-kid=\"136\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"137\">Green Construction</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"138\">Eco-friendly materials, architecture and interior design.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"139\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"140\"></i></a>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"141\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"142\">\n            <i class=\"ri-car-line text-3xl\" data-kid=\"143\"></i>\n          </div>\n          <div data-kid=\"144\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"145\">E-Vehicle Business</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"146\">Mobility solutions, charging networks, and EVs.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"147\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"148\"></i></a>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-8 rounded-2xl card-shadow border border-gray-100 flex items-start gap-6 hover:border-[var(--primary-green)] transition-colors\" data-kid=\"149\">\n          <div class=\"w-14 h-14 shrink-0 rounded-xl bg-green-50 flex items-center justify-center text-[var(--primary-green)]\" data-kid=\"150\">\n            <i class=\"ri-heart-pulse-line text-3xl\" data-kid=\"151\"></i>\n          </div>\n          <div data-kid=\"152\">\n            <h4 class=\"text-lg font-bold text-gray-900 mb-2\" data-kid=\"153\">Healthcare & Wellness</h4>\n            <p class=\"text-sm text-gray-500 mb-4 leading-relaxed\" data-kid=\"154\">Eco-conscious wellness and sustainable medical tech.</p>\n            <a href=\"#\" class=\"text-sm font-bold text-[var(--primary-green)] flex items-center gap-1 hover:underline\" data-kid=\"155\">Apply <i class=\"ri-arrow-right-s-line\" data-kid=\"156\"></i></a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-white overflow-hidden relative\" data-kid=\"157\">\n    <div class=\"absolute top-0 right-0 -z-10 w-64 h-64 bg-[var(--cream-white)] rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl opacity-50\" data-kid=\"158\"></div>\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"159\">\n      <div class=\"text-center mb-16\" data-kid=\"160\">\n        <h2 class=\"text-4xl lg:text-5xl font-serif text-[var(--dark-green)] mb-6\" data-kid=\"161\">Choose Your Award Track</h2>\n        <p class=\"text-gray-600 max-w-xl mx-auto text-lg leading-relaxed\" data-kid=\"162\">Nomination is always <span class=\"text-[var(--primary-green)] font-bold underline decoration-[var(--accent-gold)] underline-offset-4\" data-kid=\"163\">FREE</span> for the Honorary track. Choose the path that fits your journey.</p>\n      </div>\n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch\" data-kid=\"164\">\n        \n        <div class=\"relative p-10 lg:p-14 rounded-[40px] bg-[var(--cream-white)] border border-gray-100 flex flex-col group hover:shadow-xl transition-all\" data-kid=\"165\">\n          <div class=\"flex items-center justify-between mb-10\" data-kid=\"166\">\n            <div class=\"w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-[var(--primary-green)] shadow-sm\" data-kid=\"167\">\n              <i class=\"ri-award-line text-3xl\" data-kid=\"168\"></i>\n            </div>\n            <span class=\"bg-[var(--leaf-green)]/10 text-[var(--leaf-green)] text-xs font-black px-5 py-2 rounded-full uppercase tracking-widest border border-[var(--leaf-green)]/20\" data-kid=\"169\">Free to Nominate</span>\n          </div>\n          <h3 class=\"text-4xl font-serif text-[var(--dark-green)] mb-6\" data-kid=\"170\">Honorary Awards</h3>\n          <p class=\"text-gray-600 mb-10 text-lg leading-relaxed\" data-kid=\"171\">For exceptional lifetime contributions or sector leadership. Candidates are selected based on 100% jury evaluation.</p>\n          <ul class=\"space-y-5 mb-12 flex-grow\" data-kid=\"172\">\n            <li class=\"flex items-center gap-4 text-gray-700 font-medium\" data-kid=\"173\">\n              <div class=\"w-6 h-6 rounded-full bg-[var(--primary-green)] flex items-center justify-center shrink-0\" data-kid=\"174\">\n                <i class=\"ri-check-line text-white text-sm\" data-kid=\"175\"></i>\n              </div>\n              <span data-kid=\"176\">No nomination fee ever</span>\n            </li>\n            <li class=\"flex items-center gap-4 text-gray-700 font-medium\" data-kid=\"177\">\n              <div class=\"w-6 h-6 rounded-full bg-[var(--primary-green)] flex items-center justify-center shrink-0\" data-kid=\"178\">\n                <i class=\"ri-check-line text-white text-sm\" data-kid=\"179\"></i>\n              </div>\n              <span data-kid=\"180\">Invitation-based or Self-nomination</span>\n            </li>\n            <li class=\"flex items-center gap-4 text-gray-700 font-medium\" data-kid=\"181\">\n              <div class=\"w-6 h-6 rounded-full bg-[var(--p