      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #F9F5EE;\n    color: #0D3D20;\n    margin: 0;\n  }\n\n  .font-playfair { font-family: 'Playfair Display', serif; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n\n  .gold-border { border: 1px solid rgba(201, 150, 58, 0.3); }\n  .gold-border-accent { border-left: 4px solid #C9963A; }\n  \n  .prestigious-shadow {\n    box-shadow: 0 30px 60px -15px rgba(13, 61, 32, 0.12);\n  }\n\n  .heritage-ornament {\n    background-image: radial-gradient(circle at 1px 1px, #C9963A 1px, transparent 0);\n    background-size: 24px 24px;\n    opacity: 0.05;\n  }\n\n  .gold-gradient-text {\n    background: linear-gradient(to bottom, #C9963A, #B0822F);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n</style>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"1\"></script>\n\n<main class=\"relative min-h-screen\" data-kid=\"2\">\n\n<nav class=\"relative z-50 bg-[#F9F5EE]/98 backdrop-blur-xl border-b border-[#C9963A]/20\" data-kid=\"3\">\n  <div class=\"max-w-7xl mx-auto px-6 h-24 flex items-center justify-between\" data-kid=\"4\">\n    <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"5\">\n      <div class=\"w-12 h-12 bg-[#1E6B3C] rounded-sm flex items-center justify-center text-white shadow-lg group-hover:bg-[#0D3D20] transition-colors\" data-kid=\"6\">\n        <i data-lucide=\"leaf\" class=\"w-7 h-7\" data-kid=\"7\"></i>\n      </div>\n      <div class=\"flex flex-col\" data-kid=\"8\">\n        <span class=\"font-playfair text-2xl font-bold leading-none tracking-tight\" data-kid=\"9\">GOLDEN PRENEUR</span>\n        <span class=\"text-[9px] uppercase tracking-[0.3em] text-[#C9963A] font-bold mt-1\" data-kid=\"10\">A Peers Global Initiative</span>\n      </div>\n    </div>\n\n    <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"11\">\n      <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.25em] font-bold hover:text-[#C9963A] transition-colors\" data-kid=\"12\">The Legacy</a>\n      <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.25em] font-bold hover:text-[#C9963A] transition-colors\" data-kid=\"13\">Nominate</a>\n      <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.25em] font-bold hover:text-[#C9963A] transition-colors\" data-kid=\"14\">Winners</a>\n      <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.25em] font-bold hover:text-[#C9963A] transition-colors\" data-kid=\"15\">The Book</a>\n      <a href=\"#\" class=\"text-[10px] uppercase tracking-[0.25em] font-bold hover:text-[#C9963A] transition-colors\" data-kid=\"16\">Partners</a>\n    </div>\n\n    <div class=\"flex items-center gap-6\" data-kid=\"17\">\n      <button class=\"px-8 py-3.5 text-[10px] uppercase tracking-[0.2em] font-bold border border-[#1E6B3C] text-[#1E6B3C] hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"18\">Get Pass</button>\n      <button class=\"px-8 py-3.5 text-[10px] uppercase tracking-[0.2em] font-bold bg-[#C9963A] text-white hover:bg-[#B0822F] shadow-xl transition-all\" data-kid=\"19\">Nominate</button>\n    </div>\n  </div>\n</nav>\n\n\n<section class=\"relative h-[880px] flex items-center overflow-hidden bg-[#0D3D20]\" data-kid=\"20\">\n  <div class=\"absolute inset-0\" data-kid=\"21\">\n    <img src=\"https://images.unsplash.com/photo-1618898613684-2cf0ae9a7c19?auto=format&w=1920&q=80&fit=crop\" alt=\"Prestigious Green Landscape\" class=\"w-full h-full object-cover opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n    <div class=\"absolute inset-0 bg-gradient-to-r from-[#0D3D20] via-[#0D3D20]/70 to-transparent\" data-kid=\"23\"></div>\n    <div class=\"absolute inset-0 heritage-ornament opacity-10\" data-kid=\"24\"></div>\n  </div>\n  \n  <div class=\"relative z-10 max-w-7xl mx-auto px-6\" data-kid=\"25\">\n    <div class=\"max-w-4xl\" data-kid=\"26\">\n      <div class=\"inline-flex items-center gap-4 mb-10 px-5 py-2.5 bg-[#C9963A]/15 border border-[#C9963A]/40 backdrop-blur-md\" data-kid=\"27\">\n        <div class=\"w-2 h-2 bg-[#C9963A] animate-pulse\" data-kid=\"28\"></div>\n        <span class=\"text-[#C9963A] text-[10px] font-bold uppercase tracking-[0.4em]\" data-kid=\"29\">5th Year Anniversary Celebration</span>\n      </div>\n      \n      <h1 class=\"font-playfair text-7xl md:text-[100px] text-white mb-10 leading-[0.95] tracking-tight\" data-kid=\"30\">\n        Honouring the <br data-kid=\"31\">\n        <span class=\"italic text-[#C9963A]\" data-kid=\"32\">Architects of a</span> <br data-kid=\"33\">\n        Sustainable India\n      </h1>\n      \n      <p class=\"text-xl md:text-2xl text-white/80 mb-14 font-light leading-relaxed max-w-2xl\" data-kid=\"34\">\n        The ultimate recognition for visionaries redefining India's environmental legacy. A prestigious summit of leadership and innovation.\n      </p>\n      \n      <div class=\"flex flex-wrap items-center gap-10\" data-kid=\"35\">\n        <a href=\"#\" class=\"px-12 py-6 bg-[#C9963A] text-white font-bold text-xs uppercase tracking-[0.2em] flex items-center gap-4 shadow-[0_20px_40px_rgba(201,150,58,0.3)] hover:bg-[#B0822F] hover:-translate-y-1 transition-all group\" data-kid=\"36\">\n          Apply for Recognition\n          <i data-lucide=\"award\" class=\"w-5 h-5 group-hover:rotate-12 transition-transform\" data-kid=\"37\"></i>\n        </a>\n        <div class=\"flex items-center gap-6 group cursor-default\" data-kid=\"38\">\n          <div class=\"w-16 h-px bg-white/30 group-hover:w-24 transition-all duration-500\" data-kid=\"39\"></div>\n          <div class=\"flex flex-col\" data-kid=\"40\">\n            <span class=\"text-[#C9963A] text-[10px] uppercase tracking-widest font-bold mb-1\" data-kid=\"41\">Ahmedabad Celebration</span>\n            <span class=\"text-white font-medium text-lg\" data-kid=\"42\">25th June 2026</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"mt-28 grid grid-cols-3 gap-16 border-t border-white/10 pt-16 max-w-3xl\" data-kid=\"43\">\n        <div class=\"group\" data-kid=\"44\">\n          <span class=\"block text-4xl font-playfair text-[#C9963A] mb-2 group-hover:scale-110 transition-transform origin-left\" data-kid=\"45\">04+</span>\n          <span class=\"text-white/40 text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"46\">Years of Legacy</span>\n        </div>\n        <div class=\"group\" data-kid=\"47\">\n          <span class=\"block text-4xl font-playfair text-[#C9963A] mb-2 group-hover:scale-110 transition-transform origin-left\" data-kid=\"48\">500+</span>\n          <span class=\"text-white/40 text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"49\">Elite Delegates</span>\n        </div>\n        <div class=\"group\" data-kid=\"50\">\n          <span class=\"block text-4xl font-playfair text-[#C9963A] mb-2 group-hover:scale-110 transition-transform origin-left\" data-kid=\"51\">148+</span>\n          <span class=\"text-white/40 text-[10px] uppercase tracking-[0.2em] font-bold\" data-kid=\"52\">Sectors covered</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 bg-white relative overflow-hidden\" data-kid=\"53\">\n  <div class=\"absolute inset-0 heritage-ornament opacity-5\" data-kid=\"54\"></div>\n  <div class=\"max-w-7xl mx-auto px-6 relative z-10\" data-kid=\"55\">\n    <div class=\"flex flex-col lg:flex-row items-center justify-between gap-24\" data-kid=\"56\">\n      <div class=\"lg:w-1/2\" data-kid=\"57\">\n        <span class=\"text-[#C9963A] font-bold uppercase tracking-[0.4em] text-[10px] mb-6 block\" data-kid=\"58\">National Commitment</span>\n        <h2 class=\"font-playfair text-5xl md:text-6xl text-[#0D3D20] mb-10 leading-tight\" data-kid=\"59\">\n          A National Vision for <br data-kid=\"60\"><span class=\"italic text-[#1E6B3C]\" data-kid=\"61\">Global Impact</span>\n        </h2>\n        <p class=\"text-xl text-gray-600 mb-12 leading-relaxed font-light\" data-kid=\"62\">\n          Golden preneur 2026 is strictly aligned with the national goal of <strong data-kid=\"63\">Viksit Bharat @2047</strong> and the United Nations Sustainable Development Goals. We believe the future of India is green, inclusive, and self-reliant.\n        </p>\n        \n        <div class=\"flex flex-wrap items-center gap-16\" data-kid=\"64\">\n          <div class=\"flex flex-col items-center gap-4 group\" data-kid=\"65\">\n            <div class=\"w-36 h-36 rounded-full border border-[#C9963A]/30 bg-[#F9F5EE] flex flex-col items-center justify-center p-6 text-center prestigious-shadow group-hover:border-[#C9963A] transition-all relative\" data-kid=\"66\">\n              <div class=\"absolute inset-2 border border-dashed border-[#C9963A]/20 rounded-full\" data-kid=\"67\"></div>\n              <span class=\"text-[9px] font-bold text-gray-400 uppercase leading-none mb-1\" data-kid=\"68\">Building</span>\n              <span class=\"text-lg font-playfair font-black text-[#0D3D20] leading-tight\" data-kid=\"69\">VIKSIT BHARAT</span>\n              <span class=\"text-xs font-bold text-[#C9963A] mt-1 tracking-widest\" data-kid=\"70\">@2047</span>\n            </div>\n            <span class=\"text-[9px] font-bold text-[#0D3D20] uppercase tracking-[0.2em]\" data-kid=\"71\">National Mission</span>\n          </div>\n          \n          <div class=\"h-24 w-px bg-gray-200 hidden md:block\" data-kid=\"72\"></div>\n          \n          <div class=\"flex flex-col gap-6\" data-kid=\"73\">\n            <div class=\"flex items-center gap-3\" data-kid=\"74\">\n              <div class=\"grid grid-cols-4 gap-2\" data-kid=\"75\">\n                <div class=\"w-10 h-10 bg-[#E5243B] shadow-sm hover:scale-110 transition-transform\" title=\"No Poverty\" data-kid=\"76\"></div>\n                <div class=\"w-10 h-10 bg-[#DDA63A] shadow-sm hover:scale-110 transition-transform\" title=\"Zero Hunger\" data-kid=\"77\"></div>\n                <div class=\"w-10 h-10 bg-[#4C9F38] shadow-sm hover:scale-110 transition-transform\" title=\"Good Health\" data-kid=\"78\"></div>\n                <div class=\"w-10 h-10 bg-[#C5192D] shadow-sm hover:scale-110 transition-transform\" title=\"Quality Education\" data-kid=\"79\"></div>\n                <div class=\"w-10 h-10 bg-[#FF3A21] shadow-sm hover:scale-110 transition-transform\" title=\"Gender Equality\" data-kid=\"80\"></div>\n                <div class=\"w-10 h-10 bg-[#26BDE2] shadow-sm hover:scale-110 transition-transform\" title=\"Clean Water\" data-kid=\"81\"></div>\n                <div class=\"w-10 h-10 bg-[#FCC30B] shadow-sm hover:scale-110 transition-transform\" title=\"Affordable Energy\" data-kid=\"82\"></div>\n                <div class=\"w-10 h-10 bg-[#A21942] shadow-sm hover:scale-110 transition-transform\" title=\"Decent Work\" data-kid=\"83\"></div>\n              </div>\n              <div class=\"flex flex-col ml-6 border-l border-[#C9963A]/20 pl-6\" data-kid=\"84\">\n                <span class=\"font-playfair text-3xl font-bold text-[#0D3D20] leading-none mb-1\" data-kid=\"85\">UN SDGs</span>\n                <span class=\"text-[9px] text-[#C9963A] uppercase tracking-[0.3em] font-black\" data-kid=\"86\">Global Alignment</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"lg:w-1/2 grid grid-cols-2 gap-8\" data-kid=\"87\">\n        <div class=\"bg-[#F9F5EE] p-10 border border-[#C9963A]/20 prestigious-shadow group hover:bg-[#0D3D20] transition-all duration-500\" data-kid=\"88\">\n          <i data-lucide=\"shield-check\" class=\"w-10 h-10 text-[#C9963A] mb-6 group-hover:text-white transition-colors\" data-kid=\"89\"></i>\n          <h4 class=\"font-playfair text-2xl mb-4 group-hover:text-white transition-colors\" data-kid=\"90\">NGO Certified</h4>\n          <p class=\"text-sm text-gray-500 group-hover:text-white/60 transition-colors leading-relaxed\" data-kid=\"91\">1MEIF is a Section 8 Company with full 80G & 12A heritage of service.</p>\n        </div>\n        <div class=\"bg-[#F9F5EE] p-10 border border-[#C9963A]/20 prestigious-shadow group hover:bg-[#0D3D20] transition-all duration-500\" data-kid=\"92\">\n          <i data-lucide=\"globe\" class=\"w-10 h-10 text-[#C9963A] mb-6 group-hover:text-white transition-colors\" data-kid=\"93\"></i>\n          <h4 class=\"font-playfair text-2xl mb-4 group-hover:text-white transition-colors\" data-kid=\"94\">Global Network</h4>\n          <p class=\"text-sm text-gray-500 group-hover:text-white/60 transition-colors leading-relaxed\" data-kid=\"95\">Connecting green visionaries across 150+ international economy sectors.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 bg-[#F9F5EE]\" data-kid=\"96\">\n  <div class=\"max-w-7xl mx-auto px-6 text-center mb-24\" data-kid=\"97\">\n    <span class=\"text-[#C9963A] font-bold uppercase tracking-[0.5em] text-[10px] mb-6 block\" data-kid=\"98\">The Core Framework</span>\n    <h2 class=\"font-playfair text-6xl text-[#0D3D20]\" data-kid=\"99\">The Pillars of Excellence</h2>\n  </div>\n  \n  <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12\" data-kid=\"100\">\n    \n    <div class=\"bg-white p-14 text-center prestigious-shadow border border-[#C9963A]/20 group hover:border-[#C9963A] transition-all duration-700 relative\" data-kid=\"101\">\n      <div class=\"absolute top-6 left-6 w-10 h-10 border-t border-l border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"102\"></div>\n      <div class=\"absolute bottom-6 right-6 w-10 h-10 border-b border-r border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"103\"></div>\n      \n      <div class=\"w-24 h-24 bg-[#C9963A]/10 flex items-center justify-center mx-auto mb-12 text-[#C9963A] group-hover:bg-[#C9963A] group-hover:text-white transition-all duration-700 shadow-xl rounded-sm\" data-kid=\"104\">\n        <i data-lucide=\"award\" class=\"w-12 h-12\" data-kid=\"105\"></i>\n      </div>\n      <h3 class=\"font-playfair text-3xl mb-6 text-[#0D3D20] tracking-tight\" data-kid=\"106\">RECOGNISE</h3>\n      <p class=\"text-gray-500 mb-12 leading-relaxed font-light\" data-kid=\"107\">\n        Identifying and honouring green brilliance across 35+ prestigious categories through an elite jury process.\n      </p>\n      <a href=\"#\" class=\"inline-block px-10 py-4 bg-[#0D3D20] text-white text-[10px] uppercase tracking-[0.25em] font-bold hover:bg-[#1E6B3C] transition-all shadow-lg\" data-kid=\"108\">Nominate Now</a>\n    </div>\n\n    \n    <div class=\"bg-white p-14 text-center prestigious-shadow border border-[#C9963A]/20 group hover:border-[#C9963A] transition-all duration-700 relative\" data-kid=\"109\">\n      <div class=\"absolute top-6 left-6 w-10 h-10 border-t border-l border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"110\"></div>\n      <div class=\"absolute bottom-6 right-6 w-10 h-10 border-b border-r border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"111\"></div>\n      \n      <div class=\"w-24 h-24 bg-[#1E6B3C]/10 flex items-center justify-center mx-auto mb-12 text-[#1E6B3C] group-hover:bg-[#1E6B3C] group-hover:text-white transition-all duration-700 shadow-xl rounded-sm\" data-kid=\"112\">\n        <i data-lucide=\"users\" class=\"w-12 h-12\" data-kid=\"113\"></i>\n      </div>\n      <h3 class=\"font-playfair text-3xl mb-6 text-[#0D3D20] tracking-tight\" data-kid=\"114\">NETWORK</h3>\n      <p class=\"text-gray-500 mb-12 leading-relaxed font-light\" data-kid=\"115\">\n        Building a high-impact ecosystem of 500+ green entrepreneurs for national scaling and collaboration.\n      </p>\n      <a href=\"#\" class=\"inline-block px-10 py-4 bg-[#0D3D20] text-white text-[10px] uppercase tracking-[0.25em] font-bold hover:bg-[#1E6B3C] transition-all shadow-lg\" data-kid=\"116\">Join Conclave</a>\n    </div>\n\n    \n    <div class=\"bg-white p-14 text-center prestigious-shadow border border-[#C9963A]/20 group hover:border-[#C9963A] transition-all duration-700 relative\" data-kid=\"117\">\n      <div class=\"absolute top-6 left-6 w-10 h-10 border-t border-l border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"118\"></div>\n      <div class=\"absolute bottom-6 right-6 w-10 h-10 border-b border-r border-[#C9963A]/40 group-hover:w-14 group-hover:h-14 transition-all\" data-kid=\"119\"></div>\n      \n      <div class=\"w-24 h-24 bg-[#C9963A]/10 flex items-center justify-center mx-auto mb-12 text-[#C9963A] group-hover:bg-[#C9963A] group-hover:text-white transition-all duration-700 shadow-xl rounded-sm\" data-kid=\"120\">\n        <i data-lucide=\"megaphone\" class=\"w-12 h-12\" data-kid=\"121\"></i>\n      </div>\n      <h3 class=\"font-playfair text-3xl mb-6 text-[#0D3D20] tracking-tight\" data-kid=\"122\">AMPLIFY</h3>\n      <p class=\"text-gray-500 mb-12 leading-relaxed font-light\" data-kid=\"123\">\n        Projecting your vision to 1M+ eco-conscious readers globally through our multi-channel media platforms.\n      </p>\n      <a href=\"#\" class=\"inline-block px-10 py-4 bg-[#0D3D20] text-white text-[10px] uppercase tracking-[0.25em] font-bold hover:bg-[#1E6B3C] transition-all shadow-lg\" data-kid=\"124\">Submit Story</a>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 bg-white relative\" data-kid=\"125\">\n  <div class=\"max-w-7xl mx-auto px-6 relative z-10\" data-kid=\"126\">\n    <div class=\"text-center mb-24\" data-kid=\"127\">\n      <span class=\"text-[#C9963A] font-bold uppercase tracking-[0.5em] text-[10px] mb-6 block\" data-kid=\"128\">Selection Pathways</span>\n      <h2 class=\"font-playfair text-6xl text-[#0D3D20]\" data-kid=\"129\">Two Tracks of Excellence</h2>\n    </div>\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20\" data-kid=\"130\">\n      <div class=\"relative group\" data-kid=\"131\">\n        <div class=\"absolute -inset-4 bg-[#C9963A]/5 border border-[#C9963A]/10 -z-10 transition-transform group-hover:scale-105\" data-kid=\"132\"></div>\n        <div class=\"bg-[#F9F5EE] p-16 prestigious-shadow border-t-8 border-[#C9963A] h-full relative overflow-hidden\" data-kid=\"133\">\n          <div class=\"absolute top-0 right-0 w-32 h-32 heritage-ornament opacity-20 translate-x-10 -translate-y-10\" data-kid=\"134\"></div>\n          <span class=\"text-xs font-bold text-[#C9963A] tracking-[0.3em] uppercase mb-8 block\" data-kid=\"135\">Track One</span>\n          <h3 class=\"font-playfair text-4xl text-[#0D3D20] mb-8\" data-kid=\"136\">Honorary Recognition</h3>\n          <p class=\"text-gray-600 mb-12 text-lg font-light leading-relaxed\" data-kid=\"137\">Dedicated to lifetime achievers and extraordinary green innovators. 100% Jury Selection, based purely on impact and merit.</p>\n          <ul class=\"space-y-6 mb-16\" data-kid=\"138\">\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"139\">\n              <i data-lucide=\"award\" class=\"w-6 h-6 text-[#C9963A] group-hover/item:scale-125 transition-transform\" data-kid=\"140\"></i>\n              <span class=\"font-medium\" data-kid=\"141\">Nomination is completely FREE</span>\n            </li>\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"142\">\n              <i data-lucide=\"users\" class=\"w-6 h-6 text-[#C9963A] group-hover/item:scale-125 transition-transform\" data-kid=\"143\"></i>\n              <span class=\"font-medium\" data-kid=\"144\">100% Jury Evaluation</span>\n            </li>\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"145\">\n              <i data-lucide=\"star\" class=\"w-6 h-6 text-[#C9963A] group-hover/item:scale-125 transition-transform\" data-kid=\"146\"></i>\n              <span class=\"font-medium\" data-kid=\"147\">Invitation or Merit Based</span>\n            </li>\n          </ul>\n          <button class=\"w-full py-6 bg-[#C9963A] text-white font-bold uppercase tracking-[0.3em] text-[10px] hover:bg-[#B0822F] transition-all shadow-xl\" data-kid=\"148\">Apply for Honorary Award</button>\n        </div>\n      </div>\n\n      <div class=\"relative group\" data-kid=\"149\">\n        <div class=\"absolute -inset-4 bg-[#1E6B3C]/5 border border-[#1E6B3C]/10 -z-10 transition-transform group-hover:scale-105\" data-kid=\"150\"></div>\n        <div class=\"bg-white p-16 prestigious-shadow border-t-8 border-[#1E6B3C] h-full relative overflow-hidden border border-gray-100\" data-kid=\"151\">\n           <div class=\"absolute top-0 right-0 w-32 h-32 heritage-ornament opacity-20 translate-x-10 -translate-y-10\" data-kid=\"152\"></div>\n          <span class=\"text-xs font-bold text-[#1E6B3C] tracking-[0.3em] uppercase mb-8 block\" data-kid=\"153\">Track Two</span>\n          <h3 class=\"font-playfair text-4xl text-[#0D3D20] mb-8\" data-kid=\"154\">The Rated Challenge</h3>\n          <p class=\"text-gray-600 mb-12 text-lg font-light leading-relaxed\" data-kid=\"155\">A competitive framework for MSMEs and Startups. Combines 75% expert jury weightage with 25% public validation.</p>\n          <ul class=\"space-y-6 mb-16\" data-kid=\"156\">\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"157\">\n              <i data-lucide=\"zap\" class=\"w-6 h-6 text-[#1E6B3C] group-hover/item:scale-125 transition-transform\" data-kid=\"158\"></i>\n              <span class=\"font-medium\" data-kid=\"159\">Starting from Rs. 2,000</span>\n            </li>\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"160\">\n              <i data-lucide=\"megaphone\" class=\"w-6 h-6 text-[#1E6B3C] group-hover/item:scale-125 transition-transform\" data-kid=\"161\"></i>\n              <span class=\"font-medium\" data-kid=\"162\">Public Voting Campaign</span>\n            </li>\n            <li class=\"flex items-center gap-5 text-gray-700 group/item\" data-kid=\"163\">\n              <i data-lucide=\"check-circle\" class=\"w-6 h-6 text-[#1E6B3C] group-hover/item:scale-125 transition-transform\" data-kid=\"164\"></i>\n              <span class=\"font-medium\" data-kid=\"165\">Personalised Media Assets</span>\n            </li>\n          </ul>\n          <button class=\"w-full py-6 bg-[#0D3D20] text-white font-bold uppercase tracking-[0.3em] text-[10px] hover:bg-[#1E6B3C] transition-all shadow-xl\" data-kid=\"166\">Join the Challenge</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 bg-[#F9F5EE]\" data-kid=\"167\">\n  <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"168\">\n    <div class=\"relative bg-white border border-[#C9963A]/40 overflow-hidden shadow-2xl\" data-kid=\"169\">\n      <div class=\"absolute top-0 left-0 w-48 h-48 border-t-8 border-l-8 border-[#C9963A]/10 m-12\" data-kid=\"170\"></div>\n      <div class=\"absolute bottom-0 right-0 w-48 h-48 border-b-8 border-r-8 border-[#C9963A]/10 m-12\" data-kid=\"171\"></div>\n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-0 relative z-10\" data-kid=\"172\">\n        <div class=\"p-20 lg:p-32 bg-[#F9F5EE]/80 flex flex-col justify-center relative\" data-kid=\"173\">\n          <div class=\"absolute inset-0 heritage-ornament opacity-20 pointer-events-none\" data-kid=\"174\"></div>\n          <span class=\"relative z-10 text-[#C9963A] font-bold tracking-[0.6em] uppercase text-[9px] mb-10 block\" data-kid=\"175\">Heritage Archive • 2026 Edition</span>\n          <h2 class=\"relative z-10 font-playfair text-6xl md:text-7xl text-[#0D3D20] mb-12 leading-[0.95] tracking-tight\" data-kid=\"176\">\n            Top 50 <br data-kid=\"177\"> Sustainable <br data-kid=\"178\"><span class=\"italic text-[#C9963A]\" data-kid=\"179\">Leaders</span>\n          </h2>\n          <p class=\"relative z-10 text-xl text-gray-600 mb-14 leading-relaxed font-light\" data-kid=\"180\">\n            A prestigious hardcover publication documenting the vision of India's most influential green pioneers. An archival masterpiece for future generations.\n          </p>\n          \n          <div class=\"relative z-10 space-y-8 mb-16\" data-kid=\"181\">\n            <div class=\"flex items-center gap-6 group\" data-kid=\"182\">\n              <div class=\"w-14 h-14 rounded-full bg-white border border-[#C9963A]/30 flex items-center justify-center text-[#C9963A] shadow-lg group-hover:bg-[#C9963A] group-hover:text-white transition-all\" data-kid=\"183\">\n                <i data-lucide=\"book-open\" class=\"w-6 h-6\" data-kid=\"184\"></i>\n              </div>\n              <div class=\"flex flex-col\" data-kid=\"185\">\n                <span class=\"text-2xl font-playfair text-[#0D3D20]\" data-kid=\"186\">5,000+</span>\n                <span class=\"text-[10px] uppercase tracking-widest text-gray-400 font-bold\" data-kid=\"187\">Print Editions</span>\n              </div>\n            </div>\n            <div class=\"flex items-center gap-6 group text-[#1E6B3C]\" data-kid=\"188\">\n               <div class=\"w-14 h-14 rounded-full bg-white border border-[#1E6B3C]/30 flex items-center justify-center shadow-lg group-hover:bg-[#1E6B3C] group-hover:text-white transition-all\" data-kid=\"189\">\n                <i data-lucide=\"share-2\" class=\"w-6 h-6\" data-kid=\"190\"></i>\n              </div>\n              <div class=\"flex flex-col\" data-kid=\"191\">\n                <span class=\"text-2xl font-playfair text-[#0D3D20]\" data-kid=\"192\">5,00,000+</span>\n                <span class=\"text-[10px] uppercase tracking-widest text-gray-400 font-bold\" data-kid=\"193\">Digital Reach</span>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"relative z-10 flex flex-wrap items-center gap-8\" data-kid=\"194\">\n            <button class=\"px-12 py-6 bg-[#C9963A] text-white font-bold uppercase tracking-[0.3em] text-[10px] hover:bg-[#B0822F] transition-all shadow-xl\" data-kid=\"195\">Apply for Feature</button>\n            <div class=\"flex flex-col\" data-kid=\"196\">\n              <span class=\"text-[#DC2626] font-bold text-[10px] uppercase tracking-widest bg-red-50 px-3 py-1 border border-red-100 mb-1\" data-kid=\"197\">Status: Sold Out</span>\n              <span class=\"text-xs text-gray-400\" data-kid=\"198\">Main Cover Story</span>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"relative min-h-[750px] flex items-center justify-center p-20 lg:p-32 bg-[#0D3D20]\" data-kid=\"199\">\n          <div class=\"absolute inset-0 opacity-10\" data-kid=\"200\">\n             <img src=\"https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&w=1200&q=80\" alt=\"Book Background\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"201\">\n          </div>\n          <div class=\"relative group\" data-kid=\"202\">\n            <div class=\"absolute -inset-12 border-2 border-[#C9963A]/40 group-hover:-inset-16 transition-all duration-700\" data-kid=\"203\"></div>\n            <img src=\"https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&w=800&q=80\" alt=\"Coffee Table Book\" class=\"w-[450px] h-[600px] object-cover shadow-[50px_50px_100px_-20px_rgba(0,0,0,0.8)] border border-white/10 group-hover:-rotate-3 group-hover:translate-x-6 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"204\">\n            <div class=\"absolute inset-0 border border-white/10 pointer-events-none shadow-inner\" data-kid=\"205\"></div>\n            <div class=\"absolute -bottom-10 -right-10 w-40 h-40 bg-[#C9963A] p-8 flex items-center justify-center text-center shadow-2xl\" data-kid=\"206\">\n              <span class=\"text-white font-playfair text-xl leading-tight italic\" data-kid=\"207\">Collector's Edition</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"bg-[#0D3D20] text-white py-32 border-t-8 border-[#C9963A]\" data-kid=\"208\">\n  <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"209\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20 mb-32\" data-kid=\"210\">\n      <div class=\"max-w-xs\" data-kid=\"211\">\n        <div class=\"flex items-center gap-3 mb-10\" data-kid=\"212\">\n          <div class=\"w-12 h-12 bg-[#C9963A] rounded-sm flex items-center justify-center text-white shadow-xl\" data-kid=\"213\">\n            <i data-lucide=\"leaf\" class=\"w-7 h-7\" data-kid=\"214\"></i>\n          </div>\n          <span class=\"font-playfair text-3xl font-bold tracking-tight\" data-kid=\"215\">GOLDEN PRENEUR</span>\n        </div>\n        <p class=\"text-white/50 leading-loose mb-10 font-light\" data-kid=\"216\">\n          India's most prestigious platform identifying and celebrating the leaders of our sustainable future.\n        </p>\n        <div class=\"flex gap-5\" data-kid=\"217\">\n          <a href=\"#\" class=\"w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#C9963A] hover:-translate-y-1 transition-all\" data-kid=\"218\"><i data-lucide=\"instagram\" class=\"w-5 h-5\" data-kid=\"219\"></i></a>\n          <a href=\"#\" class=\"w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#C9963A] hover:-translate-y-1 transition-all\" data-kid=\"220\"><i data-lucide=\"facebook\" class=\"w-5 h-5\" data-kid=\"221\"></i></a>\n          <a href=\"#\" class=\"w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#C9963A] hover:-translate-y-1 transition-all\" data-kid=\"222\"><i data-lucide=\"linkedin\" class=\"w-5 h-5\" data-kid=\"223\"></i></a>\n        </div>\n      </div>\n      \n      <div data-kid=\"224\">\n        <h5 class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-[10px] mb-12\" data-kid=\"225\">The Ecosystem</h5>\n        <ul class=\"space-y-6 text-white/60 text-xs font-medium uppercase tracking-widest\" data-kid=\"226\">\n          <li data-kid=\"227\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"228\">About 1MEIF</a></li>\n          <li data-kid=\"229\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"230\">Legacy Award Tracks</a></li>\n          <li data-kid=\"231\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"232\">Nomination Ethics</a></li>\n          <li data-kid=\"233\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"234\">Elite Partners</a></li>\n          <li data-kid=\"235\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"236\">Summit Agenda</a></li>\n        </ul>\n      </div>\n      \n      <div data-kid=\"237\">\n        <h5 class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-[10px] mb-12\" data-kid=\"238\">Engagement</h5>\n        <ul class=\"space-y-6 text-white/60 text-xs font-medium uppercase tracking-widest\" data-kid=\"239\">\n          <li data-kid=\"240\"><a href=\"#\" class=\"hover:text-white transition-colors text-white\" data-kid=\"241\">Apply for Award</a></li>\n          <li data-kid=\"242\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"243\">Request VIP Pass</a></li>\n          <li data-kid=\"244\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"245\">Book Featurette</a></li>\n          <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"247\">Sponsorship Conclave</a></li>\n          <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"249\">Exhibit Innovation</a></li>\n        </ul>\n      </div>\n      \n      <div data-kid=\"250\">\n        <h5 class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-[10px] mb-12\" data-kid=\"251\">Secretariat</h5>\n        <div class=\"space-y-10\" data-kid=\"252\">\n          <div class=\"flex items-start gap-5 group\" data-kid=\"253\">\n            <i data-lucide=\"phone\" class=\"w-6 h-6 text-[#C9963A] group-hover:scale-110 transition-transform\" data-kid=\"254\"></i>\n            <div class=\"flex flex-col\" data-kid=\"255\">\n              <span class=\"text-white font-medium\" data-kid=\"256\">+91 70411 51714</span>\n              <span class=\"text-[10px] text-white/40 uppercase tracking-widest mt-1\" data-kid=\"257\">Vishal Parmar</span>\n            </div>\n          </div>\n          <div class=\"flex items-start gap-5 group\" data-kid=\"258\">\n            <i data-lucide=\"mail\" class=\"w-6 h-6 text-[#C9963A] group-hover:scale-110 transition-transform\" data-kid=\"259\"></i>\n            <div class=\"flex flex-col\" data-kid=\"260\">\n              <span class=\"text-white font-medium\" data-kid=\"261\">hello@goldenpreneur.in</span>\n              <span class=\"text-[10px] text-white/40 uppercase tracking-widest mt-1\" data-kid=\"262\">Official Enquiries</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"border-t border-white/10 pt-16 flex flex-col md:flex-row justify-between items-end gap-12\" data-kid=\"263\">\n      <div class=\"flex flex-col gap-6\" data-kid=\"264\">\n        <div class=\"flex items-center gap-10\" data-kid=\"265\">\n           <div class=\"flex flex-col\" data-kid=\"266\">\n            <span class=\"text-[9px] text-white/30 uppercase tracking-[0.3em] mb-2 font-black\" data-kid=\"267\">Certification</span>\n            <span class=\"text-xs text-white/50 font-medium\" data-kid=\"268\">NGO Section 8 | CSR Certified</span>\n           </div>\n           <div class=\"flex flex-col\" data-kid=\"269\">\n            <span class=\"text-[9px] text-white/30 uppercase tracking-[0.3em] mb-2 font-black\" data-kid=\"270\">Taxation</span>\n            <span class=\"text-xs text-white/50 font-medium\" data-kid=\"271\">80G & 12A Compliant</span>\n           </div>\n        </div>\n        <p class=\"text-[10px] text-white/30 uppercase tracking-widest\" data-kid=\"272\">Ahmedabad • Mumbai • Delhi • Bengaluru</p>\n      </div>\n      <div class=\"text-right\" data-kid=\"273\">\n        <p class=\"font-playfair italic text-3xl text-white/60 mb-6 leading-tight\" data-kid=\"274\">आइए, साथ मिलकर एक बेहतर <br data-kid=\"275\"> भविष्य का निर्माण करें।</p>\n        <p class=\"text-[9px] text-white/30 uppercase tracking-[0.4em] font-bold\" data-kid=\"276\">© 2026 GOLDEN PRENEUR ARCHIVE • ALL RIGHTS RESERVED.</p>\n      </div>\n    </div>\n  </div>\n</footer>\n\n\n<a href=\"#\" class=\"absolute bottom-10 right-10 z-[60] bg-[#25D366] text-white p-5 rounded-full shadow-[0_20px_40px_rgba(37,211,102,0.4)] hover:scale-110 hover:-translate-y-2 transition-all group overflow-hidden\" data-kid=\"277\">\n  <div class=\"absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300\" data-kid=\"278\"></div>\n  <i data-lucide=\"message-circle\" class=\"w-7 h-7 relative z-10\" data-kid=\"279\"></i>\n</a>\n</main>\n\n<script data-kid=\"280\">\n  document.addEventListener('DOMContentLoaded', function() {\n    lucide.createIcons();\n  });\n</script>\n",
