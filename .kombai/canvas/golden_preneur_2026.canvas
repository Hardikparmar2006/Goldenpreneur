        "head": "<meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Awards Overview - Golden preneur 2026</title>\n    <script src=\"https://unpkg.com/@phosphor-icons/web\"></script>"
