    "var_bbf2d0219933": {
      "type": "variant",
      "label": "Apply for Award - Variation 1 (Wizard)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 10780,
        "y": 0,
        "w": 1440,
        "h": 1890
