      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n\n    :root {\n        --color-primary: #1E6B3C;\n        --color-dark: #0D3D20;\n        --color-gold: #C9963A;\n        --color-leaf: #4CAF50;\n        --color-cream: #F9F5EE;\n    }\n\n    body {\n        font-family: 'Inter', sans-serif;\n        background-color: var(--color-cream);\n        color: #1A1A1A;\n        margin: 0;\n        padding: 0;\n    }\n\n    h1, h2, h3, .font-serif {\n        font-family: 'Playfair Display', serif;\n    }\n</style>\n\n<div class=\"flex flex-col\" data-kid=\"1\">\n    \n    <nav class=\"relative z-50 bg-white shadow-sm px-6 md:px-20 py-4 flex items-center justify-between\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <div class=\"w-10 h-10 bg-[var(--color-primary)] rounded-lg flex items-center justify-center text-white\" data-kid=\"4\">\n                <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 19l9 2-9-18-9 18 9-2zm0 0v-8\" data-kid=\"6\"></path></svg>\n            </div>\n            <span class=\"text-xl font-bold text-[var(--color-dark)] tracking-tight\" data-kid=\"7\">Golden preneur <span class=\"text-[var(--color-gold)]\" data-kid=\"8\">2026</span></span>\n        </div>\n        <div class=\"hidden lg:flex items-center gap-8 font-medium text-sm text-gray-700\" data-kid=\"9\">\n            <a href=\"#\" class=\"hover:text-[var(--color-primary)]\" data-kid=\"10\">Home</a>\n            <a href=\"#\" class=\"hover:text-[var(--color-primary)]\" data-kid=\"11\">About</a>\n            <a href=\"#\" class=\"text-[var(--color-primary)] font-bold\" data-kid=\"12\">Awards</a>\n            <a href=\"#\" class=\"hover:text-[var(--color-primary)]\" data-kid=\"13\">Sponsors</a>\n            <a href=\"#\" class=\"hover:text-[var(--color-primary)]\" data-kid=\"14\">Community</a>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"15\">\n            <button class=\"hidden md:block border-2 border-[var(--color-primary)] text-[var(--color-primary)] px-6 py-2.5 rounded-xl font-bold text-sm hover:bg-[var(--color-primary)] hover:text-white transition-all cursor-pointer\" data-kid=\"16\">Get Pass</button>\n            <button class=\"bg-[var(--color-primary)] text-white px-6 py-2.5 rounded-xl font-bold text-sm hover:bg-[var(--color-dark)] transition-all flex items-center gap-2 shadow-lg shadow-[var(--color-primary)]/20 cursor-pointer\" data-kid=\"17\">\n                <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"18\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" data-kid=\"19\"></path></svg> Apply Now\n            </button>\n        </div>\n    </nav>\n\n    \n    <header class=\"relative bg-[var(--color-dark)] py-24 md:py-32 px-6 md:px-20 overflow-hidden text-center\" data-kid=\"20\">\n        <div class=\"absolute inset-0 opacity-10\" data-kid=\"21\">\n            <svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"22\">\n                <path d=\"M0,100 C20,80 40,90 60,70 C80,50 100,60 100,40 L100,0 L0,0 Z\" fill=\"var(--color-leaf)\" data-kid=\"23\"></path>\n            </svg>\n        </div>\n        <div class=\"max-w-4xl mx-auto relative z-10\" data-kid=\"24\">\n            <h1 class=\"text-4xl md:text-6xl text-white font-bold mb-6\" data-kid=\"25\">Golden preneur Awards 2026 — How It Works</h1>\n            <p class=\"text-[var(--color-gold)] text-xl md:text-2xl font-medium mb-8\" data-kid=\"26\">India's most comprehensive green entrepreneurship platform celebrating 5 years of impact.</p>\n            <div class=\"flex flex-wrap justify-center gap-4\" data-kid=\"27\">\n                <div class=\"bg-white/10 backdrop-blur-md px-6 py-3 rounded-full border border-white/20 text-white text-sm\" data-kid=\"28\">\n                    <span class=\"text-[var(--color-gold)] font-bold\" data-kid=\"29\">4+</span> Editions Completed\n                </div>\n                <div class=\"bg-white/10 backdrop-blur-md px-6 py-3 rounded-full border border-white/20 text-white text-sm\" data-kid=\"30\">\n                    <span class=\"text-[var(--color-gold)] font-bold\" data-kid=\"31\">35+</span> Award Categories\n                </div>\n                <div class=\"bg-white/10 backdrop-blur-md px-6 py-3 rounded-full border border-white/20 text-white text-sm\" data-kid=\"32\">\n                    <span class=\"text-[var(--color-gold)] font-bold\" data-kid=\"33\">10,000+</span> Stories Published\n                </div>\n            </div>\n        </div>\n    </header>\n\n    \n    <section class=\"py-24 px-6 md:px-20\" data-kid=\"34\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"35\">\n            <div class=\"text-center mb-16\" data-kid=\"36\">\n                <h2 class=\"text-3xl md:text-4xl font-bold text-[var(--color-dark)] mb-4\" data-kid=\"37\">Choose Your Path to Recognition</h2>\n                <p class=\"text-gray-600 max-w-2xl mx-auto italic\" data-kid=\"38\">Whether you are a seasoned pioneer or a rising star, we have a platform for your story.</p>\n            </div>\n\n            <div class=\"grid lg:grid-cols-2 gap-10\" data-kid=\"39\">\n                \n                <div class=\"bg-white border-2 border-[var(--color-primary)] rounded-3xl p-8 md:p-12 shadow-xl hover:shadow-2xl transition-all relative overflow-hidden flex flex-col\" data-kid=\"40\">\n                    <div class=\"absolute -top-4 -right-4 w-32 h-32 bg-[var(--color-primary)]/5 rounded-full\" data-kid=\"41\"></div>\n                    <div class=\"mb-10 relative\" data-kid=\"42\">\n                        <span class=\"inline-block bg-[var(