      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap');\n\n  :root {\n    --primary-green: #1E6B3C;\n    --dark-green: #0D3D20;\n    --accent-gold: #C9963A;\n    --leaf-green: #4CAF50;\n    --cream: #F9F5EE;\n    --dark-text: #1A1A1A;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .editorial-border {\n    position: relative;\n  }\n  .editorial-border::after {\n    content: '';\n    position: absolute;\n    bottom: -1px;\n    left: 0;\n    width: 60px;\n    height: 1px;\n    background-color: var(--accent-gold);\n  }\n</style>\n\n<div class=\"font-sans bg-[var(--cream)] text-[var(--dark-text)] antialiased relative\" data-kid=\"1\">\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-100 px-6 md:px-12 py-5 flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-[var(--primary-green)] rounded-lg flex items-center justify-center text-white\" data-kid=\"4\">\n        <span class=\"font-serif font-bold text-xl\" data-kid=\"5\">G</span>\n      </div>\n      <div class=\"leading-tight hidden sm:block\" data-kid=\"6\">\n        <span class=\"block font-bold text-sm tracking-widest uppercase\" data-kid=\"7\">Golden preneur</span>\n        <span class=\"block text-[10px] text-gray-500 font-medium\" data-kid=\"8\">Awards 2026</span>\n      </div>\n    </div>\n    \n    <div class=\"hidden lg:flex items-center gap-8 text-sm font-semibold uppercase tracking-wider\" data-kid=\"9\">\n      <a href=\"#\" class=\"hover:text-[var(--primary-green)] transition-colors\" data-kid=\"10\">About</a>\n      <a href=\"#\" class=\"text-[var(--primary-green)]\" data-kid=\"11\">Awards</a>\n      <a href=\"#\" class=\"hover:text-[var(--primary-green)] transition-colors\" data-kid=\"12\">Winners</a>\n      <a href=\"#\" class=\"hover:text-[var(--primary-green)] transition-colors\" data-kid=\"13\">Coffee Table Book</a>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"14\">\n      <a href=\"#\" class=\"hidden md:block text-sm font-bold text-[var(--primary-green)] border-2 border-[var(--primary-green)] px-5 py-2 rounded-lg hover:bg-[var(--primary-green)] hover:text-white transition-all\" data-kid=\"15\">Get Pass</a>\n      <a href=\"#\" class=\"bg-[var(--primary-green)] text-white px-5 py-2 rounded-lg font-bold text-sm shadow-lg shadow-[var(--primary-green)]/20 hover:bg-[var(--dark-green)] transition-all\" data-kid=\"16\">Apply Now</a>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative pt-24 pb-32 px-6 md:px-12 overflow-hidden\" data-kid=\"17\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"18\">\n      <div class=\"flex flex-col items-center text-center\" data-kid=\"19\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--primary-green)]/10 text-[var(--primary-green)] font-bold text-xs mb-8 uppercase tracking-widest border border-[var(--primary-green)]/20\" data-kid=\"20\">\n          <svg class=\"w-3 h-3\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"21\"><path d=\"M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z\" data-kid=\"22\"></path></svg>\n          5th Year Anniversary Edition\n        </div>\n        \n        <h1 class=\"font-serif text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 max-w-5xl\" data-kid=\"23\">\n          The <span class=\"italic text-[var(--accent-gold)]\" data-kid=\"24\">Prestige</span> of Green Excellence\n        </h1>\n        \n        <p class=\"text-lg md:text-xl text-gray-600 max-w-2xl leading-relaxed mb-12\" data-kid=\"25\">\n          Recognizing the visionaries redefining sustainability across 148+ sectors. Join India's most trusted platform for green entrepreneurs.\n        </p>\n\n        <div class=\"flex flex-col sm:flex-row gap-4 w-full sm:w-auto\" data-kid=\"26\">\n          <button class=\"px-10 py-4 bg-[var(--primary-green)] text-white rounded-xl font-bold text-lg shadow-xl shadow-[var(--primary-green)]/30 hover:scale-[1.02] transition-transform flex items-center justify-center gap-2\" data-kid=\"27\">\n            <span data-kid=\"28\">Apply for Award</span>\n            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"29\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"30\"></path></svg>\n          </button>\n          <button class=\"px-10 py-4 bg-white border-2 border-gray-200 text-[var(--dark-text)] rounded-xl font-bold text-lg hover:border-[var(--accent-gold)] transition-colors\" data-kid=\"31\">\n            Download Brochure\n          </button>\n        </div>\n      </div>\n    </div>\n    \n    \n    <div class=\"absolute -top-24 -left-24 w-96 h-96 bg-[var(--primary-green)]/5 rounded-full blur-3xl\" data-kid=\"32\"></div>\n    <div class=\"absolute top-1/2 -right-24 w-64 h-64 bg-[var(--accent-gold)]/10 rounded-full blur-3xl\" data-kid=\"33\"></div>\n  </header>\n\n  \n  <section class=\"bg-white border-y border-gray-100 relative z-10\" data-kid=\"34\">\n    <div class=\"max-w-7xl mx-auto px-6 py-14\" data-kid=\"35\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\" data-kid=\"36\">\n        <div class=\"lg:col-span-8\" data-kid=\"37\">\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8\" data-kid=\"38\">\n            <div class=\"flex flex-col items-center md:items-start\" data-kid=\"39\">\n              <span class=\"font-serif text-5xl font-bold text-[var(--primary-green)] mb-2\" data-kid=\"40\">4<span class=\"text-2xl align-top text-[var(--accent-gold)]\" data-kid=\"41\">+</span></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400\" data-kid=\"42\">Years of Legacy</span>\n            </div>\n            <div class=\"flex flex-col items-center md:items-start\" data-kid=\"43\">\n              <span class=\"font-serif text-5xl font-bold text-[var(--primary-green)] mb-2\" data-kid=\"44\">10k<span class=\"text-2xl align-top text-[var(--accent-gold)]\" data-kid=\"45\">+</span></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400\" data-kid=\"46\">Entrepreneurs Published</span>\n            </div>\n            <div class=\"flex flex-col items-center md:items-start\" data-kid=\"47\">\n              <span class=\"font-serif text-5xl font-bold text-[var(--primary-green)] mb-2\" data-kid=\"48\">35<span class=\"text-2xl align-top text-[var(--accent-gold)]\" data-kid=\"49\">+</span></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400\" data-kid=\"50\">Award Categories</span>\n            </div>\n            <div class=\"flex flex-col items-center md:items-start\" data-kid=\"51\">\n              <span class=\"font-serif text-5xl font-bold text-[var(--primary-green)] mb-2\" data-kid=\"52\">500<span class=\"text-2xl align-top text-[var(--accent-gold)]\" data-kid=\"53\">+</span></span>\n              <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400\" data-kid=\"54\">Annual Delegates</span>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"lg:col-span-4 bg-gray-50 p-6 rounded-2xl border border-gray-100 flex items-center gap-5 group hover:border-[var(--accent-gold)]/30 transition-all shadow-xs\" data-kid=\"55\">\n          <div class=\"shrink-0 w-16 h-16 rounded-full border-2 border-dashed border-[var(--primary-green)]/30 flex items-center justify-center p-1\" data-kid=\"56\">\n             <div class=\"w-full h-full rounded-full bg-white flex items-center justify-center text-[var(--primary-green)] shadow-sm\" data-kid=\"57\">\n               <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"58\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" data-kid=\"59\"></path></svg>\n             </div>\n          </div>\n          <div class=\"leading-tight\" data-kid=\"60\">\n            <div class=\"text-sm font-bold text-gray-800\" data-kid=\"61\">1MEIF Forum Certified</div>\n            <div class=\"text-[10px] text-gray-500 font-medium mt-1\" data-kid=\"62\">Section 8 NGO | CSR00106194</div>\n            <div class=\"flex gap-2 mt-2\" data-kid=\"63\">\n              <span class=\"px-1.5 py-0.5 bg-green-100 text-[var(--primary-green)] text-[9px] font-bold rounded\" data-kid=\"64\">80G</span>\n              <span class=\"px-1.5 py-0.5 bg-green-100 text-[var(--primary-green)] text-[9px] font-bold rounded\" data-kid=\"65\">12A</span>\n              <span class=\"px-1.5 py-0.5 bg-green-100 text-[var(--primary-green)] text-[9px] font-bold rounded\" data-kid=\"66\">DARPAN</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-white px-6 md:px-12 relative\" data-kid=\"67\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"68\">\n      <div class=\"grid lg:grid-cols-2 gap-24 items-center\" data-kid=\"69\">\n        <div class=\"relative order-2 lg:order-1\" data-kid=\"70\">\n          <div class=\"aspect-[4/5] bg-gray-100 rounded-2xl overflow-hidden relative shadow-[0_32px_64px_-16px_rgba(0,0,0,0.15)] transform -rotate-1\" data-kid=\"71\">\n            <img src=\"https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?auto=format&w=800&q=80&fit=crop\" alt=\"Impact\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"72\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent\" data-kid=\"73\"></div>\n            <div class=\"absolute bottom-12 left-12 right-12\" data-kid=\"74\">\n              <p class=\"font-serif text-3xl italic text-white leading-relaxed mb-8\" data-kid=\"75\">\n                \"We don't just give awards; we build a movement that empowers the next generation of eco-warriors.\"\n              </p>\n              <div class=\"flex items-center gap-5\" data-kid=\"76\">\n                <div class=\"w-16 h-[1px] bg-[var(--accent-gold)]\" data-kid=\"77\"></div>\n                <div class=\"flex flex-col\" data-kid=\"78\">\n                  <span class=\"text-white text-xs font-bold uppercase tracking-[0.2em]\" data-kid=\"79\">Dr. Pravin Parmar</span>\n                  <span class=\"text-white/50 text-[10px] uppercase font-medium\" data-kid=\"80\">Founder, 1MEIF Forum</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"absolute -top-12 -right-6 md:-right-12 w-48 h-48 bg-[var(--accent-gold)] rounded-full flex items-center justify-center p-10 text-center text-white border-[8px] border-white shadow-2xl rotate-12 group transition-transform hover:rotate-0 duration-700\" data-kid=\"81\">\n            <div class=\"font-serif\" data-kid=\"82\">\n              <span class=\"block text-5xl font-bold leading-none\" data-kid=\"83\">05</span>\n              <span class=\"block text-[11px] uppercase font-bold tracking-[0.15em] mt-1\" data-kid=\"84\">Years of Trust</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"order-1 lg:order-2\" data-kid=\"85\">\n          <div class=\"inline-flex items-center gap-4 mb-8\" data-kid=\"86\">\n            <div class=\"w-12 h-[1px] bg-[var(--accent-gold)]\" data-kid=\"87\"></div>\n            <span class=\"text-[var(--accent-gold)] text-xs font-bold uppercase tracking-[0.3em]\" data-kid=\"88\">The Excellence Mandate</span>\n          </div>\n          <h2 class=\"font-serif text-4xl md:text-6xl leading-[1.15] mb-12\" data-kid=\"89\">Why this is the <span class=\"text-[var(--primary-green)] italic\" data-kid=\"90\">Gold Standard</span></h2>\n          \n          <div class=\"space-y-14\" data-kid=\"91\">\n            <div class=\"editorial-border pb-10\" data-kid=\"92\">\n              <h3 class=\"font-serif text-2xl mb-5 flex items-center gap-4\" data-kid=\"93\">\n                <span class=\"text-[var(--accent-gold)] text-sm italic font-serif\" data-kid=\"94\">01.</span>\n                Unmatched National Credibility\n              </h3>\n              <p class=\"text-gray-600 leading-relaxed text-lg\" data-kid=\"95\">\n                As a CEED association partner and 1MEIF initiative, our recognition is a badge of honor that opens doors to government bodies, MSME hubs, and national media networks.\n              </p>\n            </div>\n            \n            <div class=\"editorial-border pb-10\" data-kid=\"96\">\n              <h3 class=\"font-serif text-2xl mb-5 flex items-center gap-4\" data-kid=\"97\">\n                <span class=\"text-[var(--accent-gold)] text-sm italic font-serif\" data-kid=\"98\">02.</span>\n                Section 8 NGO Integrity\n              </h3>\n              <p class=\"text-gray-600 leading-relaxed text-lg\" data-kid=\"99\">\n                Operated by a certified Section 8 company with 80G and 12A status. We ensure every nomination and award is merit-driven, transparent, and socially responsible.\n              </p>\n            </div>\n\n            <div class=\"editorial-border pb-10\" data-kid=\"100\">\n              <h3 class=\"font-serif text-2xl mb-5 flex items-center gap-4\" data-kid=\"101\">\n                <span class=\"text-[var(--accent-gold)] text-sm italic font-serif\" data-kid=\"102\">03.</span>\n                Strategic Media Amplification\n              </h3>\n              <p class=\"text-gray-600 leading-relaxed text-lg\" data-kid=\"103\">\n                Featured prominently in the Coffee Table Book and VyapaarJagat.com, reaching a premium audience of 5,00,000+ digital readers and key industry stakeholders.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-[var(--cream)] px-6 md:px-12\" data-kid=\"104\">\n    <div class=\"max-w-5xl mx-auto\" data-kid=\"105\">\n      <div class=\"text-center mb-20\" data-kid=\"106\">\n        <div class=\"inline-block px-4 py-1 rounded-full bg-[var(--accent-gold)]/10 text-[var(--accent-gold)] text-[10px] font-bold uppercase tracking-[0.4em] mb-6\" data-kid=\"107\">Tracks & Nomination</div>\n        <h2 class=\"font-serif text-4xl md:text-6xl mb-6\" data-kid=\"108\">A Path for Every Leader</h2>\n        <p class=\"text-gray-500 max-w-2xl mx-auto text-lg leading-relaxed\" data-kid=\"109\">Choose the track that best aligns with your impact journey and organizational goals.</p>\n      </div>\n\n      <div class=\"grid md:grid-cols-2 gap-10\" data-kid=\"110\">\n        \n        <div class=\"bg-white rounded-3xl p-10 shadow-sm border border-gray-100 flex flex-col group hover:shadow-xl transition-all duration-500\" data-kid=\"111\">\n          <div class=\"mb-10\" data-kid=\"112\">\n            <div class=\"w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-[var(--primary-green)] mb-6 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-colors duration-500\" data-kid=\"113\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"114\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z\" data-kid=\"115\"></path></svg>\n            </div>\n            <h3 class=\"font-serif text-3xl mb-2\" data-kid=\"116\">Honorary Awards</h3>\n            <span class=\"text-[var(--accent-gold)] text-xs font-bold uppercase tracking-widest\" data-kid=\"117\">Lifetime & Sector Impact</span>\n          </div>\n          \n          <ul class=\"space-y-6 mb-12 flex-grow\" data-kid=\"118\">\n            <li class=\"flex items-center gap-3 text-gray-600\" data-kid=\"119\">\n              <svg class=\"w-5 h-5 text-green-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"120\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"121\"></path></svg>\n              <span data-kid=\"122\">100% Jury Evaluation</span>\n            </li>\n            <li class=\"flex items-center gap-3 text-gray-600\" data-kid=\"123\">\n              <svg class=\"w-5 h-5 text-green-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"124\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"125\"></path></svg>\n              <span data-kid=\"126\">Invitation or Self-Nomination</span>\n            </li>\n            <li class=\"flex items-center gap-3 font-bold text-[var(--primary-green)]\" data-kid=\"127\">\n              <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"128\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"129\"></path></svg>\n              <span data-kid=\"130\">Nomination is FREE</span>\n            </li>\n          </ul>\n\n          <div class=\"pt-8 border-t border-gray-100\" data-kid=\"131\">\n            <div class=\"text-3xl font-serif mb-6\" data-kid=\"132\">FREE</div>\n            <button class=\"w-full py-4 bg-[var(--primary-green)] text-white rounded-xl font-bold hover:bg-[var(--dark-green)] transition-all\" data-kid=\"133\">Nominate Now</button>\n          </div>\n        </div>\n\n        \n        <div class=\"bg-[var(--dark-green)] rounded-3xl p-10 shadow-2xl flex flex-col relative overflow-hidden group\" data-kid=\"134\">\n          <div class=\"absolute -top-24 -right-24 w-64 h-64 bg-[var(--accent-gold)]/20 blur-3xl rounded-full\" data-kid=\"135\"></div>\n          \n          <div class=\"mb-10 relative z-10\" data-kid=\"136\">\n            <div class=\"w-16 h-16 rounded-2xl bg-white/10 flex items-center justify-center text-[var(--accent-gold)] mb-6 group-hover:bg-[var(--accent-gold)] group-hover:text-white transition-colors duration-500\" data-kid=\"137\">\n              <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"138\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\" data-kid=\"139\"></path></svg>\n            </div>\n            <h3 class=\"font-serif text-3xl mb-2 text-white\" data-kid=\"140\">Rated Challenge</h3>\n            <span class=\"text-[var(--accent-gold)] text-xs font-bold uppercase tracking-widest\" data-kid=\"141\">Competitive Excellence</span>\n          </div>\n          \n          <ul class=\"space-y-6 mb-12 flex-grow relative z-10 text-white/80\" data-kid=\"142\">\n            <li class=\"flex items-center gap-3\" data-kid=\"143\">\n              <svg class=\"w-5 h-5 text-[var(--accent-gold)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"144\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"145\"></path></svg>\n              <span data-kid=\"146\">75% Jury + 25% Public Voting</span>\n            </li>\n            <li class=\"flex items-center gap-3\" data-kid=\"147\">\n              <svg class=\"w-5 h-5 text-[var(--accent-gold)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"148\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"149\"></path></svg>\n              <span data-kid=\"150\">Personalised Voting Creatives</span>\n            </li>\n            <li class=\"flex items-center gap-3\" data-kid=\"151\">\n              <svg class=\"w-5 h-5 text-[var(--accent-gold)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"152\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" data-kid=\"153\"></path></svg>\n              <span data-kid=\"154\">Public Visibility Campaign</span>\n            </li>\n          </ul>\n\n          <div class=\"pt-8 border-t border-white/10 relative z-10\" data-kid=\"155\">\n            <div class=\"text-3xl font-serif mb-6 text-white\" data-kid=\"156\"><span class=\"text-xs font-sans align-top opacity-50 mr-2 uppercase font-bold\" data-kid=\"157\">From</span>₹2,000</div>\n            <button class=\"w-full py-4 bg-[var(--accent-gold)] text-white rounded-xl font-bold hover:bg-[#b08330] transition-all\" data-kid=\"158\">Join the Challenge</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-white px-6 md:px-12\" data-kid=\"159\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"160\">\n      <div class=\"bg-[var(--cream)] rounded-[3rem] p-12 md:p-20 relative overflow-hidden border border-gray-100\" data-kid=\"161\">\n        <div class=\"max-w-3xl relative z-10\" data-kid=\"162\">\n          <h2 class=\"font-serif text-4xl md:text-5xl mb-12\" data-kid=\"163\">How we measure <span class=\"italic text-[var(--accent-gold)]\" data-kid=\"164\">Impact</span></h2>\n          \n          <div class=\"grid md:grid-cols-2 gap-x-16 gap-y-12\" data-kid=\"165\">\n            <div data-kid=\"166\">\n              <h4 class=\"font-serif text-xl mb-3\" data-kid=\"167\">Environmental Stewardship</h4>\n              <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"168\">Direct contribution to carbon reduction, resource efficiency, and ecosystem restoration.</p>\n            </div>\n            <div data-kid=\"169\">\n              <h4 class=\"font-serif text-xl mb-3\" data-kid=\"170\">Innovation & Scalability</h4>\n              <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"171\">The novelty of the green solution and its potential to be replicated across diverse markets.</p>\n            </div>\n            <div data-kid=\"172\">\n              <h4 class=\"font-serif text-xl mb-3\" data-kid=\"173\">Social Transformation</h4>\n              <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"174\">Impact on local communities, job creation in the green economy, and inclusivity.</p>\n            </div>\n            <div data-kid=\"175\">\n              <h4 class=\"font-serif text-xl mb-3\" data-kid=\"176\">Leadership & Ethics</h4>\n              <p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"177\">Commitment to transparent business practices and long-term sustainable vision.</p>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"absolute top-1/2 right-12 -translate-y-1/2 hidden lg:block\" data-kid=\"178\">\n           <div class=\"w-64 h-64 border border-[var(--accent-gold)]/20 rounded-full flex items-center justify-center\" data-kid=\"179\">\n              <div class=\"w-56 h-56 border border-[var(--accent-gold)]/40 rounded-full flex items-center justify-center\" data-kid=\"180\">\n                 <div class=\"w-48 h-48 bg-white rounded-full flex items-center justify-center shadow-lg\" data-kid=\"181\">\n                    <div class=\"text-center\" data-kid=\"182\">\n                       <span class=\"block text-[10px] uppercase font-bold tracking-widest text-gray-400\" data-kid=\"183\">Jury weightage</span>\n                       <span class=\"block text-4xl font-serif font-bold text-[var(--primary-green)]\" data-kid=\"184\">100%</span>\n                       <span class=\"block text-[8px] uppercase font-bold tracking-tighter text-gray-400\" data-kid=\"185\">For Honorary Track</span>\n                    </div>\n                 </div>\n              </div>\n           </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-white px-6 md:px-12 border-b border-gray-50\" data-kid=\"186\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"187\">\n      <div class=\"flex flex-col lg:flex-row lg:items-end justify-between mb-20 gap-8\" data-kid=\"188\">\n        <div class=\"max-w-2xl\" data-kid=\"189\">\n          <div class=\"flex items-center gap-4 mb-6\" data-kid=\"190\">\n             <div class=\"w-10 h-[1px] bg-[var(--accent-gold)]\" data-kid=\"191\"></div>\n             <span class=\"text-[var(--accent-gold)] text-[10px] font-bold uppercase tracking-[0.4em]\" data-kid=\"192\">Eligibility Criteria</span>\n          </div>\n          <h2 class=\"font-serif text-4xl md:text-6xl mb-6\" data-kid=\"193\">Designed for India's <span class=\"italic text-[var(--accent-gold)]\" data-kid=\"194\">Green Architects</span></h2>\n          <p class=\"text-gray-500 text-lg leading-relaxed max-w-xl\" data-kid=\"195\">Whether you are a startup founder or a corporate leader, if your work protects the planet, you belong here.</p>\n        </div>\n        <a href=\"#\" class=\"inline-flex items-center gap-3 text-[var(--primary-green)] font-bold text-sm uppercase tracking-widest group border-b-2 border-[var(--primary-green)] pb-2\" data-kid=\"196\">\n          Explore 35+ Categories \n          <svg class=\"w-5 h-5 group-hover:translate-x-2 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"197\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"198\"></path></svg>\n        </a>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10\" data-kid=\"199\">\n        <div class=\"group\" data-kid=\"200\">\n          <div class=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-[var(--primary-green)] mb-8 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-500 shadow-sm\" data-kid=\"201\">\n            <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"202\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4\" data-kid=\"203\"></path></svg>\n          </div>\n          <h4 class=\"font-serif text-2xl mb-4\" data-kid=\"204\">MSMEs</h4>\n          <p class=\"text-gray-500 leading-relaxed\" data-kid=\"205\">Established small & medium manufacturing or service units looking for national recognition.</p>\n        </div>\n\n        <div class=\"group\" data-kid=\"206\">\n          <div class=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-[var(--primary-green)] mb-8 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-500 shadow-sm\" data-kid=\"207\">\n            <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"208\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"209\"></path></svg>\n          </div>\n          <h4 class=\"font-serif text-2xl mb-4\" data-kid=\"210\">Startups</h4>\n          <p class=\"text-gray-500 leading-relaxed\" data-kid=\"211\">Early-stage ventures with innovative green solutions and high scalability potential.</p>\n        </div>\n\n        <div class=\"group\" data-kid=\"212\">\n          <div class=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-[var(--primary-green)] mb-8 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-500 shadow-sm\" data-kid=\"213\">\n            <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"214\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z\" data-kid=\"215\"></path></svg>\n          </div>\n          <h4 class=\"font-serif text-2xl mb-4\" data-kid=\"216\">NGOs</h4>\n          <p class=\"text-gray-500 leading-relaxed\" data-kid=\"217\">Non-profits and social enterprises driving deep-rooted environmental change.</p>\n        </div>\n\n        <div class=\"group\" data-kid=\"218\">\n          <div class=\"w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-[var(--primary-green)] mb-8 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-500 shadow-sm\" data-kid=\"219\">\n            <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"220\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\" data-kid=\"221\"></path></svg>\n          </div>\n          <h4 class=\"font-serif text-2xl mb-4\" data-kid=\"222\">CXOs</h4>\n          <p class=\"text-gray-500 leading-relaxed\" data-kid=\"223\">Visionary corporate leaders championing robust ESG and CSR initiatives.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 bg-[var(--dark-green)] relative overflow-hidden\" data-kid=\"224\">\n    <div class=\"max-w-5xl mx-auto px-6 text-center relative z-10\" data-kid=\"225\">\n      <div class=\"inline-flex items-center gap-4 mb-10 px-6 py-2 rounded-full border border-white/10 bg-white/5 text-white/80 text-xs font-bold uppercase tracking-[0.2em]\" data-kid=\"226\">\n         <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--accent-gold)]\" data-kid=\"227\"></span>\n         Nominations Closing Soon\n      </div>\n      <h2 class=\"font-serif text-5xl md:text-7xl text-white mb-10 leading-[1.1]\" data-kid=\"228\">Join the movement redefining <span class=\"text-[var(--accent-gold)] italic\" data-kid=\"229\">Sustainability in Bharat</span>.</h2>\n      <p class=\"text-white/50 text-xl mb-16 max-w-2xl mx-auto leading-relaxed font-light\" data-kid=\"230\">Join India's most comprehensive green entrepreneurship celebration. Recognition is the first step towards national impact.</p>\n      \n      <div class=\"flex flex-col sm:flex-row justify-center items-center gap-8\" data-kid=\"231\">\n        <button class=\"w-full sm:w-auto px-16 py-7 bg-[var(--accent-gold)] text-white rounded-2xl font-bold text-xl hover:bg-[#b08330] shadow-[0_25px_50px_-12px_rgba(201,150,58,0.5)] transition-all hover:-translate-y-1\" data-kid=\"232\">Apply Today — It's Free</button>\n        <button class=\"w-full sm:w-auto px-16 py-7 bg-white/5 text-white border border-white/10 rounded-2xl font-bold text-xl hover:bg-white/10 transition-all\" data-kid=\"233\">Request Full Brochure</button>\n      </div>\n    </div>\n    \n    <div class=\"absolute inset-0 opacity-[0.05] pointer-events-none mix-blend-overlay\" data-kid=\"234\">\n       <div class=\"absolute inset-0\" style=\"background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');\" data-kid=\"235\"></div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-white pt-20 pb-10 px-6 md:px-12 border-t border-gray-100\" data-kid=\"236\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"237\">\n      <div class=\"grid lg:grid-cols-4 gap-12 mb-16\" data-kid=\"238\">\n        <div data-kid=\"239\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"240\">\n            <div class=\"w-8 h-8 bg-[var(--primary-green)] rounded-md flex items-center justify-center text-white\" data-kid=\"241\">\n              <span class=\"font-serif font-bold text-sm\" data-kid=\"242\">G</span>\n            