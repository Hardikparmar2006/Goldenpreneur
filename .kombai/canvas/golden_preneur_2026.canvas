12\">\n                            <svg class=\"w-24 h-24\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"213\"><path d=\"M12 1L9 9l-8 3 8 3 3 8 3-8 8-3-8-3-3-8z\" data-kid=\"214\"></path></svg>\n                        </div>\n                        <h4 class=\"text-2xl font-bold mb-4\" data-kid=\"215\">The VyapaarJagat Advantage</h4>\n                        <p class=\"text-gray-600 mb-6 italic\" data-kid=\"216\">\"Winners get more than just a trophy. They get a platform to tell their story to 1,000,000+ readers across India.\"</p>\n                        <div class=\"flex items-center gap-2 font-bold text-[var(--color-primary)]\" data-kid=\"217\">\n                            <span data-kid=\"218\">Learn More about Story Drive</span>\n                            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"219\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14 5l7 7m0 0l-7 7m7-7H3\" data-kid=\"220\"></path></svg>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 px-6 md:px-20 bg-[var(--color-cream)]\" data-kid=\"221\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"222\">\n            <div class=\"text-center mb-16\" data-kid=\"223\">\n                <h2 class=\"text-3xl font-bold text-[var(--color-dark)] mb-4\" data-kid=\"224\">4 Steps to Your Rated Award</h2>\n                <div class=\"h-1 w-20 bg-[var(--color-gold)] mx-auto rounded-full\" data-kid=\"225\"></div>\n            </div>\n            \n            <div class=\"grid md:grid-cols-4 gap-8\" data-kid=\"226\">\n                <div class=\"relative text-center\" data-kid=\"227\">\n                    <div class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center font-bold text-[var(--color-dark)] shadow-sm mx-auto mb-6 relative z-10 border border-gray-100\" data-kid=\"228\">1</div>\n                    <div class=\"absolute top-6 left-1/2 w-full h-px bg-gray-200 hidden md:block\" data-kid=\"229\"></div>\n                    <h5 class=\"font-bold mb-2\" data-kid=\"230\">Register</h5>\n                    <p class=\"text-sm text-gray-500\" data-kid=\"231\">Fill the application form and choose Rated Track.</p>\n                </div>\n                <div class=\"relative text-center\" data-kid=\"232\">\n                    <div class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center font-bold text-[var(--color-dark)] shadow-sm mx-auto mb-6 relative z-10 border border-gray-100\" data-kid=\"233\">2</div>\n                    <div class=\"absolute top-6 left-1/2 w-full h-px bg-gray-200 hidden md:block\" data-kid=\"234\"></div>\n                    <h5 class=\"font-bold mb-2\" data-kid=\"235\">Get Link</h5>\n                    <p class=\"text-sm text-gray-500\" data-kid=\"236\">Receive your personalized digital voting link.</p>\n                </div>\n                <div class=\"relative text-center\" data-kid=\"237\">\n                    <div class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center font-bold text-[var(--color-dark)] shadow-sm mx-auto mb-6 relative z-10 border border-gray-100\" data-kid=\"238\">3</div>\n                    <div class=\"absolute top-6 left-1/2 w-full h-px bg-gray-200 hidden md:block\" data-kid=\"239\"></div>\n                    <h5 class=\"font-bold mb-2\" data-kid=\"240\">Share Link</h5>\n                    <p class=\"text-sm text-gray-500\" data-kid=\"241\">Engage your network to vote for your business.</p>\n                </div>\n                <div class=\"relative text-center\" data-kid=\"242\">\n                    <div class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center font-bold text-[var(--color-dark)] shadow-sm mx-auto mb-6 relative z-10 border border-gray-100\" data-kid=\"243\">4</div>\n                    <h5 class=\"font-bold mb-2\" data-kid=\"244\">Win Big</h5>\n                    <p class=\"text-sm text-gray-500\" data-kid=\"245\">Top scorers are felicitated on the grand stage.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 md:px-20\" data-kid=\"246\">\n        <div class=\"max-w-6xl mx-auto bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-dark)] rounded-[40px] p-8 md:p-24 text-center text-white relative overflow-hidden shadow-2xl shadow-[var(--color-primary)]/30\" data-kid=\"247\">\n            <div class=\"absolute inset-0 opacity-10\" data-kid=\"248\">\n                <svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"249\">\n                    <path d=\"M0,50 Q25,30 50,50 T100,50 L100,100 L0,100 Z\" fill=\"rgba(255,255,255,0.1)\" data-kid=\"250\"></path>\n                    <path d=\"M0,60 Q25,40 50,60 T100,60 L100,100 L0,100 Z\" fill=\"rgba(255,255,255,0.05)\" data-kid=\"251\"></path>\n                </svg>\n            </div>\n            <div class=\"relative z-10\" data-kid=\"252\">\n                <h2 class=\"text-4xl md:text-6xl font-bold mb-8\" data-kid=\"253\">Ready to claim your recognition?</h2>\n                <p class=\"text-xl text-white/80 mb-10 max-w-2xl mx-auto\" data-kid=\"254\">Nominations are closing soon for the 2026 edition. Join India's leading green entrepreneurs at Renaissance by Marriott, Ahmedabad.</p>\n                <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\" data-kid=\"255\">\n                    <button class=\"w-full sm:w-auto bg-white text-[var(--color-primary)] px-10 py-5 rounded-2xl font-bold text-lg hover:bg-[var(--color-cream)] transition-all shadow-xl\" data-kid=\"256\">Apply for Award</button>\n                    <button class=\"w-full sm:w-auto border-2 border-white text-white px-10 py-5 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all\" data-kid=\"257\">Download Brochure</button>\n                </div>\n                <p class=\"mt-8 text-sm text-white/60\" data-kid=\"258\">Need help? WhatsApp us: <a href=\"tel:+917041151714\" class=\"underline font-bold\" data-kid=\"259\">+91 70411 51714</a></p>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--color-dark)] text-white/60 py-20 px-6 md:px-20 border-t border-white/5\" data-kid=\"260\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12\" data-kid=\"261\">\n            <div data-kid=\"262\">\n                <div class=\"flex items-center gap-2 mb-6\" data-kid=\"263\">\n                    <div class=\"w-8 h-8 bg-[var(--color-primary)] rounded-lg flex items-center justify-center text-white\" data-kid=\"264\">\n                        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"265\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 19l9 2-9-18-9 18 9-2zm0 0v-8\" data-kid=\"266\"></path></svg>\n                    </div>\n                    <span class=\"text-lg font-bold text-white tracking-tight\" data-kid=\"267\">Golden preneur 2026</span>\n                </div>\n                <p class=\"text-sm leading-relaxed mb-6\" data-kid=\"268\">A high-impact platform by 1 Million Entrepreneurs International Forum (1MEIF), powered by VyapaarJagat.com.</p>\n                <div class=\"flex items-center gap-4\" data-kid=\"269\">\n                    <a href=\"#\" class=\"w-10 h-10 bg-white/5 rounded-full flex items-center justify-center hover:bg-[var(--color-primary)] transition-all\" data-kid=\"270\">\n                        <svg class=\"w-5 h-5 fill-current\" viewBox=\"0 0 24 24\" data-kid=\"271\"><path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1