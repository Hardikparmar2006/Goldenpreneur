      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap');\n    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css');\n\n    :root {\n        --primary-green: #1E6B3C;\n        --dark-green: #0D3D20;\n        --accent-gold: #C9963A;\n        --cream-bg: #F9F5EE;\n    }\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .gold-gradient {\n        background: linear-gradient(135deg, #C9963A 0%, #E5B566 50%, #C9963A 100%);\n    }\n\n    .card-hover {\n        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);\n    }\n    .card-hover:hover {\n        transform: translateY(-8px);\n        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);\n    }\n\n    .leaf-pattern {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0c1.657 0 3 1.343 3 3v10c0 1.657-1.343 3-3 3s-3-1.343-3-3V3c0-1.657 1.343-3 3-3zm15.5 6.5c1.17 1.17 1.17 3.07 0 4.24l-7.07 7.07c-1.17 1.17-3.07 1.17-4.24 0-1.17-1.17-1.17-3.07 0-4.24l7.07-7.07c1.17-1.17 3.07-1.17 4.24 0zM53.5 30c0 1.657-1.343 3-3 3h-10c-1.657 0-3-1.343-3-3s1.343-3 3-3h10c1.657 0 3 1.343 3 3zm-6.5 15.5c-1.17 1.17-3.07 1.17-4.24 0l-7.07-7.07c-1.17-1.17-1.17-3.07 0-4.24 1.17-1.17 3.07-1.17 4.24 0l7.07 7.07c1.17 1.17 1.17 3.07 0 4.24zM30 53.5c-1.657 0-3-1.343-3-3v-10c0-1.657 1.343-3 3-3s3 1.343 3 3v10c0 1.657-1.343 3-3 3zm-15.5-6.5c-1.17-1.17-1.17-3.07 0-4.24l7.07-7.07c1.17-1.17 3.07-1.17 4.24 0 1.17 1.17 1.17 3.07 0 4.24l-7.07 7.07c-1.17 1.17-3.07 1.17-4.24 0zM6.5 30c0-1.657 1.343-3 3-3h10c1.657 0 3 1.343 3 3s-1.343 3-3 3h-10c-1.657 0-3-1.343-3-3zm6.5-15.5c1.17-1.17 3.07-1.17 4.24 0l7.07 7.07c1.17 1.17 1.17 3.07 0 4.24-1.17 1.17-3.07 1.17-4.24 0l-7.07-7.07c-1.17-1.17-1.17-3.07 0-4.24z' fill='%23ffffff' fill-opacity='0.03' fill-rule='evenodd'/%3E%3C/svg%3E\");\n    }\n\n    .glass-nav {\n        background: rgba(255, 255, 255, 0.95);\n        backdrop-filter: blur(10px);\n        border-bottom: 1px solid rgba(0, 0, 0, 0.05);\n    }\n</style>\n\n<div class=\"bg-white text-[#1A1A1A] font-sans selection:bg-[#1E6B3C] selection:text-white\" data-kid=\"1\">\n    \n    <nav class=\"relative z-50 glass-nav\" data-kid=\"2\">\n        <div class=\"max-w-7xl mx-auto px-4 md:px-8\" data-kid=\"3\">\n            <div class=\"flex items-center justify-between h-20\" data-kid=\"4\">\n                <div class=\"flex items-center gap-8\" data-kid=\"5\">\n                    <div class=\"h-10\" data-kid=\"6\">\n                        <span class=\"text-2xl font-serif font-black tracking-tighter text-[#0D3D20]\" data-kid=\"7\">GREEN<span class=\"text-[#C9963A]\" data-kid=\"8\">PRENEUR</span> <span class=\"text-sm font-sans font-normal tracking-normal text-gray-400\" data-kid=\"9\">2026</span></span>\n                    </div>\n                    <div class=\"hidden lg:flex items-center gap-6\" data-kid=\"10\">\n                        <a href=\"#\" class=\"text-sm font-medium hover:text-[#1E6B3C] transition-colors\" data-kid=\"11\">HOME</a>\n                        <a href=\"#\" class=\"text-sm font-medium hover:text-[#1E6B3C] transition-colors\" data-kid=\"12\">ABOUT</a>\n                        <a href=\"#\" class=\"text-sm font-medium text-[#1E6B3C]\" data-kid=\"13\">EVENT 2026</a>\n                        <a href=\"#\" class=\"text-sm font-medium hover:text-[#1E6B3C] transition-colors\" data-kid=\"14\">AWARDS</a>\n                        <a href=\"#\" class=\"text-sm font-medium hover:text-[#1E6B3C] transition-colors\" data-kid=\"15\">WINNERS</a>\n                    </div>\n                </div>\n                <div class=\"flex items-center gap-4\" data-kid=\"16\">\n                    <button class=\"hidden md:block px-6 py-2.5 border-2 border-[#1E6B3C] text