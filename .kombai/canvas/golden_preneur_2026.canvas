      "html": "\n<div class=\"min-h-[1800px] bg-[#F9F5EE] font-sans text-[#1A1A1A]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n\n        .font-serif {\n            font-family: 'Playfair Display', serif;\n        }\n\n        .font-sans {\n            font-family: 'Inter', sans-serif;\n        }\n\n        /* Custom scrollbar for better mobile feel */\n        ::-webkit-scrollbar {\n            width: 6px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #F9F5EE;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #1E6B3C;\n            border-radius: 10px;\n        }\n    </style>\n\n    \n    <header class=\"relative z-50 bg-white shadow-xs px-4 py-3 flex items-center justify-between border-b border-gray-100\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <div class=\"w-10 h-10 bg-[#1E6B3C] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n                <span class=\"text-white font-serif font-bold text-xl\" data-kid=\"5\">G</span>\n            </div>\n            <div data-kid=\"6\">\n                <h1 class=\"text-lg font-bold text-[#0D3D20] leading-none uppercase tracking-wider\" data-kid=\"7\">Golden preneur</h1>\n                <p class=\"text-[10px] text-[#C9963A] font-semibold uppercase tracking-[0.2em]\" data-kid=\"8\">2026 Celebration</p>\n            </div>\n        </div>\n        <button class=\"p-2 text-[#1E6B3C]\" data-kid=\"9\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" data-kid=\"10\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\" data-kid=\"11\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\" data-kid=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\" data-kid=\"13\"></line></svg>\n        </button>\n    </header>\n\n    \n    <section class=\"bg-[#0D3D20] bg-[radial-gradient(circle_at_top_right,#1E6B3C,transparent)] text-white pt-12 pb-24 px-6 text-center\" data-kid=\"14\">\n        <h2 class=\"text-3xl font-serif font-bold mb-4\" data-kid=\"15\">Apply for Award</h2>\n        <p class=\"text-gray-300 max-w-lg mx-auto mb-8 text-lg\" data-kid=\"16\">Celebrate your journey as a green entrepreneur. Join India's most comprehensive sustainability platform.</p>\n        \n        <div class=\"flex flex-wrap justify-center gap-6 opacity-90\" data-kid=\"17\">\n            <div class=\"flex flex-col items-center\" data-kid=\"18\">\n                <div class=\"w-14 h-14 bg-white/10 ring-1 ring-white/20 rounded-2xl flex items-center justify-center mb-3\" data-kid=\"19\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#4CAF50\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check\" data-kid=\"20\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z\" data-kid=\"21\"></path><path d=\"m9 12 2 2 4-4\" data-kid=\"22\"></path></svg>\n                </div>\n                <span class=\"text-[11px] font-bold tracking-wider uppercase text-white/90\" data-kid=\"23\">NGO Certified</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"24\">\n                <div class=\"w-14 h-14 bg-white/10 ring-1 ring-white/20 rounded-2xl flex items-center justify-center mb-3\" data-kid=\"25\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#C9963A\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award\" data-kid=\"26\"><circle cx=\"12\" cy=\"8\" r=\"6\" data-kid=\"27\"></circle><path d=\"M15.477 12.89 17 22l-5-3-5 3 1.523-9.11\" data-kid=\"28\"></path></svg>\n                </div>\n                <span class=\"text-[11px] font-bold tracking-wider uppercase text-white/90\" data-kid=\"29\">5th Year Legacy</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"30\">\n                <div class=\"w-14 h-14 bg-white/10 ring-1 ring-white/20 rounded-2xl flex items-center justify-center mb-3\" data-kid=\"31\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#25D366\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check-circle\" data-kid=\"32\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\" data-kid=\"33\"></path><polyline points=\"22 4 12 14.01 9 11.01\" data-kid=\"34\"></polyline></svg>\n                </div>\n                <span class=\"text-[11px] font-bold tracking-wider uppercase text-white/90\" data-kid=\"35\">10k+ Stories</span>\n            </div>\n        </div>\n    </section>\n\n    \n    <main class=\"-mt-16 pb-20 px-4 md:px-0\" data-kid=\"36\">\n        <form class=\"max-w-2xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden\" data-kid=\"37\">\n            \n            \n            <div class=\"p-8 border-b border-gray-100\" data-kid=\"38\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"39\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#1E6B3C]/10 text-[#1E6B3C] flex items-center justify-center font-bold text-xl border border-[#1E6B3C]/20\" data-kid=\"40\">01</div>\n                    <h3 class=\"text-2xl font-bold text-[#0D3D20] font-serif\" data-kid=\"41\">Choose Award Track</h3>\n                </div>\n\n                <div class=\"grid grid-cols-1 gap-4\" data-kid=\"42\">\n                    \n                    <label class=\"relative block p-6 rounded-2xl border-2 border-[#1E6B3C] bg-[#1E6B3C]/5 cursor-pointer shadow-xs\" data-kid=\"43\">\n                        <input type=\"radio\" name=\"track\" value=\"honorary\" class=\"sr-only peer\" checked data-kid=\"44\">\n                        <div class=\"flex items-start justify-between\" data-kid=\"45\">\n                            <div data-kid=\"46\">\n                                <h4 class=\"text-xl font-bold text-[#0D3D20]\" data-kid=\"47\">Honorary Award</h4>\n                                <p class=\"text-sm text-gray-600 mt-1 leading-relaxed\" data-kid=\"48\">Recognising exceptional lifetime or sector contribution. Invitation-based or self-nomination.</p>\n                            </div>\n                            <span class=\"bg-[#1E6B3C] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider\" data-kid=\"49\">Free</span>\n                        </div>\n                        <div class=\"mt-5 flex items-center text-[#1E6B3C] font-bold text-sm\" data-kid=\"50\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#1E6B3C] text-white flex items-center justify-center mr-3\" data-kid=\"51\">\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"52\"><polyline points=\"20 6 9 17 4 12\" data-kid=\"53\"></polyline></svg>\n                            </div>\n                            Selected Track\n                        </div>\n                    </label>\n\n                    \n                    <label class=\"relative block p-6 rounded-2xl border-2 border-gray-100 bg-gray-50/50 hover:border-gray-200 cursor-pointer transition-all\" data-kid=\"54\">\n                        <input type=\"radio\" name=\"track\" value=\"rated\" class=\"sr-only peer\" data-kid=\"55\">\n                        <div class=\"flex items-start justify-between\" data-kid=\"56\">\n                            <div data-kid=\"57\">\n                                <h4 class=\"text-xl font-bold text-[#0D3D20]\" data-kid=\"58\">Rated Challenge</h4>\n                                <p class=\"text-sm text-gray-600 mt-1 leading-relaxed\" data-kid=\"59\">Jury evaluation + Public Voting. Get personalised creatives & national visibility.</p>\n                            </div>\n                            <span class=\"bg-[#C9963A] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider\" data-kid=\"60\">From ₹2,000</span>\n                        </div>\n                        <div class=\"mt-5 flex items-center text-gray-400 font-bold text-sm\" data-kid=\"61\">\n                            <div class=\"w-6 h-6 rounded-full border-2 border-current mr-3\" data-kid=\"62\"></div>\n                            Select this track\n                        </div>\n                    </label>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 border-b border-gray-100 bg-gray-50/20\" data-kid=\"63\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"64\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#1E6B3C]/10 text-[#1E6B3C] flex items-center justify-center font-bold text-xl border border-[#1E6B3C]/20\" data-kid=\"65\">02</div>\n                    <h3 class=\"text-2xl font-bold text-[#0D3D20] font-serif\" data-kid=\"66\">Your Details</h3>\n                </div>\n\n                <div class=\"space-y-6\" data-kid=\"67\">\n                    <div data-kid=\"68\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"69\">Full Name</label>\n                        <input type=\"text\" placeholder=\"e.g. Dr. Pravin Parmar\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"70\">\n                    </div>\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"71\">\n                        <div data-kid=\"72\">\n                            <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"73\">Mobile Number (WhatsApp preferred)</label>\n                            <input type=\"tel\" placeholder=\"+91 00000 00000\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"74\">\n                        </div>\n                        <div data-kid=\"75\">\n                            <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"76\">Email Address</label>\n                            <input type=\"email\" placeholder=\"hello@example.com\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"77\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 border-b border-gray-100\" data-kid=\"78\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"79\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#1E6B3C]/10 text-[#1E6B3C] flex items-center justify-center font-bold text-xl border border-[#1E6B3C]/20\" data-kid=\"80\">03</div>\n                    <h3 class=\"text-2xl font-bold text-[#0D3D20] font-serif\" data-kid=\"81\">Business Details</h3>\n                </div>\n\n                <div class=\"space-y-6\" data-kid=\"82\">\n                    <div data-kid=\"83\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"84\">Organisation / Business Name</label>\n                        <input type=\"text\" placeholder=\"e.g. Peers Global Business Platform\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"85\">\n                    </div>\n                    <div data-kid=\"86\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"87\">City</label>\n                        <input type=\"text\" placeholder=\"e.g. Ahmedabad\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"88\">\n                    </div>\n                    <div data-kid=\"89\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"90\">Award Category</label>\n                        <div class=\"relative\" data-kid=\"91\">\n                            <select class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all appearance-none cursor-pointer\" data-kid=\"92\">\n                                <option disabled selected data-kid=\"93\">Select a category</option>\n                                <option data-kid=\"94\">Eco-Friendly Product</option>\n                                <option data-kid=\"95\">Sustainable Manufacturer</option>\n                                <option data-kid=\"96\">Renewable Energy / Solar</option>\n                                <option data-kid=\"97\">Waste Management & Recycling</option>\n                                <option data-kid=\"98\">Water Conservation</option>\n                                <option data-kid=\"99\">Sustainable Agriculture & Organic</option>\n                                <option data-kid=\"100\">Healthcare & Eco-Wellness</option>\n                                <option data-kid=\"101\">Eco-Friendly Product Innovation</option>\n                                <option data-kid=\"102\">Green Construction & Architecture</option>\n                                <option data-kid=\"103\">Circular Economy Startup</option>\n                                <option data-kid=\"104\">Social Impact / NGO Impact</option>\n                                <option data-kid=\"105\">MSME Excellence - Manufacturing</option>\n                                <option data-kid=\"106\">MSME Excellence - Service</option>\n                                <option data-kid=\"107\">Other Green Sector Category</option>\n                            </select>\n                            <div class=\"absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\" data-kid=\"108\">\n                                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down\" data-kid=\"109\"><path d=\"m6 9 6 6 6-6\" data-kid=\"110\"></path></svg>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 bg-gray-50/20\" data-kid=\"111\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"112\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#1E6B3C]/10 text-[#1E6B3C] flex items-center justify-center font-bold text-xl border border-[#1E6B3C]/20\" data-kid=\"113\">04</div>\n                    <h3 class=\"text-2xl font-bold text-[#0D3D20] font-serif\" data-kid=\"114\">Your Story</h3>\n                </div>\n\n                <div class=\"space-y-6\" data-kid=\"115\">\n                    <div data-kid=\"116\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"117\">Briefly describe your green work (Impact & Goals)</label>\n                        <textarea rows=\"5\" placeholder=\"Tell us how your business is helping the environment...\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all resize-none\" data-kid=\"118\"></textarea>\n                        <p class=\"text-xs text-gray-400 mt-2\" data-kid=\"119\">Maximum 200 words. We want to hear about your unique contribution.</p>\n                    </div>\n                    <div data-kid=\"120\">\n                        <label class=\"block text-sm font-bold text-gray-700 mb-2\" data-kid=\"121\">Website or Social Link (Optional)</label>\n                        <input type=\"url\" placeholder=\"https://...\" class=\"w-full bg-white px-5 py-4 text-lg border-2 border-gray-100 rounded-xl focus:border-[#1E6B3C] focus:outline-hidden transition-all\" data-kid=\"122\">\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 bg-white\" data-kid=\"123\">\n                <button type=\"submit\" class=\"w-full bg-[#1E6B3C] hover:bg-[#0D3D20] text-white text-xl font-bold py-5 rounded-2xl shadow-lg shadow-[#1E6B3C]/20 transition-all transform active:scale-[0.98] flex items-center justify-center gap-3\" data-kid=\"124\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf\" data-kid=\"125\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\" data-kid=\"126\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\" data-kid=\"127\"></path></svg>\n                    Submit Nomination\n                </button>\n                <p class=\"text-center text-xs text-gray-400 mt-6 px-6\" data-kid=\"128\">By submitting, you agree to our terms and conditions. Our team will contact you within 48 hours.</p>\n            </div>\n\n        </form>\n\n        \n        <div class=\"max-w-2xl mx-auto mt-12 px-4\" data-kid=\"129\">\n            <div class=\"bg-[#1E6B3C]/5 border-2 border-dashed border-[#1E6B3C]/20 rounded-3xl p-8 flex flex-col items-center text-center\" data-kid=\"130\">\n                <div class=\"w-16 h-16 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-4 text-[#1E6B3C]\" data-kid=\"131\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-headset\" data-kid=\"132\"><path d=\"M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0h-3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-5Z\" data-kid=\"133\"></path><path d=\"M21 11v2a2 2 0 0 1-2 2h-5\" data-kid=\"134\"></path></svg>\n                </div>\n                <h4 class=\"text-xl font-bold text-[#0D3D20] mb-2 font-serif\" data-kid=\"135\">Confused about the categories?</h4>\n                <p class=\"text-gray-600 mb-6 leading-relaxed max-w-sm\" data-kid=\"136\">Our award coordinator <strong data-kid=\"137\">Vishal Parmar</strong> is available to help you complete your nomination via WhatsApp.</p>\n                <a href=\"https://wa.me/917041151714\" class=\"w-full sm:w-auto flex items-center justify-center gap-3 bg-[#25D366] text-white px-10 py-5 rounded-2xl font-bold shadow-xl shadow-[#25D366]/30 hover:bg-[#128C7E] transition-all transform hover:scale-[1.03] active:scale-[0.97]\" data-kid=\"138\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle\" data-kid=\"139\"><path d=\"M7.9 20A9 9 0 1 0 4 16.1L2 22Z\" data-kid=\"140\"></path></svg>\n                    WhatsApp Vishal: +91 70411 51714\n                </a>\n            </div>\n        </div>\n    </main>\n\n    \n    <footer class=\"bg-white border-t border-gray-100 py-16 px-6\" data-kid=\"141\">\n        <div class=\"max-w-4xl mx-auto text-center\" data-kid=\"142\">\n            <div class=\"flex flex-wrap justify-center items-center gap-10 mb-10 opacity-80\" data-kid=\"143\">\n                <div class=\"flex items-center gap-2\" data-kid=\"144\">\n                    <img src=\"https://img.icons8.com/fluency/96/handshake.png\" class=\"h-8 w-auto\" alt=\"Partner\" data-kid=\"145\">\n                    <span class=\"text-[#1E6B3C] font-bold\" data-kid=\"146\">Peers Global</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"147\">\n                    <img src=\"https://img.icons8.com/fluency/96/organization.png\" class=\"h-8 w-auto\" alt=\"NGO\" data-kid=\"148\">\n                    <span class=\"text-[#1E6B3C] font-bold\" data-kid=\"149\">1MEIF</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"150\">\n                    <img src=\"https://img.icons8.com/fluency/96/certificate.png\" class=\"h-8 w-auto\" alt=\"CEED\" data-kid=\"151\">\n                    <span class=\"text-[#1E6B3C] font-bold\" data-kid=\"152\">CEED Association</span>\n                </div>\n            </div>\n            <div class=\"h-px w-24 bg-gray-100 mx-auto mb-10\" data-kid=\"153\"></div>\n            <p class=\"text-sm text-gray-500 leading-relaxed mb-6\" data-kid=\"154\">\n                © 2026 Golden preneur | 1 Million Entrepreneurs International Forum<br data-kid=\"155\">\n                Section 8 Company | 80G & 12A Certified | CSR No. CSR00106194<br data-kid=\"156\">\n                Association Partner: CEED — Culinary Education & Enterprise Development\n            </p>\n            <div class=\"flex justify-center gap-4 text-gray-400\" data-kid=\"157\">\n                <a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"158\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-instagram\" data-kid=\"159\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\" data-kid=\"160\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\" data-kid=\"161\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\" data-kid=\"162\"></line></svg></a>\n                <a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"163\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-linkedin\" data-kid=\"164\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\" data-kid=\"165\"></path><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\" data-kid=\"166\"></rect><circle cx=\"4\" cy=\"4\" r=\"2\" data-kid=\"167\"></circle></svg></a>\n                <a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"168\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-facebook\" data-kid=\"169\"><path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\" data-kid=\"170\"></path></svg></a>\n            </div>\n            <p class=\"text-xs text-gray-600 mt-8 uppercase tracking-[0.2em] font-medium\" data-kid=\"171\">आइए, साथ मिलकर एक बेहतर भविष्य का निर्माण करें</p>\n        </div>\n    </footer>\n</div>\n",
