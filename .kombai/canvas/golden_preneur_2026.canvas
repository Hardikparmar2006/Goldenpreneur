      "html": "\n<div class=\"font-['Inter'] text-[#1A1A1A] bg-[#F9F5EE]\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css');\n\n        .font-serif { font-family: 'Playfair Display', serif; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        .agenda-dot::after {\n            content: '';\n            position: absolute;\n            left: 50%;\n            top: 100%;\n            width: 2px;\n            height: 140%;\n            background: #C9963A;\n            opacity: 0.4;\n            transform: translateX(-50%);\n        }\n        .agenda-item:last-child .agenda-dot::after {\n            display: none;\n        }\n\n        .brochure-border {\n            border: 1px solid rgba(201, 150, 58, 0.2);\n            position: relative;\n            background: rgba(255, 255, 255, 0.03);\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .brochure-border::before {\n            content: '';\n            position: absolute;\n            top: 6px;\n            left: 6px;\n            right: 6px;\n            bottom: 6px;\n            border: 1px solid rgba(201, 150, 58, 0.1);\n            pointer-events: none;\n        }\n        .brochure-border:hover {\n            background: rgba(201, 150, 58, 0.08);\n            border-color: rgba(201, 150, 58, 0.5);\n            transform: translateY(-4px);\n        }\n\n        .hero-pattern {\n            background-image: url(\"https://www.transparenttextures.com/patterns/leaf.png\");\n        }\n    </style>\n\n    \n    <nav class=\"relative z-50 bg-white border-b border-gray-100 px-6 py-6 flex items-center justify-between\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <div class=\"w-10 h-10 bg-[#1E6B3C] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n                <i class=\"ri-leaf-line text-white text-xl\" data-kid=\"5\"></i>\n            </div>\n            <div data-kid=\"6\">\n                <span class=\"block font-bold text-[#0D3D20] leading-none uppercase tracking-tighter text-xl\" data-kid=\"7\">Golden preneur</span>\n                <span class=\"block text-[10px] text-[#C9963A] uppercase tracking-widest leading-none\" data-kid=\"8\">2026 Edition</span>\n            </div>\n        </div>\n        <div class=\"hidden lg:flex items-center gap-10 text-base font-semibold uppercase tracking-widest\" data-kid=\"9\">\n            <a href=\"#\" class=\"hover:text-[#1E6B3C] transition-colors text-sm\" data-kid=\"10\">Overview</a>\n            <a href=\"#agenda\" class=\"hover:text-[#1E6B3C] transition-colors text-sm\" data-kid=\"11\">Agenda</a>\n            <a href=\"#venue\" class=\"hover:text-[#1E6B3C] transition-colors text-sm\" data-kid=\"12\">Venue</a>\n            <a href=\"#attendees\" class=\"hover:text-[#1E6B3C] transition-colors text-sm\" data-kid=\"13\">Who Should Attend</a>\n        </div>\n        <div class=\"flex items-center gap-5\" data-kid=\"14\">\n            <a href=\"#\" class=\"hidden sm:block text-[11px] font-bold border-2 border-[#1E6B3C] text-[#1E6B3C] px-7 py-2.5 rounded-lg hover:bg-[#1E6B3C] hover:text-white transition-all uppercase tracking-[0.2em]\" data-kid=\"15\">Apply for Award</a>\n            <a href=\"#register\" class=\"text-[11px] font-bold bg-[#1E6B3C] text-white px-7 py-2.5 rounded-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all uppercase tracking-[0.2em]\" data-kid=\"16\">Get Pass</a>\n        </div>\n    </nav>\n\n    \n    <header class=\"relative bg-[#0D3D20] pt-32 pb-40 px-6 overflow-hidden\" data-kid=\"17\">\n        \n        <div class=\"absolute inset-0 hero-pattern opacity-10\" data-kid=\"18\"></div>\n        \n        <div class=\"absolute inset-0\" data-kid=\"19\">\n            <div class=\"absolute -top-24 -left-24 w-[600px] h-[600px] bg-[#C9963A] rounded-full blur-[160px] opacity-10\" data-kid=\"20\"></div>\n            <div class=\"absolute -bottom-24 -right-24 w-[600px] h-[600px] bg-[#1E6B3C] rounded-full blur-[160px] opacity-20\" data-kid=\"21\"></div>\n        </div>\n        \n        <div class=\"max-w-6xl mx-auto text-center relative z-10\" data-kid=\"22\">\n            <div class=\"inline-flex items-center gap-3 px-6 py-2 border border-[#C9963A]/30 rounded-full mb-10 bg-[#0D3D20]/50 backdrop-blur-sm\" data-kid=\"23\">\n                <span class=\"w-2 h-2 bg-[#C9963A] rounded-full animate-ping\" data-kid=\"24\"></span>\n                <span class=\"text-[#C9963A] font-bold text-[10px] md:text-xs uppercase tracking-[0.4em]\" data-kid=\"25\">5th Year Milestone Celebration</span>\n            </div>\n            \n            <h1 class=\"font-serif text-6xl md:text-9xl text-white mb-10 leading-[0.9] tracking-tight\" data-kid=\"26\">\n                Golden preneur<br data-kid=\"27\"><span class=\"text-[#C9963A]\" data-kid=\"28\">2026</span>\n            </h1>\n            \n            <p class=\"font-sans text-xl md:text-2xl text-gray-400 font-light max-w-2xl mx-auto mb-20 leading-relaxed italic\" data-kid=\"29\">\n                India's most comprehensive gathering of green visionaries redefining the sustainability landscape.\n            </p>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto border-t border-white/10 pt-20\" data-kid=\"30\">\n                <div class=\"flex flex-col items-center group\" data-kid=\"31\">\n                    <div class=\"w-16 h-16 rounded-full border border-white/10 flex items-center justify-center mb-6 group-hover:border-[#C9963A]/50 transition-colors\" data-kid=\"32\">\n                        <i class=\"ri-calendar-event-line text-2xl text-[#C9963A]\" data-kid=\"33\"></i>\n                    </div>\n                    <p class=\"text-[10px] text-gray-500 uppercase tracking-widest mb-2 font-bold\" data-kid=\"34\">Date</p>\n                    <p class=\"text-white font-serif text-2xl\" data-kid=\"35\">25 June 2026</p>\n                    <p class=\"text-gray-500 text-xs mt-1\" data-kid=\"36\">Thursday</p>\n                </div>\n                <div class=\"flex flex-col items-center group\" data-kid=\"37\">\n                    <div class=\"w-16 h-16 rounded-full border border-white/10 flex items-center justify-center mb-6 group-hover:border-[#C9963A]/50 transition-colors\" data-kid=\"38\">\n                        <i class=\"ri-map-pin-2-line text-2xl text-[#C9963A]\" data-kid=\"39\"></i>\n                    </div>\n                    <p class=\"text-[10px] text-gray-500 uppercase tracking-widest mb-2 font-bold\" data-kid=\"40\">Venue</p>\n                    <p class=\"text-white font-serif text-2xl\" data-kid=\"41\">Marriott Hotel</p>\n                    <p class=\"text-gray-500 text-xs mt-1\" data-kid=\"42\">Renaissance, Ahmedabad</p>\n                </div>\n                <div class=\"flex flex-col items-center group\" data-kid=\"43\">\n                    <div class=\"w-16 h-16 rounded-full border border-white/10 flex items-center justify-center mb-6 group-hover:border-[#C9963A]/50 transition-colors\" data-kid=\"44\">\n                        <i class=\"ri-time-line text-2xl text-[#C9963A]\" data-kid=\"45\"></i>\n                    </div>\n                    <p class=\"text-[10px] text-gray-500 uppercase tracking-widest mb-2 font-bold\" data-kid=\"46\">Time</p>\n                    <p class=\"text-white font-serif text-2xl\" data-kid=\"47\">2:00 – 9:30 PM</p>\n                    <p class=\"text-gray-500 text-xs mt-1\" data-kid=\"48\">Evening Gala</p>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    \n    <section id=\"agenda\" class=\"py-32 px-6 bg-[#FDFCF8] relative overflow-hidden\" data-kid=\"49\">\n        <div class=\"absolute left-0 top-0 w-full h-full opacity-5 pointer-events-none hero-pattern\" data-kid=\"50\"></div>\n        <div class=\"max-w-4xl mx-auto relative z-10\" data-kid=\"51\">\n            <div class=\"text-center mb-32\" data-kid=\"52\">\n                <h2 class=\"font-serif text-5xl md:text-7xl text-[#0D3D20] mb-6 tracking-tight\" data-kid=\"53\">The Agenda</h2>\n                <p class=\"text-[#C9963A] font-bold uppercase tracking-[0.4em] text-[10px]\" data-kid=\"54\">A Masterclass in Transformation</p>\n                <div class=\"flex items-center justify-center gap-4 mt-8\" data-kid=\"55\">\n                    <div class=\"h-px w-12 bg-[#C9963A]/30\" data-kid=\"56\"></div>\n                    <i class=\"ri-infinity-line text-[#C9963A] text-xl\" data-kid=\"57\"></i>\n                    <div class=\"h-px w-12 bg-[#C9963A]/30\" data-kid=\"58\"></div>\n                </div>\n            </div>\n\n            <div class=\"space-y-0\" data-kid=\"59\">\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"60\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"61\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"62\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"63\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"64\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"65\">02:00 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"66\">Arrival & Golden preneur Celebration</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"67\">Warm welcome and networking reception for all attendees to kick off the 5th anniversary celebration.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"68\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"69\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"70\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"71\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"72\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"73\">03:15 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"74\">Panel Discussion: Sustainability in Viksit Bharat</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"75\">High-level dialogue on aligning entrepreneurship with India's 2047 sustainable development goals.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"76\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"77\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"78\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"79\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"80\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"81\">04:15 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"82\">Coffee Table Book Launch</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"83\">Exclusive unveiling of \"Top 50 Sustainable Leaders\" – a premium publication documenting India's green journey.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"84\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"85\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"86\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"87\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"88\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"89\">04:30 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"90\">Golden preneur Awards Ceremony</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"91\">Honoring excellence across 25+ categories in the green business ecosystem.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"92\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"93\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"94\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"95\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"96\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"97\">05:15 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"98\">Peers Global Roundtable Conclave</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"99\">A curated brainstorming session for industry leaders to forge strategic partnerships.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"100\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"101\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"102\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"103\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"104\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"105\">06:45 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"106\">Leadership Ceremony & New Member Welcome</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"107\">Inducting new members into the 1MEIF community and celebrating visionary leadership.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16 pb-16\" data-kid=\"108\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"109\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"110\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"111\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"112\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"113\">07:35 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"114\">Peers Global Awards</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"115\">Recognizing exceptional global contributions to the green business network.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"agenda-item flex gap-8 md:gap-16\" data-kid=\"116\">\n                    <div class=\"flex flex-col items-center pt-2\" data-kid=\"117\">\n                        <div class=\"agenda-dot w-5 h-5 rounded-full bg-[#C9963A] relative z-10 shadow-[0_0_0_8px_rgba(201,150,58,0.1)] flex items-center justify-center\" data-kid=\"118\">\n                            <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"119\"></div>\n                        </div>\n                    </div>\n                    <div data-kid=\"120\">\n                        <span class=\"text-[#C9963A] font-bold text-lg mb-1 block\" data-kid=\"121\">08:45 PM</span>\n                        <h3 class=\"font-serif text-2xl text-[#0D3D20] mb-3\" data-kid=\"122\">Gala Dinner & Live Music</h3>\n                        <p class=\"text-gray-600 leading-relaxed max-w-2xl\" data-kid=\"123\">Concluding the evening with a grand dinner and live cultural performances for networking.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"venue\" class=\"py-32 px-6 bg-white\" data-kid=\"124\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"125\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\" data-kid=\"126\">\n                <div data-kid=\"127\">\n                    <h2 class=\"font-serif text-4xl md:text-5xl text-[#0D3D20] mb-8\" data-kid=\"128\">The Venue</h2>\n                    <p class=\"text-[#C9963A] font-bold uppercase tracking-widest text-sm mb-6\" data-kid=\"129\">Renaissance by Marriott Ahmedabad</p>\n                    <p class=\"text-gray-600 text-lg leading-relaxed mb-8\" data-kid=\"130\">\n                        Experience the perfect blend of luxury and sustainability at one of Ahmedabad's most prestigious hospitality destinations. Renaissance by Marriott provides an inspiring setting for the 5th Golden preneur celebration.\n                    </p>\n                    \n                    <div class=\"space-y-6\" data-kid=\"131\">\n                        <div class=\"flex gap-4\" data-kid=\"132\">\n                            <div class=\"w-12 h-12 bg-[#F9F5EE] rounded-full flex items-center justify-center shrink-0\" data-kid=\"133\">\n                                <i class=\"ri-parking-box-line text-[#1E6B3C] text-xl\" data-kid=\"134\"></i>\n                            </div>\n                            <div data-kid=\"135\">\n                                <h4 class=\"font-bold text-[#0D3D20]\" data-kid=\"136\">Premium Facilities</h4>\n                                <p class=\"text-gray-500 text-sm\" data-kid=\"137\">State-of-the-art conference halls and ample parking for 500+ guests.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\" data-kid=\"138\">\n                            <div class=\"w-12 h-12 bg-[#F9F5EE] rounded-full flex items-center justify-center shrink-0\" data-kid=\"139\">\n                                <i class=\"ri-restaurant-line text-[#1E6B3C] text-xl\" data-kid=\"140\"></i>\n                            </div>\n                            <div data-kid=\"141\">\n                                <h4 class=\"font-bold text-[#0D3D20]\" data-kid=\"142\">Culinary Excellence</h4>\n                                <p class=\"text-gray-500 text-sm\" data-kid=\"143\">Curated green menu featuring local and sustainable ingredients.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\" data-kid=\"144\">\n                            <div class=\"w-12 h-12 bg-[#F9F5EE] rounded-full flex items-center justify-center shrink-0\" data-kid=\"145\">\n                                <i class=\"ri-map-pin-line text-[#1E6B3C] text-xl\" data-kid=\"146\"></i>\n                            </div>\n                            <div data-kid=\"147\">\n                                <h4 class=\"font-bold text-[#0D3D20]\" data-kid=\"148\">Strategic Location</h4>\n                                <p class=\"text-gray-500 text-sm\" data-kid=\"149\">Centrally located in Ahmedabad's business hub, S.G. Highway.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"relative group\" data-kid=\"150\">\n                    <div class=\"absolute -inset-4 border-2 border-[#C9963A]/20 rounded-2xl group-hover:-inset-6 transition-all duration-500\" data-kid=\"151\"></div>\n                    <img src=\"https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Marriott Hotel\" class=\"relative w-full h-[500px] object-cover rounded-xl shadow-2xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"152\">\n                    <div class=\"absolute bottom-16 left-8 right-8 bg-white/95 backdrop-blur-md p-10 rounded-lg shadow-2xl border border-white/20\" data-kid=\"153\">\n                        <p class=\"text-[10px] text-[#C9963A] font-bold uppercase tracking-[0.3em] mb-2\" data-kid=\"154\">Location</p>\n                        <p class=\"text-[#0D3D20] font-bold text-lg leading-tight\" data-kid=\"155\">Behind Ganesh Meridian, S.G. Highway, Sola, Ahmedabad</p>\n                        <a href=\"#\" class=\"inline-flex items-center gap-2 mt-6 text-[#1E6B3C] font-bold text-xs uppercase tracking-widest hover:gap-3 transition-all\" data-kid=\"156\">Get Directions <i class=\"ri-arrow-right-line\" data-kid=\"157\"></i></a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"attendees\" class=\"py-32 px-6 bg-[#0D3D20] text-white relative overflow-hidden\" data-kid=\"158\">\n        <div class=\"absolute inset-0 hero-pattern opacity-5\" data-kid=\"159\"></div>\n        <div class=\"max-w-6xl mx-auto relative z-10\" data-kid=\"160\">\n            <div class=\"text-center mb-24\" data-kid=\"161\">\n                <h2 class=\"font-serif text-4xl md:text-6xl mb-6\" data-kid=\"162\">Who Should Attend</h2>\n                <p class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-[10px] mb-8\" data-kid=\"163\">Uniting the Pillars of Sustainability</p>\n                <p class=\"text-gray-400 max-w-xl mx-auto text-sm leading-relaxed\" data-kid=\"164\">Join the most influential gathering of leaders committed to environmental excellence and economic growth.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"165\">\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"166\">\n                    <i class=\"ri-leaf-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"167\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"168\">Green Entrepreneurs</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"169\">\n                    <i class=\"ri-building-4-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"170\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"171\">MSME Owners</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"172\">\n                    <i class=\"ri-rocket-2-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"173\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"174\">Sustainable Startups</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"175\">\n                    <i class=\"ri-user-star-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"176\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"177\">CXOs & Executives</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"178\">\n                    <i class=\"ri-heart-pulse-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"179\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"180\">NGO Leaders</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"181\">\n                    <i class=\"ri-bank-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"182\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"183\">Govt Officials</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"184\">\n                    <i class=\"ri-shake-hands-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"185\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"186\">Corporate Sponsors</h4>\n                </div>\n                \n                <div class=\"brochure-border p-8 text-center bg-white/5 hover:bg-white/10 transition-colors\" data-kid=\"187\">\n                    <i class=\"ri-compass-3-line text-3xl text-[#C9963A] mb-4 block\" data-kid=\"188\"></i>\n                    <h4 class=\"font-bold uppercase tracking-widest text-sm\" data-kid=\"189\">Green Architects</h4>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"register\" class=\"bg-[#C9963A] py-20 px-6 relative overflow-hidden\" data-kid=\"190\">\n        <div class=\"absolute right-0 top-0 bottom-0 w-1/3 bg-black/5 -skew-x-12 translate-x-1/2\" data-kid=\"191\"></div>\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between relative z-10 gap-8\" data-kid=\"192\">\n            <div class=\"text-center md:text-left\" data-kid=\"193\">\n                <h2 class=\"font-serif text-3xl md:text-5xl text-white mb-4\" data-kid=\"194\">Secure Your Exclusive Pass</h2>\n                <p class=\"text-white/80 text-lg font-sans\" data-kid=\"195\">Limited slots available for the 5th Year Mega Event. Register before slots fill up.</p>\n            </div>\n            <div class=\"flex flex-wrap justify-center gap-4 shrink-0\" data-kid=\"196\">\n                <button class=\"px-10 py-5 bg-[#0D3D20] text-white font-bold rounded-lg shadow-2xl hover:bg-[#1E6B3C] transition-all uppercase tracking-[0.2em] text-sm\" data-kid=\"197\">Get Your Pass Now</button>\n                <button class=\"px-10 py-5 bg-white text-[#0D3D20] font-bold rounded-lg shadow-2xl hover:bg-gray-100 transition-all uppercase tracking-[0.2em] text-sm flex items-center gap-2\" data-kid=\"198\">\n                    <i class=\"ri-download-line\" data-kid=\"199\"></i> Brochure\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-20 px-6 bg-[#FDFCF8] border-t border-gray-100\" data-kid=\"200\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"201\">\n            <div class=\"flex flex-col md:flex-row items-center justify-between gap-12 text-center md:text-left\" data-kid=\"202\">\n                <div class=\"max-w-md\" data-kid=\"203\">\n                    <h3 class=\"font-serif text-3xl text-[#0D3D20] mb-4\" data-kid=\"204\">Global Vision, Local Action</h3>\n                    <p class=\"text-gray-600 text-sm\" data-kid=\"205\">Golden preneur 2026 is strictly aligned with the UN Sustainable Development Goals and the vision for Viksit Bharat @2047.</p>\n                </div>\n                <div class=\"flex flex-wrap justify-center gap-10 items-center transition-all duration-500\" data-kid=\"206\">\n                    <div class=\"flex flex-col items-center\" data-kid=\"207\">\n                        <span class=\"text-[#0D3D20] font-bold text-[10px] uppercase tracking-[0.2em] mb-3\" data-kid=\"208\">Viksit Bharat @2047</span>\n                        <div class=\"w-16 h-16 bg-white rounded-full flex items-center justify-center border border-[#1E6B3C]/10 shadow-sm\" data-kid=\"209\">\n                            <i class=\"ri-flag-line text-[#1E6B3C] text-2xl\" data-kid=\"210\"></i>\n                        </div>\n                    </div>\n                    <div class=\"flex flex-wrap justify-center gap-4\" data-kid=\"211\">\n                        <div class=\"w-14 h-14 bg-white border border-[#C9963A]/20 flex flex-col items-center justify-center rounded-lg shadow-sm\" data-kid=\"212\">\n                            <span class=\"text-[10px] text-gray-400 font-bold uppercase\" data-kid=\"213\">SDG</span>\n                            <span class=\"font-bold text-[#C9963A] text-sm\" data-kid=\"214\">07</span>\n                        </div>\n                        <div class=\"w-14 h-14 bg-white border border-[#C9963A]/20 flex flex-col items-center justify-center rounded-lg shadow-sm\" data-kid=\"215\">\n                            <span class=\"text-[10px] text-gray-400 font-bold uppercase\" data-kid=\"216\">SDG</span>\n                            <span class=\"font-bold text-[#C9963A] text-sm\" data-kid=\"217\">11</span>\n                        </div>\n                        <div class=\"w-14 h-14 bg-white border border-[#C9963A]/20 flex flex-col items-center justify-center rounded-lg shadow-sm\" data-kid=\"218\">\n                            <span class=\"text-[10px] text-gray-400 font-bold uppercase\" data-kid=\"219\">SDG</span>\n                            <span class=\"font-bold text-[#C9963A] text-sm\" data-kid=\"220\">13</span>\n                        </div>\n                        <div class=\"w-14 h-14 bg-white border border-[#C9963A]/20 flex flex-col items-center justify-center rounded-lg shadow-sm\" data-kid=\"221\">\n                            <span class=\"text-[10px] text-gray-400 font-bold uppercase\" data-kid=\"222\">SDG</span>\n                            <span class=\"font-bold text-[#C9963A] text-sm\" data-kid=\"223\">17</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-white py-20 px-6 border-t border-gray-100\" data-kid=\"224\">\n        <div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mb-16\" data-kid=\"225\">\n            <div class=\"md:col-span-2\" data-kid=\"226\">\n                <div class=\"flex items-center gap-2 mb-6\" data-kid=\"227\">\n                    <div class=\"w-10 h-10 bg-[#1E6B3C] rounded flex items-center justify-center\" data-kid=\"228\">\n                        <i class=\"ri-leaf-line text-white text-lg\" data-kid=\"229\"></i>\n                    </div>\n                    <span class=\"font-bold text-[#0D3D20] uppercase tracking-tighter text-xl\" data-kid=\"230\">Golden preneur</span>\n                </div>\n                <p class=\"text-gray-500 text-sm max-w-sm mb-8 leading-relaxed\" data-kid=\"231\">\n                    Organised by 1 Million Entrepreneurs International Forum (1MEIF) NGO. Empowering green stories and building a sustainable future together.\n                </p>\n                <div class=\"flex gap-4\" data-kid=\"232\">\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-100 rounded-full flex items-center justify-center text-gray-400 hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"233\"><i class=\"ri-facebook-fill\" data-kid=\"234\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-100 rounded-full flex items-center justify-center text-gray-400 hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"235\"><i class=\"ri-instagram-line\" data-kid=\"236\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-100 rounded-full flex items-center justify-center text-gray-400 hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"237\"><i class=\"ri-linkedin-fill\" data-kid=\"238\"></i></a>\n                    <a href=\"https://wa.me/917041151714\" class=\"w-10 h-10 border border-gray-100 rounded-full flex items-center justify-center text-gray-400 hover:bg-[#25D366] hover:text-white transition-all\" data-kid=\"239\"><i class=\"ri-whatsapp-line\" data-kid=\"240\"></i></a>\n                </div>\n            </div>\n            <div data-kid=\"241\">\n                <h4 class=\"font-bold text-sm uppercase tracking-widest text-[#0D3D20] mb-6\" data-kid=\"242\">Quick Links</h4>\n                <ul class=\"space-y-4 text-sm text-gray-500\" data-kid=\"243\">\n                    <li data-kid=\"244\"><a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"245\">About 1MEIF</a></li>\n                    <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"247\">Award Categories</a></li>\n                    <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"249\">Past Winners</a></li>\n                    <li data-kid=\"250\"><a href=\"#\" class=\"hover:text-[#1E6B3C]\" data-kid=\"251\">Gallery</a></li>\n                </ul>\n            </div>\n            <div data-kid=\"252\">\n                <h4 class=\"font-bold text-sm uppercase tracking-widest text-[#0D3D20] mb-6\" data-kid=\"253\">Contact</h4>\n                <ul class=\"space-y-4 text-sm text-gray-500\" data-kid=\"254\">\n                    <li class=\"flex items-start gap-3\" data-kid=\"255\">\n                        <i class=\"ri-mail-line mt-1\" data-kid=\"256\"></i>\n                        <span data-kid=\"257\">hello@goldenpreneur.in</span>\n                    </li>\n                    <li class=\"flex items-start gap-3\" data-kid=\"258\">\n                        <i class=\"ri-phone-line mt-1\" data-kid=\"259\"></i>\n                        <span data-kid=\"260\">+91 70411 51714</span>\n                    </li>\n                </ul>\n            </div>\n        </div>\n        <div class=\"max-w-6xl mx-auto pt-10 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"261\">\n            <p class=\"text-gray-400 text-[9px] md:text-[10px] uppercase tracking-[0.2em] text-center md:text-left font-medium leading-relaxed\" data-kid=\"262\">\n                © 2026 Golden preneur | CSR No.: CSR00106194 | 80G & 12A Certified NGO | आइए, साथ मिलकर एक बेहतर भविष्य का निर्माण करें।\n            </p>\n            <div class=\"flex items-center gap-6 opacity-60\" data-kid=\"263\">\n                <span class=\"text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"264\">Partners</span>\n                <div class=\"h-4 w-px bg-gray-200\" data-kid=\"265\"></div>\n                <span class=\"text-[10px] font-bold text-[#0D3D20]\" data-kid=\"266\">CEED</span>\n                <span class=\"text-[10px] font-bold text-[#0D3D20]\" data-kid=\"267\">VYAPAAR JAGAT</span>\n            </div>\n        </div>\n    </footer>\n</div>\n",
