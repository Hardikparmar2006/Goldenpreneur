      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap');\n\n    .font-serif {\n        font-family: 'Playfair Display', serif;\n    }\n\n    .font-sans {\n        font-family: 'Inter', sans-serif;\n    }\n\n    .gradient-green {\n        background: linear-gradient(135deg, #0D3D20 0%, #1E6B3C 100%);\n    }\n\n    .tier-card {\n        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);\n        display: flex;\n        flex-direction: column;\n        border: 1px solid rgba(0,0,0,0.05);\n    }\n\n    .tier-title-glow {\n        box-shadow: 0 0 40px -10px rgba(201, 150, 58, 0.2);\n    }\n\n    .tier-card:hover {\n        transform: translateY(-12px);\n        box-shadow: 0 40px 60px -15px rgba(13, 61, 32, 0.15);\n    }\n\n    .glass-effect {\n        background: rgba(255, 255, 255, 0.05);\n        backdrop-filter: blur(10px);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    @keyframes float {\n        0% { transform: translateY(0px); }\n        50% { transform: translateY(-10px); }\n        100% { transform: translateY(0px); }\n    }\n\n    .float-anim {\n        animation: float 4s ease-in-out infinite;\n    }\n\n    .partner-logo {\n        background: linear-gradient(to bottom, #f0f0f0, #e0e0e0);\n        border: 1px solid #dcdcdc;\n    }\n</style>\n\n<div class=\"font-sans text-[#1A1A1A] bg-[#F9F5EE] relative min-h-screen\" data-kid=\"1\">\n    \n    <nav class=\"bg-white/90 backdrop-blur-md shadow-sm py-4 px-6 relative z-50\" data-kid=\"2\">\n        <div class=\"max-w-7xl mx-auto flex items-center justify-between\" data-kid=\"3\">\n            <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-10 h-10 bg-[#1E6B3C] rounded-lg flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-[#1E6B3C]/20\" data-kid=\"5\">G</div>\n                <div class=\"flex flex-col\" data-kid=\"6\">\n                    <span class=\"font-serif text-xl font-bold text-[#1E6B3C] leading-none\" data-kid=\"7\">GOLDEN PRENEUR</span>\n                    <span class=\"text-[10px] tracking-[0.3em] uppercase text-[#C9963A] font-bold\" data-kid=\"8\">Awards 2026</span>\n                </div>\n            </div>\n            <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"9\">\n                <a href=\"#\" class=\"font-semibold text-sm uppercase tracking-wider text-[#1A1A1A] hover:text-[#1E6B3C] transition-colors\" data-kid=\"10\">Home</a>\n                <a href=\"#\" class=\"font-semibold text-sm uppercase tracking-wider text-[#1A1A1A] hover:text-[#1E6B3C] transition-colors\" data-kid=\"11\">About</a>\n                <a href=\"#\" class=\"font-semibold text-sm uppercase tracking-wider text-[#1A1A1A] hover:text-[#1E6B3C] transition-colors\" data-kid=\"12\">Awards</a>\n                <a href=\"#\" class=\"font-semibold text-sm uppercase tracking-wider text-[#1E6B3C] border-b-2 border-[#1E6B3C] py-1\" data-kid=\"13\">Sponsors</a>\n                <a href=\"#\" class=\"font-semibold text-sm uppercase tracking-wider text-[#1A1A1A] hover:text-[#1E6B3C] transition-colors\" data-kid=\"14\">Winners</a>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"15\">\n                <button class=\"hidden sm:block px-5 py-2.5 border-2 border-[#1E6B3C] text-[#1E6B3C] font-bold text-sm uppercase tracking-tighter rounded-lg hover:bg-[#1E6B3C]/5 transition-all\" data-kid=\"16\">Get Pass</button>\n                <button class=\"px-5 py-2.5 bg-[#1E6B3C] text-white font-bold text-sm uppercase tracking-tighter rounded-lg hover:bg-[#0D3D20] transition-all shadow-lg shadow-[#1E6B3C]/30\" data-kid=\"17\">Apply for Award</button>\n            </div>\n        </div>\n    </nav>\n\n    \n    <header class=\"gradient-green py-32 px-6 text-white text-center relative overflow-hidden\" data-kid=\"18\">\n        \n        <div class=\"absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none\" data-kid=\"19\">\n            <div class=\"absolute top-10 left-10 w-64 h-64 bg-white rounded-full blur-[100px]\" data-kid=\"20\"></div>\n            <div class=\"absolute bottom-10 right-10 w-96 h-96 bg-[#C9963A] rounded-full blur-[120px]\" data-kid=\"21\"></div>\n        </div>\n        \n        <div class=\"max-w-4xl mx-auto relative z-10\" data-kid=\"22\">\n            <div class=\"inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-[#C9963A] text-xs font-black mb-10 tracking-[0.25em] uppercase\" data-kid=\"23\">\n                <span class=\"w-2 h-2 rounded-full bg-[#C9963A] float-anim\" data-kid=\"24\"></span>\n                Partnership Opportunities 2026\n            </div>\n            <h1 class=\"text-5xl md:text-8xl font-bold font-serif mb-10 leading-[1.1]\" data-kid=\"25\">Be a Part of India's Green Economy Movement</h1>\n            <p class=\"text-xl md:text-2xl text-white/70 mb-14 max-w-2xl mx-auto leading-relaxed font-light\" data-kid=\"26\">Join the 5th edition of India's most comprehensive platform celebrating sustainable entrepreneurship and innovation.</p>\n            <div class=\"flex flex-col sm:flex-row justify-center gap-6\" data-kid=\"27\">\n                <a href=\"#tiers\" class=\"px-12 py-5 bg-[#C9963A] text-white font-bold rounded-xl hover:bg-[#b08332] hover:scale-105 transition-all shadow-2xl shadow-[#C9963A]/40 text-lg uppercase tracking-wider\" data-kid=\"28\">Explore Tiers</a>\n                <a href=\"#contact\" class=\"px-12 py-5 border-2 border-white/30 text-white font-bold rounded-xl hover:bg-white/10 hover:scale-105 transition-all text-lg uppercase tracking-wider backdrop-blur-sm\" data-kid=\"29\">Contact Us</a>\n            </div>\n        </div>\n    </header>\n\n    \n    <section class=\"py-32 px-6 bg-white border-b border-gray-100\" data-kid=\"30\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"31\">\n            <div class=\"flex flex-col lg:flex-row items-end justify-between mb-24 gap-8\" data-kid=\"32\">\n                <div class=\"max-w-2xl\" data-kid=\"33\">\n                    <span class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-xs mb-4 block\" data-kid=\"34\">The Value Proposition</span>\n                    <h2 class=\"text-4xl md:text-6xl font-bold font-serif text-[#1A1A1A] leading-tight\" data-kid=\"35\">Why Partner with Golden preneur?</h2>\n                </div>\n                <div class=\"lg:w-1/3\" data-kid=\"36\">\n                    <p class=\"text-gray-500 text-lg leading-relaxed\" data-kid=\"37\">Position your brand at the center of the sustainability dialogue and connect with the pioneers of India's green future.</p>\n                </div>\n            </div>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12\" data-kid=\"38\">\n                <div class=\"group\" data-kid=\"39\">\n                    <div class=\"w-16 h-16 bg-[#F9F5EE] rounded-3xl flex items-center justify-center text-[#1E6B3C] mb-8 group-hover:bg-[#1E6B3C] group-hover:text-white transition-all duration-500 transform group-hover:rotate-6 shadow-sm\" data-kid=\"40\">\n                        <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"41\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z\" data-kid=\"42\"></path></svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-4 font-serif\" data-kid=\"43\">Brand Visibility</h3>\n                    <p class=\"text-gray-600 leading-relaxed\" data-kid=\"44\">Nationwide media reach through Vyapaar Jagat & 1,000+ green story drive integration across all platforms.</p>\n                </div>\n                <div class=\"group\" data-kid=\"45\">\n                    <div class=\"w-16 h-16 bg-[#F9F5EE] rounded-3xl flex items-center justify-center text-[#1E6B3C] mb-8 group-hover:bg-[#1E6B3C] group-hover:text-white transition-all duration-500 transform group-hover:rotate-6 shadow-sm\" data-kid=\"46\">\n                        <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"47\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z\" data-kid=\"48\"></path></svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-4 font-serif\" data-kid=\"49\">Elite Networking</h3>\n                    <p class=\"text-gray-600 leading-relaxed\" data-kid=\"50\">Direct engagement with 500+ high-profile entrepreneurs, corporate CXOs, and industry policy makers.</p>\n                </div>\n                <div class=\"group\" data-kid=\"51\">\n                    <div class=\"w-16 h-16 bg-[#F9F5EE] rounded-3xl flex items-center justify-center text-[#1E6B3C] mb-8 group-hover:bg-[#1E6B3C] group-hover:text-white transition-all duration-500 transform group-hover:rotate-6 shadow-sm\" data-kid=\"52\">\n                        <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"53\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h1.5a2.5 2.5 0 012.5 2.5v.665M19 10.5a2 2 0 11-4 0 2 2 0 014 0zM12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z\" data-kid=\"54\"></path></svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-4 font-serif\" data-kid=\"55\">ESG Leadership</h3>\n                    <p class=\"text-gray-600 leading-relaxed\" data-kid=\"56\">Demonstrate concrete commitment to UN SDGs and the national vision of Viksit Bharat @2047.</p>\n                </div>\n                <div class=\"group\" data-kid=\"57\">\n                    <div class=\"w-16 h-16 bg-[#F9F5EE] rounded-3xl flex items-center justify-center text-[#1E6B3C] mb-8 group-hover:bg-[#1E6B3C] group-hover:text-white transition-all duration-500 transform group-hover:rotate-6 shadow-sm\" data-kid=\"58\">\n                        <svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"59\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\" data-kid=\"60\"></path></svg>\n                    </div>\n                    <h3 class=\"text-xl font-bold mb-4 font-serif\" data-kid=\"61\">Measurable Impact</h3>\n                    <p class=\"text-gray-600 leading-relaxed\" data-kid=\"62\">Access full attendee insights and high-quality leads from a focused, industry-specific audience.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"tiers\" class=\"py-32 px-6 relative bg-[#F9F5EE]\" data-kid=\"63\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"64\">\n            <div class=\"text-center mb-24\" data-kid=\"65\">\n                <span class=\"text-[#C9963A] font-bold uppercase tracking-[0.3em] text-xs mb-4 block\" data-kid=\"66\">Investment Opportunities</span>\n                <h2 class=\"text-4xl md:text-7xl font-bold font-serif text-[#1A1A1A] mb-6\" data-kid=\"67\">Select Your Impact Level</h2>\n                <div class=\"w-24 h-1.5 bg-[#C9963A] mx-auto rounded-full mb-8\" data-kid=\"68\"></div>\n                <p class=\"text-gray-600 max-w-2xl mx-auto text-lg\" data-kid=\"69\">Strategic partnership tiers designed for organizations that want to lead the change.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\" data-kid=\"70\">\n                \n                <div class=\"tier-card relative bg-white rounded-[2rem] border-2 border-[#C9963A] p-12 shadow-2xl flex flex-col tier-title-glow\" data-kid=\"71\">\n                    <div class=\"absolute top-0 right-10 -translate-y-1/2 bg-[#C9963A] text-white px-8 py-2 rounded-full text-[10px] font-black tracking-widest uppercase shadow-lg shadow-[#C9963A]/30\" data-kid=\"72\">Elite Tier</div>\n                    <div class=\"mb-10\" data-kid=\"73\">\n                        <h3 class=\"text-3xl font-bold text-[#0D3D20] mb-4 font-serif\" data-kid=\"74\">Title Sponsor</h3>\n                        <div class=\"flex items-baseline gap-2 mb-2\" data-kid=\"75\">\n                            <span class=\"text-6xl font-serif font-black text-[#C9963A]\" data-kid=\"76\">₹2L</span>\n                            <span class=\"text-gray-400 font-bold text-sm uppercase\" data-kid=\"77\">Total Investment</span>\n                        </div>\n                        <p class=\"text-xs text-[#1E6B3C] font-bold tracking-widest uppercase\" data-kid=\"78\">Full Naming Rights & Max Exposure</p>\n                    </div>\n                    <div class=\"space-y-5 mb-12 flex-grow\" data-kid=\"79\">\n                        <div class=\"flex items-start gap-4\" data-kid=\"80\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#C9963A]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"81\"><svg class=\"w-3 h-3 text-[#C9963A]\" fill=\"currentColor\" viewBox=\"0 0 20 20\" data-kid=\"82\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\" data-kid=\"83\"></path></svg></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"84\">Event naming rights: Presented by Your Brand</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"85\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#C9963A]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"86\"><i class=\"fas fa-check text-[10px] text-[#C9963A]\" data-kid=\"87\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"88\">Logo on ALL main branding (Digital, Print, Stage)</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"89\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#C9963A]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"90\"><i class=\"fas fa-check text-[10px] text-[#C9963A]\" data-kid=\"91\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"92\">Keynote speaking slot (15 mins)</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"93\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#C9963A]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"94\"><i class=\"fas fa-check text-[10px] text-[#C9963A]\" data-kid=\"95\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"96\">Full access to 500+ attendee data</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"97\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#C9963A]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"98\"><i class=\"fas fa-check text-[10px] text-[#C9963A]\" data-kid=\"99\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"100\">Premium Coffee Table Book page + Story drive</span>\n                        </div>\n                    </div>\n                    <button class=\"w-full py-5 bg-[#0D3D20] text-white font-black rounded-2xl hover:bg-black hover:scale-[1.02] transition-all text-sm uppercase tracking-[0.2em] shadow-xl shadow-[#0D3D20]/20\" data-kid=\"101\">Enquire Now</button>\n                </div>\n\n                \n                <div class=\"tier-card bg-white rounded-[2rem] border border-gray-100 p-12 shadow-xl flex flex-col\" data-kid=\"102\">\n                    <div class=\"mb-10\" data-kid=\"103\">\n                        <h3 class=\"text-3xl font-bold text-[#0D3D20] mb-4 font-serif\" data-kid=\"104\">Powered By</h3>\n                        <div class=\"flex items-baseline gap-2 mb-2\" data-kid=\"105\">\n                            <span class=\"text-6xl font-serif font-black text-[#1E6B3C]\" data-kid=\"106\">₹1L</span>\n                            <span class=\"text-gray-400 font-bold text-sm uppercase\" data-kid=\"107\">Total Investment</span>\n                        </div>\n                        <p class=\"text-xs text-gray-500 font-bold tracking-widest uppercase\" data-kid=\"108\">Premium Co-Branding Presence</p>\n                    </div>\n                    <div class=\"space-y-5 mb-12 flex-grow\" data-kid=\"109\">\n                        <div class=\"flex items-start gap-4\" data-kid=\"110\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#1E6B3C]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"111\"><i class=\"fas fa-check text-[10px] text-[#1E6B3C]\" data-kid=\"112\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"113\">Co-branding on main stage backdrop</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"114\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#1E6B3C]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"115\"><i class=\"fas fa-check text-[10px] text-[#1E6B3C]\" data-kid=\"116\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"117\">Featured speaking slot during panel</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"118\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#1E6B3C]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"119\"><i class=\"fas fa-check text-[10px] text-[#1E6B3C]\" data-kid=\"120\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"121\">Coffee Table Book feature story</span>\n                        </div>\n                        <div class=\"flex items-start gap-4\" data-kid=\"122\">\n                            <div class=\"w-6 h-6 rounded-full bg-[#1E6B3C]/10 flex items-center justify-center shrink-0 mt-0.5\" data-kid=\"123\"><i class=\"fas fa-check text-[10px] text-[#1E6B3C]\" data-kid=\"124\"></i></div>\n                            <span class=\"text-gray-700 font-medium\" data-kid=\"125\">Story integration on VyapaarJagat.com</span>\n                        </div>\n                    </div>\n                    <button class=\"w-full py-5 border-2 border-[#1E6B3C] text-[#1E6B3C] font-black rounded-2xl hover:bg-[#1E6B3C] hover:text-white transition-all text-sm uppercase tracking-[0.2em]\" data-kid=\"126\">Enquire Now</button>\n                </div>\n\n                \n                <div class=\"tier-card bg-white rounded-[2rem] border border-gray-100 p-12 shadow-xl flex flex-col\" data-kid=\"127\">\n                    <div class=\"mb-10\" data-kid=\"128\">\n                        <h3 class=\"text-3xl font-bold text-[#0D3D20] mb-4 font-serif\" data-kid=\"129\">Platinum</h3>\n                        <d