order-[#1E6B3C] text-[#1E6B3C] font-bold hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"208\">Get Pass</button>\n                </div>\n\n                \n                <div class=\"p-8 rounded-3xl border-2 border-[#C9963A] bg-[#0D3D20] text-white relative flex flex-col shadow-[0_30px_60px_-15px_rgba(13,61,32,0.5)] scale-105 z-10 leaf-pattern\" data-kid=\"209\">\n                    <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 px-6 py-2 bg-gradient-to-r from-[#C9963A] to-[#E5B566] text-white text-[10px] font-black uppercase rounded-full shadow-lg\" data-kid=\"210\">Most Popular for Networking</div>\n                    <div class=\"mb-8\" data-kid=\"211\">\n                        <h3 class=\"text-2xl font-serif mb-2\" data-kid=\"212\">Conclave VIP Pass</h3>\n                        <p class=\"text-sm text-white/60\" data-kid=\"213\">The definitive choice for strategic growth.</p>\n                    </div>\n                    <ul class=\"space-y-4 mb-10 flex-grow\" data-kid=\"214\">\n                        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"215\">\n                            <i class=\"fas fa-check text-[#C9963A]\" data-kid=\"216\"></i> Priority Conclave Seating\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"217\">\n                            <i class=\"fas fa-check text-[#C9963A]\" data-kid=\"218\"></i> Roundtable Participation\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"219\">\n                            <i class=\"fas fa-check text-[#C9963A]\" data-kid=\"220\"></i> 5-Course Gala Dinner\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"221\">\n                            <i class=\"fas fa-check text-[#C9963A]\" data-kid=\"222\"></i> VIP Networking Lounge\n                        </li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-xl bg-[#C9963A] text-white font-bold hover:bg-[#b08332] transition-all shadow-lg shadow-[#C9963A]/20\" data-kid=\"223\">Get VIP Pass</button>\n                </div>\n\n                \n                <div class=\"p-8 rounded-3xl border border-gray-100 bg-white hover:border-[#1E6B3C] transition-all flex flex-col shadow-sm card-hover\" data-kid=\"224\">\n                    <div class=\"mb-8\" data-kid=\"225\">\n                        <h3 class=\"text-xl font-bold text-[#0D3D20] mb-2\" data-kid=\"226\">Corporate Table</h3>\n                        <p class=\"text-sm text-gray-500\" data-kid=\"227\">Ideal for teams or branding impact (Seats 8).</p>\n                    </div>\n                    <ul class=\"space-y-4 mb-10 flex-grow\" data-kid=\"228\">\n                        <li class=\"flex items-center gap-3 text-sm text-gray-600\" data-kid=\"229\">\n                            <i class=\"fas fa-check text-[#1E6B3C]\" data-kid=\"230\"></i> Dedicated Reserved Table\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-600\" data-kid=\"231\">\n                            <i class=\"fas fa-check text-[#1E6B3C]\" data-kid=\"232\"></i> Brand Logo on Stage\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-600\" data-kid=\"233\">\n                            <i class=\"fas fa-check text-[#1E6B3C]\" data-kid=\"234\"></i> Coffee Table Book Feature\n                        </li>\n                    </ul>\n                    <button class=\"w-full py-4 rounded-xl border-2 border-[#1E6B3C] text-[#1E6B3C] font-bold hover:bg-[#1E6B3C] hover:text-white transition-all\" data-kid=\"235\">Enquire Now</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#0D3D20] text-white py-20 border-t border-white/5\" data-kid=\"236\">\n        <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"237\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\" data-kid=\"238\">\n                \n                <div class=\"space-y-6\" data-kid=\"239\">\n                    <div class=\"text-2xl font-serif font-black tracking-tighter\" data-kid=\"240\">GREEN<span class=\"text-[#C9963A]\" data-kid=\"241\">PRENEUR</span> <span class=\"text-xs font-sans text-white/30\" data-kid=\"242\">2026</span></div>\n                    <p class=\"text-white/50 text-sm leading-relaxed\" data-kid=\"243\">Entrepreneurs Redefining Sustainability. India's most comprehensive green entrepreneurship platform.</p>\n                    <div class=\"flex gap-4\" data-kid=\"244\">\n                        <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#C9963A] transition-all\" data-kid=\"245\"><i class=\"fab fa-linkedin-in text-sm\" data-kid=\"246\"></i></a>\n                        <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#C9963A] transition-all\" data-kid=\"247\"><i class=\"fab fa-instagram text-sm\" data-kid=\"248\"></i></a>\n                        <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#C9963A] transition-all\" data-kid=\"249\"><i class=\"fab fa-facebook-f text-sm\" data-kid=\"250\"></i></a>\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-6\" data-kid=\"251\">\n                    <h4 class=\"font-bold text-lg\" data-kid=\"252\">Quick Links</h4>\n                    <ul class=\"space-y-3 text-sm text-white/50\" data-kid=\"253\">\n                        <li data-kid=\"254\"><a href=\"#\" class=\"hover:text-[#C9963A] transition-colors\" data-kid=\"255\">About 1MEIF</a></li>\n                        <li data-kid=\"256\"><a href=\"#\" class=\"hover:tex