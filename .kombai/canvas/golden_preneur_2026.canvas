      "html": "\n<div class=\"font-sans text-[#1A1A1A] bg-[#FFFFFF]\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/lucide-static@0.321.0/font/lucide.min.css');\n\n    :root {\n      --primary-green: #1E6B3C;\n      --dark-green: #0D3D20;\n      --accent-gold: #C9963A;\n      --leaf-green: #4CAF50;\n      --cream-white: #F9F5EE;\n    }\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .btn-shadow {\n      box-shadow: 0 4px 14px 0 rgba(30, 107, 60, 0.3);\n    }\n    \n    .card-hover:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.1);\n    }\n  </style>\n\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-100\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--primary-green)] rounded-lg flex items-center justify-center\" data-kid=\"5\">\n          <i class=\"lucide-leaf text-white text-xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-serif text-xl font-bold text-[var(--dark-green)] tracking-tight\" data-kid=\"7\">GOLDEN PRENEUR <span class=\"text-[var(--accent-gold)]\" data-kid=\"8\">2026</span></span>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"9\">\n        <a href=\"/\" class=\"text-sm font-medium hover:text-[var(--primary-green)] transition-colors\" data-kid=\"10\">HOME</a>\n        <a href=\"/about\" class=\"text-sm font-medium hover:text-[var(--primary-green)] transition-colors\" data-kid=\"11\">ABOUT</a>\n        <a href=\"/awards\" class=\"text-sm font-medium hover:text-[var(--primary-green)] transition-colors\" data-kid=\"12\">AWARDS 2026</a>\n        <a href=\"/sponsors\" class=\"text-sm font-medium hover:text-[var(--primary-green)] transition-colors\" data-kid=\"13\">SPONSORS</a>\n        <a href=\"/winners\" class=\"text-sm font-medium hover:text-[var(--primary-green)] transition-colors\" data-kid=\"14\">WINNERS</a>\n        <a href=\"/contact\" class=\"text-sm font-bold text-[var(--primary-green)]\" data-kid=\"15\">CONTACT</a>\n      </div>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"16\">\n        <a href=\"/awards/apply\" class=\"hidden md:block bg-[var(--primary-green)] text-white px-5 py-2.5 rounded-lg text-sm font-semibold btn-shadow hover:opacity-90 transition-all\" data-kid=\"17\">Apply for Award</a>\n        <button class=\"lg:hidden text-gray-700\" data-kid=\"18\">\n          <i class=\"lucide-menu text-2xl\" data-kid=\"19\"></i>\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative h-[400px] flex items-center justify-center overflow-hidden bg-[var(--dark-green)]\" data-kid=\"20\">\n    <div class=\"absolute inset-0 opacity-10\" data-kid=\"21\">\n      <svg width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"22\">\n        <defs data-kid=\"23\">\n          <pattern id=\"leaf-pattern\" x=\"0\" y=\"0\" width=\"100\" height=\"100\" patternUnits=\"userSpaceOnUse\" data-kid=\"24\">\n            <path d=\"M50 0 C60 20 80 30 100 35 C80 40 60 50 50 100 C40 50 20 40 0 35 C20 30 40 20 50 0\" fill=\"currentColor\" data-kid=\"25\"></path>\n          </pattern>\n        </defs>\n        <rect width=\"100%\" height=\"100%\" fill=\"url(#leaf-pattern)\" data-kid=\"26\"></rect>\n      </svg>\n    </div>\n    <div class=\"relative z-10 text-center px-6\" data-kid=\"27\">\n      <span class=\"text-[var(--accent-gold)] font-bold tracking-widest uppercase text-sm mb-4 block\" data-kid=\"28\">Connect with our leadership</span>\n      <h1 class=\"font-serif text-5xl md:text-6xl text-white font-bold mb-6\" data-kid=\"29\">Let's Build a Greener <br data-kid=\"30\">Future Together</h1>\n      <p class=\"text-white/80 text-lg max-w-2xl mx-auto\" data-kid=\"31\">Have a query? Our team is ready to assist you in your journey towards sustainable excellence.</p>\n    </div>\n  </section>\n\n  \n  <section class=\"relative z-20 -mt-20 px-6\" data-kid=\"32\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"33\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"34\">\n        \n        <div class=\"bg-white rounded-3xl p-8 shadow-xl border border-gray-100 flex flex-col items-center text-center card-hover transition-all duration-500 group\" data-kid=\"35\">\n          <div class=\"relative mb-6\" data-kid=\"36\">\n            <div class=\"w-32 h-32 rounded-full overflow-hidden border-4 border-[var(--cream-white)] shadow-md\" data-kid=\"37\">\n              <img src=\"https://i.pravatar.cc/150?u=pravin\" alt=\"Dr. Pravin Parmar\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"38\">\n            </div>\n            <div class=\"absolute bottom-1 right-1 w-8 h-8 bg-[var(--primary-green)] rounded-full flex items-center justify-center border-2 border-white\" data-kid=\"39\">\n              <i class=\"lucide-user-check text-white text-xs\" data-kid=\"40\"></i>\n            </div>\n          </div>\n          <h3 class=\"font-serif text-2xl font-bold text-[var(--dark-green)] mb-1\" data-kid=\"41\">Dr. Pravin Parmar</h3>\n          <p class=\"text-[var(--accent-gold)] font-semibold uppercase tracking-wider text-xs mb-4\" data-kid=\"42\">Founder - 1MEIF</p>\n          <p class=\"text-gray-500 mb-8 max-w-sm text-sm leading-relaxed\" data-kid=\"43\">\"Golden preneur is more than an event; it's a commitment to India's sustainable growth. Join our mission.\"</p>\n          <div class=\"flex flex-col gap-3 w-full\" data-kid=\"44\">\n            <a href=\"mailto:hello@goldenpreneur.in\" class=\"flex items-center justify-center gap-2 py-3 px-6 rounded-xl border-2 border-gray-100 text-gray-700 font-semibold group-hover:border-[var(--primary-green)] group-hover:bg-[var(--primary-green)]/5 transition-all\" data-kid=\"45\">\n              <i class=\"lucide-mail text-lg text-[var(--primary-green)]\" data-kid=\"46\"></i> hello@goldenpreneur.in\n            </a>\n          </div>\n        </div>\n\n        \n        <div class=\"bg-white rounded-3xl p-8 shadow-xl border border-gray-100 flex flex-col items-center text-center card-hover transition-all duration-500 group\" data-kid=\"47\">\n          <div class=\"relative mb-6\" data-kid=\"48\">\n            <div class=\"w-32 h-32 rounded-full overflow-hidden border-4 border-[var(--cream-white)] shadow-md\" data-kid=\"49\">\n              <img src=\"https://i.pravatar.cc/150?u=vishal\" alt=\"Vishal Parmar\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"50\">\n            </div>\n            <div class=\"absolute bottom-1 right-1 w-8 h-8 bg-[#25D366] rounded-full flex items-center justify-center border-2 border-white\" data-kid=\"51\">\n              <i class=\"lucide-message-circle text-white text-xs\" data-kid=\"52\"></i>\n            </div>\n          </div>\n          <h3 class=\"font-serif text-2xl font-bold text-[var(--dark-green)] mb-1\" data-kid=\"53\">Vishal Parmar</h3>\n          <p class=\"text-[var(--accent-gold)] font-semibold uppercase tracking-wider text-xs mb-4\" data-kid=\"54\">Director - Peers Global</p>\n          <p class=\"text-gray-500 mb-8 max-w-sm text-sm leading-relaxed\" data-kid=\"55\">For Sponsorships, Stalls, and Event Partnerships, connect directly via phone or WhatsApp.</p>\n          <div class=\"grid grid-cols-2 gap-3 w-full\" data-kid=\"56\">\n            <a href=\"tel:+917041151714\" class=\"flex items-center justify-center gap-2 py-3 px-4 rounded-xl bg-[var(--primary-green)] text-white font-semibold shadow-md hover:bg-[var(--dark-green)] transition-all\" data-kid=\"57\">\n              <i class=\"lucide-phone text-lg\" data-kid=\"58\"></i> Call\n            </a>\n            <a href=\"https://wa.me/917041151714\" class=\"flex items-center justify-center gap-2 py-3 px-4 rounded-xl bg-[#25D366] text-white font-semibold shadow-md hover:opacity-90 transition-all\" data-kid=\"59\">\n              <i class=\"lucide-message-circle text-lg\" data-kid=\"60\"></i> WhatsApp\n            </a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 px-6\" data-kid=\"61\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"62\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 items-start\" data-kid=\"63\">\n        \n        <div class=\"lg:col-span-7 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-2xl shadow-green-900/5\" data-kid=\"64\">\n          <h2 class=\"font-serif text-3xl font-bold text-[var(--dark-green)] mb-2\" data-kid=\"65\">Send a Message</h2>\n          <p class=\"text-gray-500 mb-10\" data-kid=\"66\">We usually respond within 24 hours.</p>\n          \n          <form class=\"space-y-6\" data-kid=\"67\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"68\">\n              <div class=\"space-y-2\" data-kid=\"69\">\n                <label class=\"text-xs font-bold uppercase tracking-widest text-gray-500\" data-kid=\"70\">Your Name</label>\n                <input type=\"text\" placeholder=\"Full Name\" class=\"w-full bg-white border border-gray-200 rounded-xl px-4 py-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary-green)]/20 focus:border-[var(--primary-green)] transition-all shadow-sm\" data-kid=\"71\">\n              </div>\n              <div class=\"space-y-2\" data-kid=\"72\">\n                <label class=\"text-xs font-bold uppercase tracking-widest text-gray-500\" data-kid=\"73\">Phone Number</label>\n                <input type=\"tel\" placeholder=\"+91\" class=\"w-full bg-white border border-gray-200 rounded-xl px-4 py-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary-green)]/20 focus:border-[var(--primary-green)] transition-all shadow-sm\" data-kid=\"74\">\n              </div>\n            </div>\n            \n            <div class=\"space-y-2\" data-kid=\"75\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-gray-500\" data-kid=\"76\">Email Address</label>\n              <input type=\"email\" placeholder=\"email@example.com\" class=\"w-full bg-white border border-gray-200 rounded-xl px-4 py-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary-green)]/20 focus:border-[var(--primary-green)] transition-all shadow-sm\" data-kid=\"77\">\n            </div>\n\n            <div class=\"space-y-2\" data-kid=\"78\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-gray-500\" data-kid=\"79\">I'm Interested In</label>\n              <div class=\"relative\" data-kid=\"80\">\n                <select class=\"w-full bg-white border border-gray-200 rounded-xl px-4 py-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary-green)]/20 focus:border-[var(--primary-green)] transition-all appearance-none cursor-pointer shadow-sm\" data-kid=\"81\">\n                  <option value=\"Awards\" data-kid=\"82\">Award Nomination</option>\n                  <option value=\"Sponsorship\" data-kid=\"83\">Sponsorship Opportunity</option>\n                  <option value=\"Book\" data-kid=\"84\">Coffee Table Book Feature</option>\n                  <option value=\"Exhibition\" data-kid=\"85\">Exhibition Stall</option>\n                  <option value=\"Speaking\" data-kid=\"86\">Speaking Slot</option>\n                </select>\n                <div class=\"absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none\" data-kid=\"87\">\n                  <i class=\"lucide-chevron-down text-gray-400\" data-kid=\"88\"></i>\n                </div>\n              </div>\n            </div>\n\n            <div class=\"space-y-2\" data-kid=\"89\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-gray-500\" data-kid=\"90\">Message</label>\n              <textarea rows=\"5\" placeholder=\"Tell us about your green initiative...\" class=\"w-full bg-white border border-gray-200 rounded-xl px-4 py-4 text-gray-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary-green)]/20 focus:border-[var(--primary-green)] transition-all resize-none shadow-sm\" data-kid=\"91\"></textarea>\n            </div>\n\n            <button type=\"submit\" class=\"w-full bg-gradient-to-r from-[var(--primary-green)] to-[var(--dark-green)] text-white font-bold py-5 rounded-xl shadow-lg shadow-green-900/20 hover:scale-[1.01] active:scale-[0.99] transition-all flex items-center justify-center gap-3 group\" data-kid=\"92\">\n              Submit Enquiry \n              <i class=\"lucide-send text-lg transition-transform group-hover:translate-x-1\" data-kid=\"93\"></i>\n            </button>\n          </form>\n        </div>\n\n        \n        <div class=\"lg:col-span-5 space-y-8\" data-kid=\"94\">\n          <div class=\"bg-[var(--cream-white)]/50 rounded-3xl p-8 border border-gray-100\" data-kid=\"95\">\n            <h4 class=\"font-serif text-2xl font-bold text-[var(--dark-green)] mb-8\" data-kid=\"96\">Contact Information</h4>\n            <div class=\"space-y-8\" data-kid=\"97\">\n              <div class=\"flex gap-6 group\" data-kid=\"98\">\n                <div class=\"w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center shrink-0 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-300\" data-kid=\"99\">\n                  <i class=\"lucide-map-pin text-xl text-[var(--primary-green)] group-hover:text-white\" data-kid=\"100\"></i>\n                </div>\n                <div data-kid=\"101\">\n                  <h5 class=\"font-bold text-gray-900 text-lg\" data-kid=\"102\">Our Registered Office</h5>\n                  <p class=\"text-gray-600 leading-relaxed text-sm\" data-kid=\"103\">1 Million Entrepreneurs International Forum,<br data-kid=\"104\">Ahmedabad, Gujarat, India</p>\n                </div>\n              </div>\n              \n              <div class=\"flex gap-6 group\" data-kid=\"105\">\n                <div class=\"w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center shrink-0 group-hover:bg-[var(--primary-green)] group-hover:text-white transition-all duration-300\" data-kid=\"106\">\n                  <i class=\"lucide-calendar text-xl text-[var(--primary-green)] group-hover:text-white\" data-kid=\"107\"></i>\n                </div>\n                <div data-kid=\"108\">\n                  <h5 class=\"font-bold text-gray-900 text-lg\" data-kid=\"109\">Golden preneur 2026 Venue</h5>\n                  <p class=\"text-gray-600 leading-relaxed text-sm\" data-kid=\"110\">Renaissance by Marriott Ahmedabad<br data-kid=\"111\">Thursday, 25th June 2026</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"p-8 bg-gradient-to-br from-[var(--dark-green)] to-[#062413] rounded-3xl text-white relative overflow-hidden shadow-2xl\" data-kid=\"112\">\n            <div class=\"absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full -mr-20 -mt-20 blur-2xl\" data-kid=\"113\"></div>\n            <div class=\"relative z-10\" data-kid=\"114\">\n              <div class=\"flex items-center justify-between mb-8\" data-kid=\"115\">\n                <h4 class=\"font-bold text-xl\" data-kid=\"116\">NGO Credentials</h4>\n                <div class=\"px-3 py-1 bg-white/10 rounded-full border border-white/10\" data-kid=\"117\">\n                  <span class=\"text-[10px] font-bold tracking-widest text-[var(--accent-gold)]\" data-kid=\"118\">VERIFIED</span>\n                </div>\n              </div>\n              <div class=\"grid grid-cols-2 gap-x-8 gap-y-6\" data-kid=\"11