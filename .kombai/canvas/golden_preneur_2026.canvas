      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n\n  :root {\n    --primary-green: #1E6B3C;\n    --dark-green: #0D3D20;\n    --accent-gold: #C9963A;\n    --leaf-green: #4CAF50;\n    --cream: #F9F5EE;\n    --dark-text: #1A1A1A;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: var(--dark-text);\n    background-color: white;\n  }\n\n  h1, h2, h3 {\n    font-family: 'Playfair Display', serif;\n  }\n\n  .accordion-item[open] summary svg {\n    transform: rotate(180deg);\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #E5E7EB;\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"min-h-screen bg-white\" data-kid=\"1\">\n  \n  <nav class=\"relative z-50 bg-white border-b border-gray-100 shadow-sm px-6 py-4\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--primary-green)] rounded-lg flex items-center justify-center text-white font-bold text-xl italic\" data-kid=\"5\">G</div>\n        <span class=\"font-bold text-xl tracking-tight text-[var(--dark-green)] hidden md:block\" data-kid=\"6\">GOLDEN PRENEUR</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 font-medium text-sm\" data-kid=\"7\">\n        <a href=\"#\" class=\"hover:text-[var(--primary-green)]\" data-kid=\"8\">Home</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary-green)]\" data-kid=\"9\">About</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary-green)]\" data-kid=\"10\">Awards 2026</a>\n        <a href=\"#\" class=\"text-[var(--primary-green)] font-semibold border-b-2 border-[var(--primary-green)]\" data-kid=\"11\">FAQs</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary-green)]\" data-kid=\"12\">Contact</a>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"13\">\n        <button class=\"hidden lg:block border-2 border-[var(--primary-green)] text-[var(--primary-green)] px-5 py-2 rounded-lg font-semibold text-sm\" data-kid=\"14\">Get Pass</button>\n        <button class=\"bg-[var(--primary-green)] text-white px-5 py-2 rounded-lg font-semibold text-sm flex items-center gap-2\" data-kid=\"15\">\n          <span data-kid=\"16\">Apply Now</span>\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf\" data-kid=\"17\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\" data-kid=\"18\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C10.9 14.4 12 13.8 14 11.3c1 2 2 4.2 2 8 0 5.5-4.5 10-10 10\" data-kid=\"19\"></path></svg>\n        </button>\n        <button class=\"md:hidden text-[var(--dark-green)]\" data-kid=\"20\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" data-kid=\"21\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\" data-kid=\"22\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\" data-kid=\"23\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\" data-kid=\"24\"></line></svg>\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <header class=\"relative bg-[var(--dark-green)] py-24 px-6 overflow-hidden\" data-kid=\"25\">\n    <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"26\">\n      <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"27\">\n        <path d=\"M0 100 C 20 0 50 0 100 100\" fill=\"none\" stroke=\"white\" stroke-width=\"0.5\" data-kid=\"28\"></path>\n        <path d=\"M0 80 C 30 20 60 20 100 80\" fill=\"none\" stroke=\"white\" stroke-width=\"0.5\" data-kid=\"29\"></path>\n      </svg>\n    </div>\n    <div class=\"max-w-4xl mx-auto text-center relative z-10\" data-kid=\"30\">\n      <div class=\"inline-block bg-[var(--accent-gold)] text-white px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"31\">Support Center</div>\n      <h1 class=\"text-white text-4xl md:text-6xl font-bold mb-6\" data-kid=\"32\">How can we help you?</h1>\n      <p class=\"text-white/70 text-lg md:text-xl font-light mb-10 max-w-2xl mx-auto\" data-kid=\"33\">\n        Everything you need to know about India's most comprehensive green entrepreneurship platform.\n      </p>\n      \n      \n      <div class=\"relative max-w-2xl mx-auto\" data-kid=\"34\">\n        <div class=\"absolute inset-y-0 left-5 flex items-center pointer-events-none text-gray-400\" data-kid=\"35\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-search\" data-kid=\"36\"><circle cx=\"11\" cy=\"11\" r=\"8\" data-kid=\"37\"></circle><path d=\"m21 21-4.3-4.3\" data-kid=\"38\"></path></svg>\n        </div>\n        <input type=\"text\" placeholder=\"Search for questions like 'nomination fee', 'event date'...\" class=\"w-full bg-white text-black py-5 pl-14 pr-32 rounded-2xl shadow-2xl focus:outline-none focus:ring-2 focus:ring-[var(--accent-gold)] font-medium\" data-kid=\"39\">\n        <button class=\"absolute right-3 top-3 bottom-3 bg-[var(--primary-green)] text-white px-6 rounded-xl font-bold hover:bg-opacity-90 transition-all hidden sm:block\" data-kid=\"40\">Search</button>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"py-20 px-6 max-w-7xl mx-auto relative bg-gradient-to-b from-white via-[#F9F5EE]/30 to-white\" data-kid=\"41\">\n    <div class=\"grid lg:grid-cols-12 gap-12\" data-kid=\"42\">\n      \n      <aside class=\"lg:col-span-3\" data-kid=\"43\">\n        <div class=\"relative space-y-2\" data-kid=\"44\">\n          <h3 class=\"text-[var(--dark-green)] text-xl font-bold mb-6 font-['Inter'] px-4\" data-kid=\"45\">Categories</h3>\n          <nav class=\"flex lg:flex-col gap-2 overflow-x-auto pb-4 lg:pb-0 scrollbar-hide lg:border-r lg:border-gray-100 pr-6\" data-kid=\"46\">\n            <a href=\"#general\" class=\"flex items-center gap-3 px-6 py-4 rounded-xl bg-[var(--cream)] text-[var(--primary-green)] font-bold transition-all border-2 border-[var(--primary-green)] border-opacity-10 whitespace-nowrap min-w-max lg:min-w-0 min-h-[48px]\" data-kid=\"47\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-info\" data-kid=\"48\"><circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"49\"></circle><path d=\"M12 16v-4\" data-kid=\"50\"></path><path d=\"M12 8h.01\" data-kid=\"51\"></path></svg>\n              General\n            </a>\n            <a href=\"#awards\" class=\"flex items-center gap-3 px-6 py-4 rounded-xl text-gray-500 hover:bg-gray-50 font-semibold transition-all whitespace-nowrap min-w-max lg:min-w-0 min-h-[48px]\" data-kid=\"52\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trophy\" data-kid=\"53\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\" data-kid=\"54\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\" data-kid=\"55\"></path><path d=\"M4 22h16\" data-kid=\"56\"></path><path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\" data-kid=\"57\"></path><path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\" data-kid=\"58\"></path><path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\" data-kid=\"59\"></path></svg>\n              Awards\n            </a>\n            <a href=\"#event\" class=\"flex items-center gap-3 px-6 py-4 rounded-xl text-gray-500 hover:bg-gray-50 font-semibold transition-all whitespace-nowrap min-w-max lg:min-w-0 min-h-[48px]\" data-kid=\"60\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar\" data-kid=\"61\"><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\" ry=\"2\" data-kid=\"62\"></rect><line x1=\"16\" x2=\"16\" y1=\"2\" y2=\"6\" data-kid=\"63\"></line><line x1=\"8\" x2=\"8\" y1=\"2\" y2=\"6\" data-kid=\"64\"></line><line x1=\"3\" x2=\"21\" y1=\"10\" y2=\"10\" data-kid=\"65\"></line></svg>\n              Event\n            </a>\n            <a href=\"#sponsorship\" class=\"flex items-center gap-3 px-6 py-4 rounded-xl text-gray-500 hover:bg-gray-50 font-semibold transition-all whitespace-nowrap min-w-max lg:min-w-0 min-h-[48px]\" data-kid=\"66\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-handshake\" data-kid=\"67\"><path d=\"m11 17 2 2 6-6\" data-kid=\"68\"></path><path d=\"m18 14 1.5 1.5a1.5 1.5 0 1 0 2.12-2.12L19.5 11.25\" data-kid=\"69\"></path><path d=\"m15 11 1.5 1.5\" data-kid=\"70\"></path><path d=\"M11 6.3c.7-.6 1.4-1.3 2.1-1.3 2.1 0 3.8 1.7 3.8 3.8 0 .7-.1 1.4-.4 2\" data-kid=\"71\"></path><path d=\"M21 21v-3c0-2.2-1.8-4-4-4H7c-2.2 0-4 1.8-4 4v3\" data-kid=\"72\"></path></svg>\n              Sponsorship\n            </a>\n            <a href=\"#coffee-table-book\" class=\"flex items-center gap-3 px-6 py-4 rounded-xl text-gray-500 hover:bg-gray-50 font-semibold transition-all whitespace-nowrap min-w-max lg:min-w-0 min-h-[48px]\" data-kid=\"73\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open\" data-kid=\"74\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\" data-kid=\"75\"></path><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\" data-kid=\"76\"></path></svg>\n              Coffee Table Book\n            </a>\n          </nav>\n        </div>\n      </aside>\n\n      \n      <div class=\"lg:col-span-9 space-y-16\" data-kid=\"77\">\n        \n        <section id=\"general\" class=\"scroll-mt-24\" data-kid=\"78\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"79\">\n            <div class=\"w-12 h-12 bg-[var(--primary-green)] text-white rounded-2xl flex items-center justify-center shadow-lg\" data-kid=\"80\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-info\" data-kid=\"81\"><circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"82\"></circle><path d=\"M12 16v-4\" data-kid=\"83\"></path><path d=\"M12 8h.01\" data-kid=\"84\"></path></svg>\n            </div>\n            <h2 class=\"text-3xl font-bold text-[var(--dark-green)] font-['Inter']\" data-kid=\"85\">General</h2>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"86\">\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"87\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"88\">\n                <span data-kid=\"89\">What is Golden preneur?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"90\"><path d=\"m6 9 6 6 6-6\" data-kid=\"91\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"92\">\n                Golden preneur is India's most comprehensive green entrepreneurship platform. It is a structured, high-impact annual event now in its 5th Year (2026). The movement celebrates and supports entrepreneurs redefining sustainability across 150+ sectors.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"93\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"94\">\n                <span data-kid=\"95\">Who is the organiser?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"96\"><path d=\"m6 9 6 6 6-6\" data-kid=\"97\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"98\">\n                Golden preneur is organised by **1 Million Entrepreneurs International Forum (1MEIF)**, a Section 8 NGO, and powered by **VyapaarJagat.com**. It's founded by Dr. Pravin Parmar.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"99\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"100\">\n                <span data-kid=\"101\">What is 1MEIF?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"102\"><path d=\"m6 9 6 6 6-6\" data-kid=\"103\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"104\">\n                1 Million Entrepreneurs International Forum is a Section 8 Company (NGO) with 80G & 12A certification. They are CSR & Darpan certified, focusing on empowering entrepreneurs across India.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"105\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"106\">\n                <span data-kid=\"107\">What is CEED?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"108\"><path d=\"m6 9 6 6 6-6\" data-kid=\"109\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"110\">\n                CEED (Culinary Education & Enterprise Development Association) is our Association Partner, founded by Shri Anil Mulchandani and IFEA Founders. They bring expertise in sustainable growth and industry collaboration.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"111\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"112\">\n                <span data-kid=\"113\">What is VyapaarJagat and why is my story published there?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"114\"><path d=\"m6 9 6 6 6-6\" data-kid=\"115\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"116\">\n                VyapaarJagat.com is one of India's leading platforms for entrepreneur stories. Publishing your story here provides you with national visibility, 3rd party credibility, and a digital footprint that helps in SEO and business networking.\n              </div>\n            </details>\n          </div>\n        </section>\n\n        \n        <section id=\"awards\" class=\"scroll-mt-24\" data-kid=\"117\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"118\">\n            <div class=\"w-12 h-12 bg-[var(--accent-gold)] text-white rounded-2xl flex items-center justify-center shadow-lg\" data-kid=\"119\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trophy\" data-kid=\"120\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\" data-kid=\"121\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\" data-kid=\"122\"></path><path d=\"M4 22h16\" data-kid=\"123\"></path><path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\" data-kid=\"124\"></path><path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\" data-kid=\"125\"></path><path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\" data-kid=\"126\"></path></svg>\n            </div>\n            <h2 class=\"text-3xl font-bold text-[var(--dark-green)] font-['Inter']\" data-kid=\"127\">Awards & Nominations</h2>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"128\">\n            <details class=\"accordion-item group border-2 border-[var(--accent-gold)] border-opacity-30 rounded-2xl bg-gradient-to-br from-[var(--cream)] to-white shadow-lg overflow-hidden ring-4 ring-[var(--accent-gold)] ring-opacity-5\" open data-kid=\"129\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"130\">\n                <div class=\"flex items-center gap-3\" data-kid=\"131\">\n                  <span class=\"bg-[var(--accent-gold)] text-white text-[10px] px-2 py-0.5 rounded-full uppercase tracking-tighter\" data-kid=\"132\">Crucial</span>\n                  <span data-kid=\"133\">Honorary vs Rated Awards?</span>\n                </div>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--accent-gold)] transition-transform duration-300\" data-kid=\"134\"><path d=\"m6 9 6 6 6-6\" data-kid=\"135\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-700 leading-relaxed border-t border-[var(--accent-gold)] border-opacity-10 pt-4\" data-kid=\"136\">\n                <div class=\"grid sm:grid-cols-2 gap-6\" data-kid=\"137\">\n                  <div class=\"bg-white/50 p-4 rounded-xl border border-gray-100\" data-kid=\"138\">\n                    <h4 class=\"font-bold text-[var(--primary-green)] mb-2 flex items-center gap-2\" data-kid=\"139\">\n                      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award\" data-kid=\"140\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\" data-kid=\"141\"></path><circle cx=\"12\" cy=\"8\" r=\"6\" data-kid=\"142\"></circle></svg>\n                      Honorary Awards\n                    </h4>\n                    <p class=\"text-sm\" data-kid=\"143\">100% Jury evaluated. **FREE** to nominate. For exceptional lifetime or sector contributions.</p>\n                  </div>\n                  <div class=\"bg-[var(--accent-gold)] bg-opacity-5 p-4 rounded-xl border border-[var(--accent-gold)] border-opacity-20\" data-kid=\"144\">\n                    <h4 class=\"font-bold text-[var(--accent-gold)] mb-2 flex items-center gap-2\" data-kid=\"145\">\n                      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trending-up\" data-kid=\"146\"><polyline points=\"22 7 13.5 15.5 8.5 10.5 2 17\" data-kid=\"147\"></polyline><polyline points=\"16 7 22 7 22 13\" data-kid=\"148\"></polyline></svg>\n                      Rated Challenge\n                    </h4>\n                    <p class=\"text-sm\" data-kid=\"149\">75% Jury + 25% Public Voting. Nominal fee (₹2k-₹5k) for premium marketing & voting links.</p>\n                  </div>\n                </div>\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"150\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"151\">\n                <span data-kid=\"152\">Is nomination really free?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"153\"><path d=\"m6 9 6 6 6-6\" data-kid=\"154\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"155\">\n                **YES!** Nomination is always FREE for the Honorary track. We believe every green effort deserves a chance to be seen. Nominal charges only apply if you choose the Rated Challenge track for premium benefits and public voting features.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"156\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"157\">\n                <span data-kid=\"158\">What are the award categories?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"159\"><path d=\"m6 9 6 6 6-6\" data-kid=\"160\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"161\">\n                We have 35+ main categories including Eco-Friendly Product, Sustainable Construction, Renewable Energy, Waste Management, and MSME Excellence Awards. A total of 148+ sub-sectors are covered.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"162\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"163\">\n                <span data-kid=\"164\">Who can apply?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"165\"><path d=\"m6 9 6 6 6-6\" data-kid=\"166\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"167\">\n                Any entrepreneur, startup, MSME, NGO, or professional working in sustainability-focused sectors (150+ categories) can apply. This includes renewable energy, waste management, organic farming, green building, and more.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"168\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"169\">\n                <span data-kid=\"170\">What does a winner receive?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"171\"><path d=\"m6 9 6 6 6-6\" data-kid=\"172\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"173\">\n                Winners receive a prestigious Trophy, Certificate of Excellence, stage felicitation at a 5-star venue, national media coverage, inclusion in the Coffee Table Book, and a full pictorial story on VyapaarJagat.com.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"174\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"175\">\n                <span data-kid=\"176\">How does public voting work?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"177\"><path d=\"m6 9 6 6 6-6\" data-kid=\"178\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"179\">\n                For the Rated Challenge, once nominated, you receive a personalised voting link and social media creatives. Your network can vote for you online. This constitutes 25% of your final score, with the remaining 75% coming from our expert Jury.\n              </div>\n            </details>\n          </div>\n        </section>\n\n        \n        <section id=\"event\" class=\"scroll-mt-24\" data-kid=\"180\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"181\">\n            <div class=\"w-12 h-12 bg-[var(--primary-green)] text-white rounded-2xl flex items-center justify-center shadow-lg\" data-kid=\"182\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar\" data-kid=\"183\"><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\" ry=\"2\" data-kid=\"184\"></rect><line x1=\"16\" x2=\"16\" y1=\"2\" y2=\"6\" data-kid=\"185\"></line><line x1=\"8\" x2=\"8\" y1=\"2\" y2=\"6\" data-kid=\"186\"></line><line x1=\"3\" x2=\"21\" y1=\"10\" y2=\"10\" data-kid=\"187\"></line></svg>\n            </div>\n            <h2 class=\"text-3xl font-bold text-[var(--dark-green)] font-['Inter']\" data-kid=\"188\">Event Details</h2>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"189\">\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"190\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"191\">\n                <span data-kid=\"192\">When is the event?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"193\"><path d=\"m6 9 6 6 6-6\" data-kid=\"194\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"195\">\n                The Golden preneur 2026 Mega Event will take place on **Thursday, 25th June 2026**, from 2:00 PM to 9:30 PM.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"196\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"197\">\n                <span data-kid=\"198\">Where is the event?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"199\"><path d=\"m6 9 6 6 6-6\" data-kid=\"200\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"201\">\n                The venue is the prestigious **Renaissance by Marriott Ahmedabad Hotel**, Gujarat, India.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"202\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"203\">\n                <span data-kid=\"204\">How do I register as a delegate?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"205\"><path d=\"m6 9 6 6 6-6\" data-kid=\"206\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"207\">\n                You can register through our \"Get Pass\" button on the website. Delegate passes include access to panel discussions, networking sessions, award ceremony, and gala dinner.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"208\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"209\">\n                <span data-kid=\"210\">Can I exhibit at the event?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"211\"><path d=\"m6 9 6 6 6-6\" data-kid=\"212\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"213\">\n                Yes! We have 25+ exhibition stalls available. We offer two sizes: Standard (6x6 ft) and Premium (10x10 ft). Please contact Vishal Parmar (+91 70411 51714) for pricing and booking.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"214\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"215\">\n                <span data-kid=\"216\">Can I speak or lead a masterclass?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"217\"><path d=\"m6 9 6 6 6-6\" data-kid=\"218\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"219\">\n                We are always looking for expert speakers in the green economy. You can apply through our \"Speakers\" page. Selection is based on expertise, impact, and relevance to our 2026 theme: \"Sustainability in Viksit Bharat\".\n              </div>\n            </details>\n          </div>\n        </section>\n\n        \n        <section id=\"sponsorship\" class=\"scroll-mt-24\" data-kid=\"220\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"221\">\n            <div class=\"w-12 h-12 bg-gray-100 text-[var(--primary-green)] rounded-2xl flex items-center justify-center shadow-lg border border-gray-200\" data-kid=\"222\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-handshake\" data-kid=\"223\"><path d=\"m11 17 2 2 6-6\" data-kid=\"224\"></path><path d=\"m18 14 1.5 1.5a1.5 1.5 0 1 0 2.12-2.12L19.5 11.25\" data-kid=\"225\"></path><path d=\"m15 11 1.5 1.5\" data-kid=\"226\"></path><path d=\"M11 6.3c.7-.6 1.4-1.3 2.1-1.3 2.1 0 3.8 1.7 3.8 3.8 0 .7-.1 1.4-.4 2\" data-kid=\"227\"></path><path d=\"M21 21v-3c0-2.2-1.8-4-4-4H7c-2.2 0-4 1.8-4 4v3\" data-kid=\"228\"></path></svg>\n            </div>\n            <h2 class=\"text-3xl font-bold text-[var(--dark-green)] font-['Inter']\" data-kid=\"229\">Sponsorship</h2>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"230\">\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"231\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"232\">\n                <span data-kid=\"233\">How can I become a sponsor?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"234\"><path d=\"m6 9 6 6 6-6\" data-kid=\"235\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"236\">\n                We offer several tiers from ₹10,000 (Category Sponsor) to ₹2,00,000 (Title Sponsor). Benefits include naming rights, stage branding, attendee data, speaking slots, and premium features in the Coffee Table Book. Contact Vishal Parmar to discuss the right fit for your brand.\n              </div>\n            </details>\n          </div>\n        </section>\n\n        \n        <section id=\"coffee-table-book\" class=\"scroll-mt-24\" data-kid=\"237\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"238\">\n            <div class=\"w-12 h-12 bg-[var(--primary-green)] text-white rounded-2xl flex items-center justify-center shadow-lg\" data-kid=\"239\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open\" data-kid=\"240\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\" data-kid=\"241\"></path><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\" data-kid=\"242\"></path></svg>\n            </div>\n            <h2 class=\"text-3xl font-bold text-[var(--dark-green)] font-['Inter']\" data-kid=\"243\">Coffee Table Book</h2>\n          </div>\n          <div class=\"space-y-4\" data-kid=\"244\">\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"245\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"246\">\n                <span data-kid=\"247\">How can I get featured in the Coffee Table Book?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"248\"><path d=\"m6 9 6 6 6-6\" data-kid=\"249\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"250\">\n                You can apply for an \"Inside Feature Story\" starting at ₹5,000 (Members) to ₹15,000 (Open). Ad slots and cover stories are also available. This book features the Top 50 Sustainable Leaders of India.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"251\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"252\">\n                <span data-kid=\"253\">How many copies of the Coffee Table Book are printed?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"254\"><path d=\"m6 9 6 6 6-6\" data-kid=\"255\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"256\">\n                We print 5,000 premium physical copies distributed to industry leaders, government offices, and delegates. Additionally, it has a digital reach of over 5,00,000 sustainable enthusiasts.\n              </div>\n            </details>\n\n            <details class=\"accordion-item group border border-gray-100 rounded-2xl bg-white shadow-sm hover:shadow-md transition-all overflow-hidden\" data-kid=\"257\">\n              <summary class=\"list-none cursor-pointer p-6 flex items-center justify-between text-lg font-bold text-[var(--dark-green)] select-none\" data-kid=\"258\">\n                <span data-kid=\"259\">Is there GST on Coffee Table Book pricing?</span>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down text-[var(--primary-green)] transition-transform duration-300\" data-kid=\"260\"><path d=\"m6 9 6 6 6-6\" data-kid=\"261\"></path></svg>\n              </summary>\n              <div class=\"px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-50 pt-4\" data-kid=\"262\">\n                No, GST is not applicable on the current pricing for Golden preneur 2026.\n              </div>\n            </details>\n          </div>\n        </section>\n      </div>\n    </div>\n  </main>\n\n  \n  <section class=\"bg-[var(--dark-green)] py-20 px-6 mt-20 relative overflow-hidden\" data-kid=\"263\">\n    \n    <div class=\"absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2\" data-kid=\"264\"></div>\n    <div class=\"absolute bottom-0 left-0 w-96 h-96 bg-[var(--primary-green)]/10 rounded-full translate-y-1/2 -translate-x-1/2\" data-kid=\"265\"></div>\n\n    <div class=\"max-w-7xl mx-auto relative z-10 grid md:grid-cols-2 gap-16 items-center\" data-kid=\"266\">\n      <div data-kid=\"267\">\n        <h2 class=\"text-white text-4xl md:text-5xl font-bold mb-8 leading-tight\" data-kid=\"268\">Can't find what you're looking for?</h2>\n        <p class=\"text-white/70 text-lg mb-10 leading-relaxed\" data-kid=\"269\">\n          Our team is dedicated to supporting India's green movement. If you have any specific query or need help with your application, reach out directly.\n        </p>\n        \n        <div class=\"flex flex-col sm:flex-row gap-4 mb-8\" data-kid=\"270\">\n          <a href=\"https://wa.me/917041151714\" class=\"inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-5 rounded-2xl font-bold text-lg hover:shadow-2xl transition-all hover:-transl