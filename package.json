{
  "name": "grenpreneur-new",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server.js",
    "dev:api": "npm --prefix backend/backend run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:api\"",
    "build": "node -e \"const fs = require('fs'); if (fs.existsSync('./node_modules/typescript')) { require('child_process').execSync('tsc -b && vite build', {stdio: 'inherit'}); } else { console.log('Skipping build step: devDependencies not installed.'); }\"",
    "start": "node backend/backend/server.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.40.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "multer": "^2.1.1",
    "mysql2": "^3.14.0",
    "nodemailer": "^6.10.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.16"
  }
}
